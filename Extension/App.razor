@using Extension.Models
@using Extension.Services
@using Extension.Services.JsBindings
@using Extension.Services.Port
@using WebExtensions.Net.Runtime
@inject NavigationManager navManager
@inject ILogger<App> logger
@inject IAppBwPortService appBwPortService
@inject AppCache appCache
@inject IJsRuntimeAdapter jsRuntimeAdapter
@inject IJSRuntime jsRuntime

@implements IAsyncDisposable

@code {
    // Fields
    private bool _isInitialized;

    // Properties
    // InitialUri captures the URI from which the app was loaded. This is used by Index.razor for popup routing (e.g., ?popupType=selectAuthorize).
    public static Uri? InitialUri { get; set; }

    /// <summary>
    /// The context type from which the app was loaded (e.g., TAB, POPUP, SIDEPANEL).
    /// Set during OnInitializedAsync from globalThis.__EXT_CONTEXT__.type.
    /// Defaults to null if the context is not set or cannot be mapped.
    /// </summary>
    public static ContextType? AppContext { get; private set; }

    public static bool IsInPopup => AppContext == ContextType.POPUP;
    public static bool IsInSidePanel => AppContext == ContextType.SIDEPANEL;
    public static bool IsInTab => AppContext == ContextType.TAB;

    protected override async Task OnInitializedAsync()
    {
        logger.LogInformation("OnInitializedAsync");

        // Capture initial URI synchronously before any async work (URI won't change)
        InitialUri = navManager.ToAbsoluteUri(navManager.Uri);
        logger.LogInformation("InitialUri: {u}", InitialUri.ToString());

        // Read the extension context from globalThis.__EXT_CONTEXT__ set in the index HTML page
        await ReadAppContextAsync();

        // Initialize AppCache and connect to BackgroundWorker in parallel.
        // Both poll for BW readiness via different mechanisms (storage vs sendMessage),
        // so overlapping them avoids waiting for BW twice sequentially.
        var cacheTask = appCache.EnsureInitializedAsync();
        var connectTask = appBwPortService.ConnectAsync();
        await Task.WhenAll(cacheTask, connectTask);
        logger.LogInformation("Connected to BackgroundWorker via port, portSessionId={PortSessionId}, originTabId={OriginTabId}",
            appBwPortService.PortSessionId, appBwPortService.OriginTabId);

        // If we're on a page that requires being authenticated (unlocked), but we're no longer authenticated, navigate to the context-appropriate index page for redirection, e.g. to UnlockPage.
        // Note: "/index.html" is a Blazor route alias for RouterPage (which does not require auth),
        // but it's not in Routes.Pages so PathRequiresAuth would incorrectly return true for it.
        var currentRelative = navManager.ToBaseRelativePath(navManager.Uri);
        var currentPath = "/" + currentRelative.Split('?')[0];
        if (!appCache.IsAuthenticated && currentPath != "/index.html" && Routes.PathRequiresAuth(currentPath))
        {
            // This situation may occur if user exited Chrome while on an unlocked page, then after session expiration time, re-launched Chrome that re-opens page requiring authorization, such as Dashboard.html.
            // forceLoad reloads as TAB context. Popup/SidePanel contexts are opened fresh by Chrome, not reloaded here.
            // Must NOT navigate back to InitialUri — that's the current auth-required page, which would cause an infinite reload loop.
            // forceLoad uses the physical index.html (not the Blazor route) to trigger a full browser reload
            logger.LogInformation("Not authenticated on auth-required page, redirecting to index.html");
            navManager.NavigateTo("/index.html", true);
            return;
        }

        // Once the above is in place, the UI and other components that may rely on above state is ready to proceed
        _isInitialized = true;
        logger.LogInformation("OnInitializedAsync complete");
    }

    /// <summary>
    /// Reads the extension context from globalThis.__EXT_CONTEXT__ set in the HTML page.
    /// Sets AppContext to the mapped ContextType enum value (TAB, POPUP, SIDEPANEL) or null if not set/unknown.
    /// When the synchronous detection defaulted to TAB (no ?context= query param),
    /// verifies via chrome.runtime.getContexts() since the service worker's setOptions/setPopup
    /// may not have completed before the page loaded.
    /// </summary>
    private async Task ReadAppContextAsync()
    {
        try
        {
            var globalThis = new GlobalThisBinding(jsRuntimeAdapter);
            var hasCtx = await globalThis.HasAsync("__EXT_CONTEXT__");
            if (hasCtx)
            {
                var ctx = await globalThis.GetAsync<ExtContext>("__EXT_CONTEXT__");
                AppContext = MapStringToContextType(ctx?.Type);

                // When context defaulted to TAB (no ?context= query param), verify using
                // chrome.runtime.getContexts() since the service worker's setOptions/setPopup
                // may not have completed before the page loaded.
                if (AppContext == ContextType.TAB)
                {
                    var verified = await jsRuntime.InvokeAsync<string>("__verifyExtContext");
                    var verifiedContext = MapStringToContextType(verified);
                    switch (verifiedContext)
                    {
                        case ContextType.SIDEPANEL:
                        case ContextType.POPUP:
                            logger.LogInformation("Context verified from TAB to {ctx}", verifiedContext);
                            AppContext = verifiedContext.Value;
                            await jsRuntime.InvokeVoidAsync("__updateExtContext", verified);
                            break;
                        case ContextType.TAB:
                            break;
                        default:
                            logger.LogWarning("Unexpected verified context: {ctx}, keeping TAB", verified);
                            break;
                    }
                }

                logger.LogInformation("AppContext: {ctx}", AppContext?.ToString() ?? "null");
            }
            else
            {
                logger.LogWarning("globalThis.__EXT_CONTEXT__ not found, AppContext will be null");
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Failed to read AppContext from globalThis.__EXT_CONTEXT__");
        }
    }

    /// <summary>
    /// Maps the string context type from HTML to the WebExtensions.Net.Runtime.ContextType enum.
    /// </summary>
    private static ContextType? MapStringToContextType(string? contextString)
    {
        return contextString?.ToUpperInvariant() switch
        {
            "TAB" => ContextType.TAB,
            "POPUP" => ContextType.POPUP,
            "SIDEPANEL" => ContextType.SIDEPANEL,
            "OPTIONS" => ContextType.TAB, // OPTIONS page runs in a tab context
            _ => null
        };
    }

    public async ValueTask DisposeAsync()
    {
        this.UnsubscribeFromAppCache();
        await appBwPortService.DisposeAsync();
        GC.SuppressFinalize(this);
    }
}

@if (!_isInitialized)
{
    <!-- Themed placeholder while AppCache and BW port initialize.
         Uses CSS vars set by splashTheme.js so background matches the HTML splash seamlessly. -->
    <div style="width:100vw; height:100vh; background-color: var(--splash-bg, #f5f5f5); display:flex; align-items:center; justify-content:center; position:relative;">
        <img class="splash-fade-out" style="display:block; width:180px; height:180px;" src="images/logo180.png" alt="logo" />
        <span class="splash-fade-out" style="position:absolute; top:calc(50% + 105px); left:0; right:0; text-align:center; font-family: 'Segoe UI', sans-serif; font-size: 2.5rem; font-variant: small-caps; font-weight: 700; color: var(--splash-fg, #212121);">DIGN</span>
    </div>
}
else
{
    <Router AppAssembly="@typeof(Program).Assembly">
        <Found Context="routeData">
            <PageTitle>@AppConfig.ProductName</PageTitle>
            <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
        </Found>
        <NotFound>
            <PageTitle>@AppConfig.ProductName</PageTitle>
            <LayoutView>
                <h1>Page not found</h1>
                <p role="alert">Sorry, there's nothing at this address</p>
            </LayoutView>
        </NotFound>
    </Router>
}
