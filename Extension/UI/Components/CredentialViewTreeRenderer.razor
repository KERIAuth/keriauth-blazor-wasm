@using Extension.Models

@code {
    [Parameter, EditorRequired]
    public required CredentialViewTree Tree { get; init; }

    [Parameter]
    public CredentialViewOptions ViewOptions { get; set; } = new();

    [Parameter]
    public Dictionary<string, bool> DisclosureState { get; set; } = new();

    [Parameter]
    public EventCallback<(string Path, bool Disclosed)> OnDisclosureToggle { get; set; }

    /// <summary>
    /// Extra indent levels applied to rows this tree (and its chained trees) renders.
    /// Passed in when the tree is rendered inside another tree's chain slot so that
    /// nested credentials indent further than their parent.
    /// </summary>
    [Parameter]
    public int DepthOffset { get; set; }

    /// <summary>
    /// True when this tree is a chained credential under another. When true, emits a
    /// header row labeling the chained credential and indents its contents one level deeper.
    /// When false (root), no header row — the caller (CredentialComponent) owns the outer chrome.
    /// </summary>
    [Parameter]
    public bool IsNested { get; set; }

    /// <summary>
    /// Unique path prefix for this tree's nodes in the shared DisclosureState dictionary.
    /// When a tree is rendered inline under a SaidReference (chain-under-edge visualization),
    /// the host passes a prefix such as <c>sad.e.auth.n/</c> so the inline chain's internal
    /// node paths (e.g., <c>sad.a</c>) don't collide with same-keyed nodes elsewhere in the
    /// overall tree. Root tree uses the empty string.
    /// </summary>
    [Parameter]
    public string PathPrefix { get; set; } = "";

    /// <summary>
    /// Flat map from credential SAID (sad.d) to its view tree, built at the root render pass
    /// over all nested chains. Provided via cascading value so a SaidReference anywhere in the
    /// tree can resolve to a sibling/nested chained credential and render it inline.
    /// </summary>
    [CascadingParameter(Name = "ChainIndex")]
    public Dictionary<string, CredentialViewTree>? ChainIndex { get; set; }

    /// <summary>
    /// SAIDs of chained credentials that have been consumed by an inline SaidReference render
    /// elsewhere in the tree — those chains are suppressed from their original top-level
    /// ChainedCredentials position to avoid double-rendering.
    /// </summary>
    [CascadingParameter(Name = "ConsumedChainSaids")]
    public HashSet<string>? ConsumedChainSaids { get; set; }

    async Task HandleDisclosureToggle((string Path, bool Disclosed) args) {
        await OnDisclosureToggle.InvokeAsync(args);
    }

    int ChildDepthOffset => IsNested ? DepthOffset + 1 : DepthOffset;

    string HeaderRowStyle() =>
        $"--bt-indent: {DepthOffset * 1.25:0.##}rem";

    bool IsRootRender => !IsNested && ChainIndex is null;

    // Computed lazily at the root render; null elsewhere.
    Dictionary<string, CredentialViewTree>? _rootChainIndex;
    HashSet<string>? _rootConsumedChainSaids;

    Dictionary<string, CredentialViewTree> EffectiveChainIndex =>
        _rootChainIndex ?? ChainIndex ?? [];

    HashSet<string> EffectiveConsumedChainSaids =>
        _rootConsumedChainSaids ?? ConsumedChainSaids ?? [];

    protected override void OnParametersSet() {
        if (!IsRootRender) {
            _rootChainIndex = null;
            _rootConsumedChainSaids = null;
            return;
        }

        var index = new Dictionary<string, CredentialViewTree>();
        BuildChainIndex(Tree, index, new HashSet<CredentialViewTree>());

        var consumed = new HashSet<string>();
        CollectConsumedFromTree(Tree, index, consumed);

        _rootChainIndex = index;
        _rootConsumedChainSaids = consumed;
    }

    static void BuildChainIndex(
        CredentialViewTree tree,
        Dictionary<string, CredentialViewTree> index,
        HashSet<CredentialViewTree> visited) {
        if (!visited.Add(tree)) return;
        foreach (var chain in tree.ChainedCredentials) {
            if (chain.CredentialSaid is { Length: > 0 } said && !index.ContainsKey(said)) {
                index[said] = chain;
            }
            BuildChainIndex(chain, index, visited);
        }
    }

    static void CollectConsumedFromTree(
        CredentialViewTree tree,
        Dictionary<string, CredentialViewTree> index,
        HashSet<string> consumed) {
        CollectConsumedFromNodes(tree.Children, index, consumed);
        foreach (var chain in tree.ChainedCredentials) {
            CollectConsumedFromTree(chain, index, consumed);
        }
    }

    static void CollectConsumedFromNodes(
        List<CredentialViewNode> nodes,
        Dictionary<string, CredentialViewTree> index,
        HashSet<string> consumed) {
        foreach (var node in nodes) {
            if (node.Kind == CredentialViewNodeKind.SaidReference
                && node.SaidDigest is { Length: > 0 } said
                && index.ContainsKey(said)) {
                consumed.Add(said);
            }
            CollectConsumedFromNodes(node.Children, index, consumed);
        }
    }
}

@{
    var chainIndex = EffectiveChainIndex;
    var consumedChainSaids = EffectiveConsumedChainSaids;
}

<CascadingValue Value="@chainIndex" Name="ChainIndex" IsFixed="false">
    <CascadingValue Value="@consumedChainSaids" Name="ConsumedChainSaids" IsFixed="false">

        @if (IsNested)
        {
            <div class="bt-credview-row" style="@HeaderRowStyle()">
                <div class="bt-credview-gutter"></div>
                <div class="bt-credview-content bt-credview-content-field bt-credview-text-schema bt-chain-separator">
                    <LabelWithProvenance Label="@(Tree.ShortName ?? Tree.SchemaTitle)"
                                         ViewSpecLabel="@Tree.ShortName"
                                         SchemaDescription="@Tree.SchemaTitle"
                                         FieldKey="@Tree.CredentialSaid" />
                </div>
            </div>
        }

        @foreach (var node in Tree.Children)
        {
            <CredentialViewNodeRenderer Node="@node"
                                        ViewOptions="@ViewOptions"
                                        DisclosureState="@DisclosureState"
                                        OnDisclosureToggle="@HandleDisclosureToggle"
                                        DepthOffset="@ChildDepthOffset"
                                        PathPrefix="@PathPrefix" />
        }
        @for (var i = 0; i < Tree.ChainedCredentials.Count; i++)
        {
            var chained = Tree.ChainedCredentials[i];
            @* Skip chains that were inlined under a matching SaidReference elsewhere in the tree. *@
            if (chained.CredentialSaid is { Length: > 0 } said && consumedChainSaids.Contains(said))
            {
                continue;
            }
            <CredentialViewTreeRenderer Tree="@chained"
                                         ViewOptions="@ViewOptions"
                                         DisclosureState="@DisclosureState"
                                         OnDisclosureToggle="@HandleDisclosureToggle"
                                         DepthOffset="@ChildDepthOffset"
                                         IsNested="true"
                                         PathPrefix="@($"{PathPrefix}chains[{i}]/")" />
        }

    </CascadingValue>
</CascadingValue>
