@using Extension.Models

@code {
    [Parameter, EditorRequired]
    public required CredentialViewTree Tree { get; init; }

    [Parameter]
    public CredentialViewOptions ViewOptions { get; set; } = new();

    [Parameter]
    public Dictionary<string, bool> DisclosureState { get; set; } = new();

    [Parameter]
    public EventCallback<(string Path, bool Disclosed)> OnDisclosureToggle { get; set; }

    /// <summary>
    /// Extra indent levels applied to rows this tree (and its chained trees) renders.
    /// Passed in when the tree is rendered inside another tree's chain slot so that
    /// nested credentials indent further than their parent.
    /// </summary>
    [Parameter]
    public int DepthOffset { get; set; }

    /// <summary>
    /// True when this tree is a chained credential under another. When true, emits a
    /// header row labeling the chained credential and indents its contents one level deeper.
    /// When false (root), no header row — the caller (CredentialComponent) owns the outer chrome.
    /// </summary>
    [Parameter]
    public bool IsNested { get; set; }

    async Task HandleDisclosureToggle((string Path, bool Disclosed) args) {
        await OnDisclosureToggle.InvokeAsync(args);
    }

    int ChildDepthOffset => IsNested ? DepthOffset + 1 : DepthOffset;

    string HeaderRowStyle() =>
        $"--bt-indent: {DepthOffset * 1.25:0.##}rem";
}

@if (!IsNested && !string.IsNullOrEmpty(Tree.SchemaDescription))
{
    <MudText Typo="Typo.caption">@Tree.SchemaDescription</MudText>
}

@if (IsNested)
{
    <div class="bt-credview-row" style="@HeaderRowStyle()">
        <div class="bt-credview-gutter"></div>
        <div class="bt-credview-content bt-credview-content-field bt-credview-text-schema">
            <b>@(Tree.ShortName ?? Tree.SchemaTitle)</b>
        </div>
    </div>
}

@foreach (var node in Tree.Children)
{
    <CredentialViewNodeRenderer Node="@node"
                                ViewOptions="@ViewOptions"
                                DisclosureState="@DisclosureState"
                                OnDisclosureToggle="@HandleDisclosureToggle"
                                DepthOffset="@ChildDepthOffset" />
}
@foreach (var chained in Tree.ChainedCredentials)
{
    <CredentialViewTreeRenderer Tree="@chained"
                                 ViewOptions="@ViewOptions"
                                 DisclosureState="@DisclosureState"
                                 OnDisclosureToggle="@HandleDisclosureToggle"
                                 DepthOffset="@ChildDepthOffset"
                                 IsNested="true" />
}
