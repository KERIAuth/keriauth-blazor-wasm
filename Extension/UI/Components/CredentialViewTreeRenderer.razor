@using Extension.Models

@code {
    [Parameter, EditorRequired]
    public required CredentialViewTree Tree { get; init; }

    [Parameter]
    public CredentialViewOptions ViewOptions { get; set; } = new();

    [Parameter]
    public Dictionary<string, bool> DisclosureState { get; set; } = new();

    [Parameter]
    public EventCallback<(string Path, bool Disclosed)> OnDisclosureToggle { get; set; }

    [Parameter]
    public bool IsNested { get; set; }

    async Task HandleDisclosureToggle((string Path, bool Disclosed) args) {
        await OnDisclosureToggle.InvokeAsync(args);
    }
}

@if (IsNested)
{
    <MudExpansionPanel Text="@(Tree.ShortName ?? Tree.SchemaTitle)" Dense="true" Class="mt-1">
        <MudStack Spacing="1" Class="pa-2">
            @foreach (var node in Tree.Children)
            {
                <CredentialViewNodeRenderer Node="@node"
                                            ViewOptions="@ViewOptions"
                                            DisclosureState="@DisclosureState"
                                            OnDisclosureToggle="@HandleDisclosureToggle" />
            }
            @foreach (var chained in Tree.ChainedCredentials)
            {
                <CredentialViewTreeRenderer Tree="@chained"
                                             ViewOptions="@ViewOptions"
                                             DisclosureState="@DisclosureState"
                                             OnDisclosureToggle="@HandleDisclosureToggle"
                                             IsNested="true" />
            }
        </MudStack>
    </MudExpansionPanel>
}
else
{
    <MudStack Spacing="1">
        @if (!string.IsNullOrEmpty(Tree.SchemaDescription))
        {
            <MudText Typo="Typo.caption">@Tree.SchemaDescription</MudText>
        }
        @foreach (var node in Tree.Children)
        {
            <CredentialViewNodeRenderer Node="@node"
                                        ViewOptions="@ViewOptions"
                                        DisclosureState="@DisclosureState"
                                        OnDisclosureToggle="@HandleDisclosureToggle" />
        }
        @foreach (var chained in Tree.ChainedCredentials)
        {
            <CredentialViewTreeRenderer Tree="@chained"
                                         ViewOptions="@ViewOptions"
                                         DisclosureState="@DisclosureState"
                                         OnDisclosureToggle="@HandleDisclosureToggle"
                                         IsNested="true" />
        }
    </MudStack>
}
