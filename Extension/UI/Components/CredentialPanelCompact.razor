@using static Extension.Helper.CredentialHelper
@using Extension.Services

@inject AppCache appCache

@code {
    [Parameter, EditorRequired]
    public required RecursiveDictionary Credential { get; init; }

    [Parameter]
    public bool IsSelected { get; set; }

    string Title => Credential.GetValueByPath("schema.title")?.Value?.ToString() ?? "Credential";

    string? Val(string field) => Credential.GetValueByPath($"sad.a.{field}")?.Value?.ToString();

    string DistinguishingAttr => GetCredentialType(Credential.GetValueByPath("sad.s")?.Value?.ToString()) switch {
        CredentialType.OorCredential => Val("officialRole") ?? "",
        CredentialType.OorAuthCredential => Val("officialRole") ?? "",
        CredentialType.EcrCredential => Val("engagementContextRole") ?? "",
        CredentialType.EcrAuthCredential => Val("engagementContextRole") ?? "",
        CredentialType.SediCredential => string.Join(" ", new[] { Val("firstName"), Val("lastName") }.Where(s => !string.IsNullOrEmpty(s))),
        CredentialType.VleiCredential => Val("LEI") ?? "",
        CredentialType.QviCredential => Val("LEI") ?? "",
        CredentialType.DataAttestation => TruncateDigest(Val("digest")),
        CredentialType.DataAttestationCredential => TruncateDigest(Val("digest")),
        CredentialType.IxbrlAttestation => "",
        _ => ""
    };

    static string TruncateDigest(string? digest) =>
        digest is { Length: > 16 } ? $"{digest[..16]}…" : digest ?? "";

    string ContainerStyle => $"background-color: {GetBackgroundColor(Credential, appCache.MyPreferences.IsDarkTheme)}; border-radius: 8px;";
    string ContainerClass => IsSelected ? "credential-compact selected-credential" : "credential-compact";
}

<MudPaper Class="@ContainerClass" Style="@ContainerStyle" Elevation="1">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="pa-2" Spacing="2">
        <MudText Typo="Typo.body2"><strong>@Title</strong></MudText>
        @if (!string.IsNullOrEmpty(DistinguishingAttr))
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">&bull; @DistinguishingAttr</MudText>
        }
    </MudStack>
</MudPaper>
