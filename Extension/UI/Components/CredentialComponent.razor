@using static Extension.Helper.Identicon
@using static Extension.Helper.CredentialHelper
@using System.Text.Json
@using Extension.Helper
@using Extension.Models
@using Extension.Models.Messages.AppBw.Requests
@using Extension.Models.Messages.AppBw.Responses
@using Extension.Services
@using Extension.Services.Port
@using Extension.Services.SignifyService.Models

@inject IJSRuntime js
@inject AppCache appCache
@inject ICredentialViewSpecService viewSpecService
@inject IAppBwPortService appBwPortService
@inject ILogger<CredentialComponent> logger

@code {
    [Parameter, EditorRequired]
    public required RecursiveDictionary Credential { get; init; }

    [Parameter]
    public CredentialViewOptions ViewOptions { get; set; } = new();

    [Parameter]
    public bool Expanded { get; set; }

    [Parameter]
    public bool IsExpandable { get; set; } = true;

    [Parameter]
    public EventCallback<bool> ExpandedChanged { get; set; }

    [Parameter]
    public RenderFragment? Actions { get; set; }

    [Parameter]
    public bool IsSelected { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    [Parameter]
    public EventCallback<Dictionary<string, bool>> ElisionMapChanged { get; set; }

    // Elision state for presentation mode
    Dictionary<string, bool> elisionMap = new();

    // Presentation-time filled credential: deep copy of Credential with empty d fields
    // (sad.e.d, sad.r.d, and any chained-credential equivalents) populated via signify-ts
    // Saider.saidify. Null while filling or on failure.
    RecursiveDictionary? _filledCredential;
    string? _filledForSaid;
    bool _isFilling;

    RecursiveDictionary EffectiveCredential => _filledCredential ?? Credential;

    // Pipeline-generated view tree (recomputed when Credential or ViewOptions change)
    CredentialViewTree? PipelineTree {
        get {
            try {
                var cloned = ClonedCredential.FromRecursiveDictionary(EffectiveCredential);
                return CredentialViewPipeline.BuildFullTree(cloned, viewSpecService, ViewOptions);
            } catch {
                return null;
            }
        }
    }

    protected override void OnInitialized() {
        InitializeElisionMap();
    }

    protected override async Task OnParametersSetAsync() {
        // Only refill when the incoming credential changes identity. Many re-renders are
        // triggered by elision toggles, cache events, etc.; those keep the same sad.d.
        var incomingSaid = Credential.GetValueByPath("sad.d")?.Value?.ToString();
        if (string.IsNullOrEmpty(incomingSaid) || incomingSaid == _filledForSaid) {
            return;
        }

        _isFilling = true;
        _filledCredential = null;
        _filledForSaid = incomingSaid;
        StateHasChanged();

        try {
            var filled = await CredentialSaidFiller.FillMissingSaidsAsync(Credential, SaidifyBlockAsync);
            if (filled is not null) {
                _filledCredential = filled;
            }
            else {
                logger.LogWarning(nameof(CredentialComponent) + ": SAID fill returned null for credential {Said}; falling back to raw credential", incomingSaid);
            }
        }
        catch (Exception ex) {
            logger.LogError(ex, nameof(CredentialComponent) + ": SAID fill threw for credential {Said}", incomingSaid);
        }
        finally {
            _isFilling = false;
        }
    }

    async Task<string?> SaidifyBlockAsync(RecursiveDictionary block) {
        var rpc = await appBwPortService.SendRequestAsync<RequestSaidifyPayload, SaidifyResponse>(
            new AppBwRequestSaidifyMessage(block));
        if (rpc.IsFailed || rpc.Value is null || !rpc.Value.Success) {
            return null;
        }
        return rpc.Value.Said;
    }

    void InitializeElisionMap() {
        elisionMap = new Dictionary<string, bool>();
        if (ViewOptions.PreselectedPresentationPaths is not null) {
            foreach (var path in ViewOptions.PreselectedPresentationPaths) {
                elisionMap[path] = true;
            }
        }
    }

    async Task OnElisionMapChanged(Dictionary<string, bool> newMap) {
        elisionMap = newMap;
        await ElisionMapChanged.InvokeAsync(newMap);
    }

    async Task OnDisclosureToggled((string Path, bool Disclosed) args) {
        elisionMap = new Dictionary<string, bool>(elisionMap) { [args.Path] = args.Disclosed };
        await ElisionMapChanged.InvokeAsync(elisionMap);
    }

    // Schema SAID and ViewSpec resolution
    string? SchemaSaid => Credential.GetValueByPath("sad.s")?.Value?.ToString();
    CredentialViewSpec ResolvedViewSpec => viewSpecService.GetOrCreateFallback(SchemaSaid ?? "");

    // Title row
    string SchemaTitle => Credential.GetValueByPath("schema.title")?.Value?.ToString() ?? ResolvedViewSpec.ShortName;
    string ShortName => ResolvedViewSpec.ShortName;

    string RoleOrContext {
        get {
            var ecr = Credential.GetValueByPath("sad.a.engagementContextRole")?.Value?.ToString();
            var oor = Credential.GetValueByPath("sad.a.officialRole")?.Value?.ToString();
            return ecr ?? oor ?? string.Empty;
        }
    }

    string Subtitle {
        get {
            var lei = Credential.GetValueByPath("sad.a.LEI")?.Value?.ToString();
            var issuer = Credential.GetValueByPath("sad.i")?.Value?.ToString();
            var issuerShort = ElideText(issuer, 12, 0);
            return lei is not null && lei.Length > 8
                ? $"LEI: {ElideText(lei, 8, 0)}"
                : (!string.IsNullOrEmpty(issuerShort) ? issuerShort : "Unknown Issuer");
        }
    }

    // Styling
    string PanelStyle => $"background-color: {GetBackgroundColor(Credential, appCache.MyPreferences.IsDarkTheme)};";
    string PanelClass => IsSelected ? "credential-panel selected-credential" : "credential-panel";

    // AID context resolution
    string? IssuerPrefix => Credential.GetValueByPath("sad.i")?.Value?.ToString();
    string? IssueePrefix => Credential.GetValueByPath("sad.a.i")?.Value?.ToString();

    (string? ProfileName, string? ConnectionName) IssuerContext => ResolveAidContext(IssuerPrefix);
    (string? ProfileName, string? ConnectionName) IssueeContext => ResolveAidContext(IssueePrefix);

    (string? ProfileName, string? ConnectionName) ResolveAidContext(string? prefix) {
        if (prefix is null) return (null, null);
        var aid = appCache?.Aids?.FirstOrDefault(a => a.Prefix == prefix);
        string? profileName = (aid is not null && !string.IsNullOrEmpty(aid.Name)) ? aid.Name : null;
        var conn = appCache?.MyConnections?.FirstOrDefault(c => c.ReceiverPrefix == prefix);
        string? connName = conn?.Name;
        return (profileName, connName);
    }

    async Task ToggleExpanded() {
        Expanded = !Expanded;
        await ExpandedChanged.InvokeAsync(Expanded);
    }

    async Task HandleClick() {
        if (OnClick.HasDelegate) {
            await OnClick.InvokeAsync();
        }
    }

    string? CredentialJson => JsonSerializer.Serialize(EffectiveCredential.ToObjectDictionary(), JsonOptions.Display);

    async Task CopyJsonToClipboard() {
        if (CredentialJson is not null) {
            await js.InvokeVoidAsync("navigator.clipboard.writeText", CredentialJson);
        }
    }
}



@* --- Shared credential body: title + description + content --- *@
@{
    RenderFragment credentialBody = @<text>
        <MudTooltip Text="@SchemaTitle" Delay="300">
            <MudText Class="bt-card-title">@ShortName</MudText>
        </MudTooltip>
        @if (ViewOptions.DetailLevel >= CredentialDetailLevel.Detailed
             && !string.IsNullOrEmpty(PipelineTree?.SchemaDescription))
        {
            <MudText Typo="Typo.body2"><em>@PipelineTree!.SchemaDescription</em></MudText>
        }
        <div class="bt-card-content">
            @if (_isFilling)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" />
            }
            @if (ViewOptions.DisplayType == CredentialDisplayType.Tree && PipelineTree is not null)
            {
                <CredentialViewTreeRenderer Tree="@PipelineTree"
                                             ViewOptions="@ViewOptions"
                                             DisclosureState="@elisionMap"
                                             OnDisclosureToggle="@OnDisclosureToggled" />
                @if (ViewOptions.DetailLevel >= CredentialDetailLevel.WithTechnicalDetails)
                {
                    <MudExpansionPanels Dense="true" Class="mt-3">
                        <MudExpansionPanel Text="Raw JSON" Dense="true">
                            <MudPaper Elevation="1" Class="pa-3" Style="overflow-x: auto;">
                                <MudText Style="white-space: pre; font-family: monospace; font-size: 0.75rem;">
                                    @CredentialJson
                                </MudText>
                                <MudButton Variant="Variant.Text"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.ContentCopy"
                                           OnClick="CopyJsonToClipboard">
                                    Copy JSON
                                </MudButton>
                            </MudPaper>
                        </MudExpansionPanel>
                    </MudExpansionPanels>
                }
            }
            else if (ViewOptions.DisplayType == CredentialDisplayType.Tree)
            {
                <MudAlert Severity="Severity.Warning">Unable to build credential view tree.</MudAlert>
            }
            else
            {
                <CredentialCardComponent Credential="@EffectiveCredential"
                                          Tree="@PipelineTree"
                                          ViewOptions="@ViewOptions"
                                          ElisionMap="@elisionMap"
                                          ElisionMapChanged="@OnElisionMapChanged"
                                          IssuerProfileName="@IssuerContext.ProfileName"
                                          IssuerConnectionName="@IssuerContext.ConnectionName"
                                          IssueeProfileName="@IssueeContext.ProfileName"
                                          IssueeConnectionName="@IssueeContext.ConnectionName" />
            }
        </div>
    </text>;
}

@if (!IsExpandable)
{
    @credentialBody
}
else
{
    <MudExpansionPanel Class="@PanelClass"
                       Gutters="false"
                       @bind-Expanded="Expanded"
                       Style="@PanelStyle">
        <TitleContent>
            @if (!Expanded)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="px-4 py-3">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudTooltip Text="@SchemaTitle" Delay="300">
                            <MudText Class="bt-card-title">@ShortName</MudText>
                        </MudTooltip>
                        <MudText Typo="Typo.caption">
                            @Subtitle @if (!string.IsNullOrEmpty(RoleOrContext)) { <text> &bull; @RoleOrContext</text> }
                        </MudText>
                    </MudStack>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        @Actions
                    </MudStack>
                </MudStack>
            }
            <MudDivider />
        </TitleContent>
        <ChildContent>
            <MudPaper Class="px-4 py-3" Elevation="0">
                @credentialBody
            </MudPaper>
        </ChildContent>
    </MudExpansionPanel>
}