@using BlazorBarcodeScanner.ZXing.JS
@inject IJSRuntime js
@inject ILogger<QrScanOverlay> logger

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public EventCallback<string> OnScanned { get; set; }
    [Parameter] public string? PreferredCameraDeviceId { get; set; }
    [Parameter] public EventCallback<string> OnCameraDeviceChanged { get; set; }
    [Parameter] public bool BeepOnScanSuccess { get; set; } = AppConfig.DefaultBeepOnScanSuccess;
    [Parameter] public EventCallback<bool> BeepOnScanSuccessChanged { get; set; }

    private BarcodeReader? _reader;
    private List<VideoInputDevice> _devices = [];
    private bool _hasMultipleCameras;
    private int _currentDeviceIdx;
    private IJSObjectReference? _audioModule;
    private IJSObjectReference? _cameraModule;
    private IJSObjectReference? _scriptLoader;
    private string? _cameraPermissionStatus;
    private bool _prevIsVisible;
    private bool _scriptsLoaded;

    // Works on Chrome, Edge, and Brave
    private string SiteDetailsUrl => $"chrome://settings/content/siteDetails?site=chrome-extension://{_extensionId}";
    private string _extensionId = "";

    private async Task EnsureBarcodeScannerScriptsAsync() {
        if (_scriptsLoaded) return;
        _scriptLoader ??= await js.InvokeAsync<IJSObjectReference>(
            "import", "./scripts/helpers/loadScript.js");
        await _scriptLoader.InvokeAsync<object>("loadScript",
            "content/BlazorBarcodeScanner.ZXing.JS/zxingjs.index.min.js");
        await _scriptLoader.InvokeAsync<object>("loadScript",
            "content/BlazorBarcodeScanner.ZXing.JS/BlazorBarcodeScanner.js");
        _scriptsLoaded = true;
    }

    protected override async Task OnInitializedAsync() {
        await EnsureBarcodeScannerScriptsAsync();
    }

    protected override async Task OnParametersSetAsync() {
        if (IsVisible && !_prevIsVisible) {
            _cameraPermissionStatus = null;
            _cameraModule ??= await js.InvokeAsync<IJSObjectReference>(
                "import", "./scripts/helpers/cameraHelper.js");
            if (string.IsNullOrEmpty(_extensionId)) {
                _extensionId = await _cameraModule.InvokeAsync<string>("getExtensionId");
            }
            _cameraPermissionStatus = await _cameraModule.InvokeAsync<string>("requestCameraPermission");
            await EnsureBarcodeScannerScriptsAsync();
        }
        else if (!IsVisible) {
            _cameraPermissionStatus = null;
        }
        _prevIsVisible = IsVisible;
    }

    private async Task OpenSiteSettings() {
        if (_cameraModule is not null) {
            await _cameraModule.InvokeVoidAsync("openInNewTab", SiteDetailsUrl);
        }
    }

    private async Task RetryPermission() {
        _cameraPermissionStatus = null;
        StateHasChanged();
        _cameraModule ??= await js.InvokeAsync<IJSObjectReference>(
            "import", "./scripts/helpers/cameraHelper.js");
        _cameraPermissionStatus = await _cameraModule.InvokeAsync<string>("requestCameraPermission");
    }

    private async Task OnBarcodeReceived(BarcodeReceivedEventArgs args) {
        if (string.IsNullOrEmpty(args.BarcodeText)) return;

        if (BeepOnScanSuccess) await PlayBeepAsync();
        await StopAndClose();
        await OnScanned.InvokeAsync(args.BarcodeText);
    }

    private void OnVideoInputDevicesChanged() {
        if (_reader?.VideoInputDevices is null) return;

        _devices = _reader.VideoInputDevices.ToList();
        _hasMultipleCameras = _devices.Count > 1;

        // logger.LogWarning("OnVideoInputDevicesChanged: {Count} devices, SelectedVideoInputId={SelectedId}, PreferredCameraDeviceId={PreferredId}", _devices.Count, _reader.SelectedVideoInputId ?? "(null)", PreferredCameraDeviceId ?? "(null)");

        // If we have a preferred camera and it differs from the auto-started one, switch to it.
        // SelectedVideoInputId may be empty during auto-start — still switch if we have a preference.
        if (!string.IsNullOrEmpty(PreferredCameraDeviceId)
            && PreferredCameraDeviceId != _reader.SelectedVideoInputId) {
            var idx = _devices.FindIndex(d => d.DeviceId == PreferredCameraDeviceId);
            if (idx >= 0) {
                _currentDeviceIdx = idx;
                _ = _reader.SelectVideoInput(_devices[idx]);
            }
        }

        // Apply continuous autofocus after camera stream is active
        _ = ApplyAutoFocusAsync();

        StateHasChanged();
    }

    private async Task OnNextCamera() {
        if (_reader is null || _devices.Count < 2) return;

        _currentDeviceIdx = (_currentDeviceIdx + 1) % _devices.Count;

        try {
            var device = _devices[_currentDeviceIdx];
            // logger.LogWarning("OnNextCamera: switching to device index={Idx}, DeviceId={DeviceId}", _currentDeviceIdx, device.DeviceId ?? "(null)");
            await _reader.SelectVideoInput(device);
            await ApplyAutoFocusAsync();
            if (!string.IsNullOrEmpty(device.DeviceId)) {
                // logger.LogWarning("OnNextCamera: invoking OnCameraDeviceChanged with DeviceId={DeviceId}", device.DeviceId);
                await OnCameraDeviceChanged.InvokeAsync(device.DeviceId);
            }
            else {
                // logger.LogWarning("OnNextCamera: device.DeviceId is null/empty, skipping OnCameraDeviceChanged");
            }
        }
        catch {
            // Camera may have been unplugged since enumeration
        }
    }

    private async Task ApplyAutoFocusAsync() {
        try {
            // Brief delay to let the camera stream initialize
            await Task.Delay(500);
            _cameraModule ??= await js.InvokeAsync<IJSObjectReference>(
                "import", "./scripts/helpers/cameraHelper.js");
            var applied = await _cameraModule.InvokeAsync<bool>("applyAutoFocus", "#qr-scan-overlay");
            logger.LogWarning("ApplyAutoFocusAsync: applied={Applied}", applied);
        }
        catch (Exception ex) {
            logger.LogWarning("ApplyAutoFocusAsync failed: {Error}", ex.Message);
        }
    }

    private async Task PlayBeepAsync() {
        try {
            _audioModule ??= await js.InvokeAsync<IJSObjectReference>(
                "import", "./scripts/helpers/audioHelper.js");
            await _audioModule.InvokeVoidAsync("playBeep", 800, 100);
        }
        catch (Exception ex) {
            logger.LogWarning("PlayBeepAsync failed: {Error}", ex.Message);
        }
    }

    private async Task StopAndClose() {
        if (_reader is not null) {
            await _reader.StopDecoding();
        }
        await IsVisibleChanged.InvokeAsync(false);
    }

    private async Task OnBeepToggled(bool value) {
        BeepOnScanSuccess = value;
        await BeepOnScanSuccessChanged.InvokeAsync(value);
    }

    private void OnErrorReceived(ErrorReceivedEventArgs args) {
        // Camera errors are non-fatal — user can try another camera or close
    }
}

@if (IsVisible)
{
    <MudOverlay Visible="true" DarkBackground="true" ZIndex="9999" OnClick="StopAndClose">
        <MudPaper id="qr-scan-overlay" Class="pa-4" Style="max-width: 400px; width: 90vw; max-height: calc(100vh - 24px); position: relative;" @onclick:stopPropagation="true">
            <MudIconButton Icon="@Icons.Material.Filled.Close"
                           OnClick="StopAndClose"
                           Style="position: absolute; top: 4px; right: 4px; z-index: 1;" />
            <MudStack>
                <MudText Typo="Typo.h6">Scan QR code</MudText>

                <div style="display: flex; justify-content: center;">
                    @if (_cameraPermissionStatus == "granted" && _scriptsLoaded)
                    {
                        @* Known console warnings from BlazorBarcodeScanner.ZXing.JS and its bundled zxingjs:
                           - "Trying to play video that is already playing."
                           - "Canvas2D: Multiple readback operations using getImageData are faster with the willReadFrequently attribute set to true."
                           - "Reset camera stream." and "undefined"
                           These originate inside the NuGet package's JS and cannot be fixed without changing the package. *@
                        <BarcodeReader @ref="_reader"
                                       Title=""
                                       StartCameraAutomatically="true"
                                       ShowStart="false"
                                       ShowStop="false"
                                       ShowReset="false"
                                       ShowToggleTorch="false"
                                       ShowVideoDeviceList="false"
                                       ShowResult="false"
                                       VideoWidth="260"
                                       VideoHeight="260"
                                       StreamWidth="720"
                                       StreamHeight="720"
                                       OnBarcodeReceived="OnBarcodeReceived"
                                       OnErrorReceived="OnErrorReceived"
                                       VideoInputDevicesChanged="OnVideoInputDevicesChanged"/>
                    }
                    else if (_cameraPermissionStatus == "blocked")
                    {
                        <MudStack Spacing="2" Style="max-width: 320px;">
                            <MudText Color="Color.Error" Align="Align.Center">
                                Camera is blocked in your browser settings.
                            </MudText>
                            <MudText Typo="Typo.body2" Align="Align.Left">
                                To fix this, open your extension's site settings and change Camera from "Block" to "Ask" or "Allow":
                            </MudText>
                            <MudLink OnClick="OpenSiteSettings" Typo="Typo.body2" Style="cursor: pointer;">
                                Open site settings
                                <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Style="vertical-align: middle; margin-left: 4px;" />
                            </MudLink>
                            <MudButton StartIcon="@Icons.Material.Filled.Refresh"
                                       OnClick="RetryPermission"
                                       Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       FullWidth="true">
                                Retry
                            </MudButton>
                        </MudStack>
                    }
                    else if (_cameraPermissionStatus == "denied")
                    {
                        <MudStack Spacing="2" Style="max-width: 320px;">
                            <MudText Color="Color.Error" Align="Align.Center">
                                Camera access was denied.
                            </MudText>
                            <MudText Typo="Typo.body2" Align="Align.Center">
                                Click Retry to be prompted again, or check your browser's site settings if the prompt does not appear.
                            </MudText>
                            <MudButton StartIcon="@Icons.Material.Filled.Refresh"
                                       OnClick="RetryPermission"
                                       Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       FullWidth="true">
                                Retry
                            </MudButton>
                        </MudStack>
                    }
                </div>

                @if (_hasMultipleCameras)
                {
                    <MudButton StartIcon="@Icons.Material.Filled.CameraAlt"
                               OnClick="OnNextCamera"
                               Variant="Variant.Outlined"
                               Color="Color.Primary"
                               FullWidth="true">
                        Next Camera
                    </MudButton>
                }
                <MudCheckBox T="bool"
                             Value="BeepOnScanSuccess"
                             ValueChanged="OnBeepToggled"
                             Label="Beep on success"
                             Dense="true"
                             Size="Size.Small" />
            </MudStack>
        </MudPaper>
    </MudOverlay>
}
