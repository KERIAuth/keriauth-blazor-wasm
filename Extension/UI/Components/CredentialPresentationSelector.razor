@using Extension.Helper
@using Extension.Models
@using Extension.Models.Messages.AppBw.Requests
@using Extension.Models.Messages.AppBw.Responses
@using Extension.Services
@using Extension.Services.Port
@using Extension.Services.SignifyService.Models

@inject ICredentialViewSpecService viewSpecService
@inject IAppBwPortService appBwPortService
@inject ILogger<CredentialPresentationSelector> logger

@code {
    [Parameter, EditorRequired]
    public required List<RecursiveDictionary> MatchingCredentials { get; init; }

    [Parameter]
    public string? SchemaSaid { get; set; }

    [Parameter]
    public EventCallback<string?> SelectedCredentialSaidChanged { get; set; }

    [Parameter]
    public EventCallback<Dictionary<string, bool>> ElisionMapChanged { get; set; }

    string? selectedCredentialSaid;
    string presentationView = "tree-full";
    Dictionary<string, bool> elisionMap = new();

    // Presentation-time SAID fill state (mirrors CredentialComponent).
    RecursiveDictionary? _filledCredential;
    string? _filledForSaid;
    bool _isFilling;

    CredentialViewOptions PresentationViewOptions => presentationView switch
    {
        "card-summary" => new(DisplayType: CredentialDisplayType.Card, DetailLevel: CredentialDetailLevel.WithOptionalSections, IsPresentation: true),
        "card-full" => new(DisplayType: CredentialDisplayType.Card, DetailLevel: CredentialDetailLevel.WithTechnicalDetails, IsPresentation: true),
        "tree-summary" => new(DisplayType: CredentialDisplayType.Tree, DetailLevel: CredentialDetailLevel.WithOptionalSections, IsPresentation: true),
        "tree-full" => new(DisplayType: CredentialDisplayType.Tree, DetailLevel: CredentialDetailLevel.WithTechnicalDetails, IsPresentation: true),
        _ => new(DisplayType: CredentialDisplayType.Tree, DetailLevel: CredentialDetailLevel.WithTechnicalDetails, IsPresentation: true)
    };

    RecursiveDictionary? SelectedCredential => selectedCredentialSaid is null
        ? null
        : MatchingCredentials.FirstOrDefault(c =>
            c.GetValueByPath("sad.d")?.Value?.ToString() == selectedCredentialSaid);

    RecursiveDictionary? EffectiveSelectedCredential =>
        _filledCredential ?? SelectedCredential;

    CredentialViewSpec ResolvedViewSpec => viewSpecService.GetOrCreateFallback(SchemaSaid ?? "");

    CredentialViewTree? PipelineTree {
        get {
            var src = EffectiveSelectedCredential;
            if (src is null) return null;
            try {
                var cloned = ClonedCredential.FromRecursiveDictionary(src);
                return CredentialViewPipeline.BuildFullTree(cloned, viewSpecService, PresentationViewOptions);
            } catch {
                return null;
            }
        }
    }

    protected override void OnInitialized()
    {
        selectedCredentialSaid = MatchingCredentials
            .FirstOrDefault()?.GetValueByPath("sad.d")?.Value?.ToString();
        if (selectedCredentialSaid is not null)
        {
            _ = SelectedCredentialSaidChanged.InvokeAsync(selectedCredentialSaid);
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        await EnsureFilledAsync();
    }

    async Task OnCredentialSelectionChanged(string? credSaid)
    {
        selectedCredentialSaid = credSaid;
        elisionMap = new();
        _filledCredential = null;
        _filledForSaid = null;
        await SelectedCredentialSaidChanged.InvokeAsync(credSaid);
        await ElisionMapChanged.InvokeAsync(elisionMap);
        await EnsureFilledAsync();
    }

    async Task EnsureFilledAsync()
    {
        var src = SelectedCredential;
        var incomingSaid = src?.GetValueByPath("sad.d")?.Value?.ToString();
        if (src is null || string.IsNullOrEmpty(incomingSaid) || incomingSaid == _filledForSaid)
        {
            return;
        }

        _isFilling = true;
        _filledCredential = null;
        _filledForSaid = incomingSaid;
        StateHasChanged();

        try
        {
            var filled = await CredentialSaidFiller.FillMissingSaidsAsync(src, SaidifyBlockAsync);
            if (filled is not null)
            {
                _filledCredential = filled;
            }
            else
            {
                logger.LogWarning(nameof(CredentialPresentationSelector) + ": SAID fill returned null for credential {Said}", incomingSaid);
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, nameof(CredentialPresentationSelector) + ": SAID fill threw for credential {Said}", incomingSaid);
        }
        finally
        {
            _isFilling = false;
        }
    }

    async Task<string?> SaidifyBlockAsync(RecursiveDictionary block)
    {
        var rpc = await appBwPortService.SendRequestAsync<RequestSaidifyPayload, SaidifyResponse>(
            new AppBwRequestSaidifyMessage(block));
        if (rpc.IsFailed || rpc.Value is null || !rpc.Value.Success)
        {
            return null;
        }
        return rpc.Value.Said;
    }

    async Task OnElisionMapChangedInternal(Dictionary<string, bool> map)
    {
        elisionMap = map;
        await ElisionMapChanged.InvokeAsync(map);
    }

    async Task OnDisclosureToggled((string Path, bool Disclosed) args)
    {
        elisionMap = new Dictionary<string, bool>(elisionMap) { [args.Path] = args.Disclosed };
        await ElisionMapChanged.InvokeAsync(elisionMap);
    }
}

@if (MatchingCredentials.Count == 0)
{
    <MudAlert Severity="Severity.Info" Class="mb-3">
        <MudText Typo="Typo.body2">You don't hold any credentials matching this request.</MudText>
        @if (SchemaSaid is not null)
        {
            <MudText Typo="Typo.caption">Schema SAID: <SaidDisplay Said="@SchemaSaid" /></MudText>
        }
    </MudAlert>
}
else
{
    <MudText Class="bt-section-title">Select credential to present <span style="font-weight: normal;">(@MatchingCredentials.Count matching)</span></MudText>
    <MudSelect T="string" Class="ml-4 mb-3"
               Value="@selectedCredentialSaid"
               ValueChanged="@OnCredentialSelectionChanged"
               Dense="true"
               Style="min-width: 300px;">
        @foreach (var credential in MatchingCredentials)
        {
            var credSaid = credential.GetValueByPath("sad.d")?.Value?.ToString();
            var schemaTitle = credential.GetValueByPath("schema.title")?.Value?.ToString() ?? "Credential";
            var lei = credential.GetValueByPath("sad.a.LEI")?.Value?.ToString();
            var displayText = lei is not null ? $"{schemaTitle} — {lei}" : schemaTitle;
            <MudSelectItem T="string" Value="@credSaid">@displayText</MudSelectItem>
        }
    </MudSelect>

    @if (SelectedCredential is not null)
    {
        <MudText Class="bt-section-title">Choose disclosures</MudText>
        <MudStack Spacing="0" Class="ml-4">
            <MudSelect T="string" @bind-Value="presentationView"
                       Label="View" Dense="true" Margin="Margin.Dense"
                       Variant="Variant.Outlined" Class="mb-3"
                       Style="min-width: 200px; flex-grow: 0;">
                <MudSelectItem T="string" Value="@("card-summary")">Card - Summary</MudSelectItem>
                <MudSelectItem T="string" Value="@("card-full")">Card - Full</MudSelectItem>
                <MudSelectItem T="string" Value="@("tree-summary")">Tree - Summary</MudSelectItem>
                <MudSelectItem T="string" Value="@("tree-full")">Tree - Full</MudSelectItem>
            </MudSelect>

            @if (_isFilling)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" />
            }
            @if (PresentationViewOptions.DisplayType == CredentialDisplayType.Tree && PipelineTree is not null)
            {
                <CredentialViewTreeRenderer Tree="@PipelineTree"
                                             ViewOptions="@PresentationViewOptions"
                                             DisclosureState="@elisionMap"
                                             OnDisclosureToggle="@OnDisclosureToggled" />
            }
            else if (PresentationViewOptions.DisplayType == CredentialDisplayType.Tree)
            {
                <MudAlert Severity="Severity.Warning">Unable to build credential view tree.</MudAlert>
            }
            else
            {
                <CredentialCardComponent Credential="@(EffectiveSelectedCredential ?? SelectedCredential)"
                                         Tree="@PipelineTree"
                                         ViewOptions="@PresentationViewOptions"
                                         ElisionMap="@elisionMap"
                                         ElisionMapChanged="@OnElisionMapChangedInternal" />
            }
        </MudStack>
    }
}
