@using System.Text.Json
@using Extension.Services.SignifyService.Models

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.LocalOffer" Color="Color.Primary" Class="mr-2" />
            Offer credential
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.subtitle2">Credential summary</MudText>
            <MudSimpleTable Dense="true" Elevation="0">
                <tbody>
                    <tr>
                        <td><MudText Typo="Typo.caption" Color="Color.Secondary">Schema</MudText></td>
                        <td><MudText Typo="Typo.body2">ECR (Engagement Context Role)</MudText></td>
                    </tr>
                    <tr>
                        <td><MudText Typo="Typo.caption" Color="Color.Secondary">Role</MudText></td>
                        <td><MudText Typo="Typo.body2">@EcrRole</MudText></td>
                    </tr>
                    <tr>
                        <td><MudText Typo="Typo.caption" Color="Color.Secondary">Issuer</MudText></td>
                        <td>
                            <MudTooltip Text="@IssuerPrefix" Delay="300">
                                <MudText Typo="Typo.body2">@Elide(IssuerPrefix, 6, 4)</MudText>
                            </MudTooltip>
                        </td>
                    </tr>
                    <tr>
                        <td><MudText Typo="Typo.caption" Color="Color.Secondary">Holder</MudText></td>
                        <td>
                            <MudTooltip Text="@HolderPrefix" Delay="300">
                                <MudText Typo="Typo.body2">@Elide(HolderPrefix, 6, 4)</MudText>
                            </MudTooltip>
                        </td>
                    </tr>
                </tbody>
            </MudSimpleTable>

            <MudExpansionPanels Dense="true">
                <MudExpansionPanel Text="Apply request JSON" Dense="true">
                    <MudPaper Elevation="1" Class="pa-3" Style="overflow-x: auto;">
                        <MudText Style="white-space: pre; font-family: monospace; font-size: 0.75rem;">
                            @ApplyJson
                        </MudText>
                    </MudPaper>
                </MudExpansionPanel>
            </MudExpansionPanels>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Outlined" Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.Block">Reject application</MudButton>
        <MudButton OnClick="Confirm" Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.LocalOffer">Offer credential</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance? MudDialog { get; set; }

    [Parameter, EditorRequired]
    public required ExchangeView ApplyExchange { get; init; }

    string? IssuerPrefix => ApplyExchange.Rp;
    string? HolderPrefix => ApplyExchange.I;

    string? EcrRole => ApplyExchange.A?.GetValueByPath("a.engagementContextRole")?.Value?.ToString();

    string? ApplyJson => JsonSerializer.Serialize(
        ApplyExchange.RawExn.ToObjectDictionary(), Helper.JsonOptions.Display);

    private void Cancel() => MudDialog?.Cancel();
    private void Confirm() => MudDialog?.Close(DialogResult.Ok(true));
}
