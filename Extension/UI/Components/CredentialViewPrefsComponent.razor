@using Extension.Models
@using Extension.Services
@using Extension.Services.Storage

@inject AppCache appCache
@inject IStorageGateway storageGateway

@*
    Credential view preferences — Card/Tree toggle and detail-level select — with a built-in
    gear icon that shows / hides the controls. Collapsed by default. Callers simply render
    <CredentialViewPrefsComponent /> above or next to their CredentialComponent — no need
    to manage an external gear or show/hide state.
*@

@code {
    bool expanded;

    CredentialDetailLevel DetailLevel => (CredentialDetailLevel)appCache.MyPreferences.CredentialsDetailLevel;
    CredentialDisplayType DisplayType => appCache.MyPreferences.CredentialsDisplayType;
    static readonly (CredentialDetailLevel Value, string Label)[] DetailLevelOptions = {
        (CredentialDetailLevel.Basic, "basic"),
        (CredentialDetailLevel.WithOptionalSections, "w/ optional sections"),
        (CredentialDetailLevel.Detailed, "w/ detail"),
        (CredentialDetailLevel.WithTechnicalDetails, "w/ technical details"),
    };

    void ToggleExpanded() => expanded = !expanded;

    async Task OnDetailLevelChanged(CredentialDetailLevel value)
    {
        var intValue = (int)value;
        await storageGateway.SetItem(appCache.MyPreferences with { CredentialsDetailLevel = intValue });
        await appCache.WaitForAppCache([() => appCache.MyPreferences.CredentialsDetailLevel == intValue]);
    }

    async Task OnDisplayTypeChanged(CredentialDisplayType value)
    {
        await storageGateway.SetItem(appCache.MyPreferences with { CredentialsDisplayType = value });
        // await appCache.WaitForAppCache([() => appCache.MyPreferences.CredentialsDisplayType == value]);
        // Note display will be updated reactively via AppCache, no need to wait here. This is just a preference update, not critical to await before UI updates.
    }

}

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Spacing="0">
    <MudIconButton Icon="@Icons.Material.Filled.Settings"
                Color="Color.Primary" 
                Size="Size.Small"
                OnClick="ToggleExpanded"
                aria-label="Toggle credential view settings" />
</MudStack>
@if (expanded)
{
    <MudPaper Class="pa-3 mb-2" Outlined="true">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
            <MudToggleGroup T="CredentialDisplayType" Value="@DisplayType" ValueChanged="@(async value => await OnDisplayTypeChanged(value))">
                <MudToggleItem Value="CredentialDisplayType.Card" Text="Card" />
                <MudToggleItem Value="CredentialDisplayType.Tree" Text="Tree" />
            </MudToggleGroup>
            <MudSelect T="CredentialDetailLevel" Value="@DetailLevel" ValueChanged="@OnDetailLevelChanged"
                       Label="Detail level" Dense="true" Margin="Margin.Dense"
                       Variant="Variant.Outlined" Style="min-width: 180px; flex-grow: 0;">
                @foreach (var (value, label) in DetailLevelOptions)
                {
                    <MudSelectItem T="CredentialDetailLevel" Value="@value">@label</MudSelectItem>
                }
            </MudSelect>
        </MudStack>
    </MudPaper>
}
