@using Extension.Models
@using Extension.Services
@using Extension.Services.SignifyService.Models
@using Extension.Services.Storage
@inject AppCache appCache
@inject IStorageGateway storageGateway

@code {
    [Parameter, EditorRequired]
    public required ExchangeView Exchange { get; init; }

    [Parameter]
    public string? Route { get; set; }

    [Parameter]
    public EventCallback OnAdmit { get; set; }

    [Parameter]
    public bool IsAdmitting { get; set; }

    [Parameter]
    public bool IsAlreadyAdmitted { get; set; }

    [Parameter]
    public EventCallback OnAgree { get; set; }

    [Parameter]
    public bool IsAgreeing { get; set; }

    [Parameter]
    public bool IsAlreadyAgreed { get; set; }

    [Parameter]
    public bool IsLoadingPrior { get; set; }

    [Parameter]
    public EventCallback OnOfferIssuance { get; set; }

    [Parameter]
    public bool IsOffering { get; set; }

    [Parameter]
    public bool IsAlreadyOffered { get; set; }

    [Parameter]
    public EventCallback OnGrant { get; set; }

    [Parameter]
    public bool IsGranting { get; set; }

    [Parameter]
    public bool IsAlreadyGranted { get; set; }

    [Parameter]
    public EventCallback OnGrantPresentation { get; set; }

    [Parameter]
    public bool IsGrantingPresentation { get; set; }

    [Parameter]
    public EventCallback OnOfferPresentation { get; set; }

    [Parameter]
    public bool IsOfferingPresentation { get; set; }

    [Parameter]
    public bool ShowActions { get; set; } = true;

    [Parameter]
    public bool CredentialExpandable { get; set; } = true;

    string? SenderAid => Exchange.I;
    string? RecipientAid => Exchange.Rp;
    string? ExchangeSaid => Exchange.D;

    string ExchangeTypeLabel => Route switch {
        "/exn/ipex/apply" => "Credential Request \u2013 Apply",
        "/exn/ipex/offer" => "Credential \u2013 Offer",
        "/exn/ipex/agree" => "Credential \u2013 Agree",
        "/exn/ipex/grant" => "Credential \u2013 Grant",
        "/exn/ipex/admit" => "Credential \u2013 Admit",
        _ => Route ?? "Exchange"
    };


    // Stub handlers for unimplemented IPEX actions
    Task HandleSpurn() => Task.CompletedTask;

    // ACDC credential extracted from exchange embedded data, wrapped for CredentialComponent
    RecursiveDictionary? AcdcCredential {
        get {
            var acdc = Exchange.E?.GetByPath("acdc")?.Dictionary;
            if (acdc is null) return null;
            return new RecursiveDictionary { ["sad"] = acdc };
        }
    }

    CredentialViewOptions CredentialViewOpts => new(
        DisplayType: appCache.MyPreferences.CredentialsDisplayType,
        DetailLevel: (CredentialDetailLevel)appCache.MyPreferences.CredentialsDetailLevel,
        IsJsonShown: appCache.MyPreferences.CredentialsDetailLevel >= (int)CredentialDetailLevel.WithTechnicalDetails
    );
}

<MudStack Spacing="1">
    @if (ExchangeSaid is not null)
    {
        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.caption" Style="min-width: 70px;">Exchange</MudText>
            <SaidDisplay Said="@ExchangeSaid" />
        </MudStack>
    }
    @* // TODO P2 should have unique class *@
    <MudText Class="bt-page-title">@ExchangeTypeLabel</MudText>

    @* Status chips — always visible *@
    @switch (Route)
    {
        case "/exn/ipex/apply" when IsAlreadyOffered:
            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text"
                     Icon="@Icons.Material.Filled.LocalOffer">Credential offered</MudChip>
            break;
        case "/exn/ipex/apply" when IsAlreadyGranted:
            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text"
                     Icon="@Icons.Material.Filled.CardGiftcard">Credential granted</MudChip>
            break;
        case "/exn/ipex/offer" when IsAlreadyAgreed:
            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text"
                     Icon="@Icons.Material.Filled.Handshake">Agreed — awaiting grant</MudChip>
            break;
        case "/exn/ipex/agree" when IsAlreadyGranted:
            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text"
                     Icon="@Icons.Material.Filled.CardGiftcard">Credential granted</MudChip>
            break;
        case "/exn/ipex/grant" when IsAlreadyAdmitted:
            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text"
                     Icon="@Icons.Material.Filled.CheckCircle">Already Admitted</MudChip>
            break;
        case "/exn/ipex/admit":
            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Text"
                     Icon="@Icons.Material.Filled.Done">Final state</MudChip>
            break;
    }

    @* Route-aware IPEX action buttons — suppressed when ShowActions=false (page renders them in button tray) *@
    @if (ShowActions)
    {
    <MudStack Row="true" Class="mt-2 flex-wrap" Spacing="1" Justify="Justify.FlexEnd">
        @switch (Route)
        {
            case "/exn/ipex/apply" when !IsAlreadyOffered && !IsAlreadyGranted:
                @if (OnOfferIssuance.HasDelegate)
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Small"
                               OnClick="OnOfferIssuance"
                               Disabled="@(IsOffering || IsGranting)">
                        @if (IsOffering) { <MudProgressCircular Color="Color.Default" Size="Size.Small" Indeterminate="true" Class="mr-2" /> <text>Offering…</text> }
                        else { <text>Offer credential...</text> }
                    </MudButton>
                }
                @if (OnOfferPresentation.HasDelegate)
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Small"
                               OnClick="OnOfferPresentation"
                               Disabled="@(IsOfferingPresentation || IsGrantingPresentation || IsGranting || IsOffering)">
                        @if (IsOfferingPresentation) { <MudProgressCircular Color="Color.Default" Size="Size.Small" Indeterminate="true" Class="mr-2" /> <text>Offering…</text> }
                        else { <text>Offer presentation</text> }
                    </MudButton>
                }
                @if (OnGrant.HasDelegate)
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Small"
                               OnClick="OnGrant"
                               Disabled="@(IsGranting || IsOffering)">
                        @if (IsGranting) { <MudProgressCircular Color="Color.Default" Size="Size.Small" Indeterminate="true" Class="mr-2" /> <text>Granting…</text> }
                        else { <text>Grant credential...</text> }
                    </MudButton>
                }
                @if (OnGrantPresentation.HasDelegate)
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Small"
                               OnClick="OnGrantPresentation"
                               Disabled="@(IsGrantingPresentation || IsGranting || IsOffering)">
                        @if (IsGrantingPresentation) { <MudProgressCircular Color="Color.Default" Size="Size.Small" Indeterminate="true" Class="mr-2" /> <text>Granting…</text> }
                        else { <text>Grant presentation</text> }
                    </MudButton>
                }
                <MudTooltip Text="Not yet implemented">
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                               Disabled="true" OnClick="HandleSpurn">Reject</MudButton>
                </MudTooltip>
                break;

            case "/exn/ipex/offer" when !IsAlreadyAgreed && OnAgree.HasDelegate:
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Small"
                           OnClick="OnAgree"
                           Disabled="@IsAgreeing">
                    @if (IsAgreeing) { <MudProgressCircular Color="Color.Default" Size="Size.Small" Indeterminate="true" Class="mr-2" /> <text>Agreeing…</text> }
                    else { <text>Agree</text> }
                </MudButton>
                <MudTooltip Text="Not yet implemented">
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                               Disabled="true" OnClick="HandleSpurn">Reject</MudButton>
                </MudTooltip>
                break;

            case "/exn/ipex/agree" when !IsAlreadyGranted && OnGrant.HasDelegate:
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Small"
                           OnClick="OnGrant"
                           Disabled="@IsGranting">
                    @if (IsGranting) { <MudProgressCircular Color="Color.Default" Size="Size.Small" Indeterminate="true" Class="mr-2" /> <text>Granting…</text> }
                    else { <text>Grant...</text> }
                </MudButton>
                <MudTooltip Text="Not yet implemented">
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                               Disabled="true" OnClick="HandleSpurn">Reject</MudButton>
                </MudTooltip>
                break;

            case "/exn/ipex/grant" when !IsAlreadyAdmitted && OnAdmit.HasDelegate:
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Small"
                           OnClick="OnAdmit"
                           Disabled="@IsAdmitting">
                    @if (IsAdmitting) { <MudProgressCircular Color="Color.Default" Size="Size.Small" Indeterminate="true" Class="mr-2" /> <text>Admitting…</text> }
                    else { <text>Admit</text> }
                </MudButton>
                <MudTooltip Text="Not yet implemented">
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                               Disabled="true" OnClick="HandleSpurn">Reject</MudButton>
                </MudTooltip>
                break;
        }
    </MudStack>
    }

    @if (AcdcCredential is not null)
    {
        <CredentialViewPrefsComponent />

        <CredentialComponent Credential="@AcdcCredential"
                             ViewOptions="@CredentialViewOpts"
                             IsExpandable="@CredentialExpandable"
                             Expanded="true" />
    }

</MudStack>
