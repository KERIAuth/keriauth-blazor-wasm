@using System.Text.Json
@using Extension.Services.SignifyService.Models
@inject IJSRuntime js
@inject ISnackbar snackbar

@code {
    [Parameter, EditorRequired]
    public required ExchangeView Exchange { get; init; }

    [Parameter]
    public string? Route { get; set; }

    [Parameter]
    public EventCallback OnAdmit { get; set; }

    [Parameter]
    public bool IsAdmitting { get; set; }

    [Parameter]
    public bool IsAlreadyAdmitted { get; set; }

    [Parameter]
    public EventCallback OnAgree { get; set; }

    [Parameter]
    public bool IsAgreeing { get; set; }

    [Parameter]
    public bool IsAlreadyAgreed { get; set; }

    [Parameter]
    public bool IsLoadingPrior { get; set; }

    [Parameter]
    public EventCallback OnOfferIssuance { get; set; }

    [Parameter]
    public bool IsOffering { get; set; }

    [Parameter]
    public bool IsAlreadyOffered { get; set; }

    [Parameter]
    public EventCallback OnGrant { get; set; }

    [Parameter]
    public bool IsGranting { get; set; }

    [Parameter]
    public bool IsAlreadyGranted { get; set; }

    [Parameter]
    public EventCallback OnGrantPresentation { get; set; }

    [Parameter]
    public bool IsGrantingPresentation { get; set; }

    [Parameter]
    public EventCallback OnOfferPresentation { get; set; }

    [Parameter]
    public bool IsOfferingPresentation { get; set; }

    string? SenderAid => Exchange.I;
    string? RecipientAid => Exchange.Rp;
    string? ExchangeSaid => Exchange.D;

    string? ExchangeJson => JsonSerializer.Serialize(Exchange.RawExn.ToObjectDictionary(), Helper.JsonOptions.Display);



    async Task CopyJsonToClipboard()
    {
        if (ExchangeJson is not null)
        {
            await js.InvokeVoidAsync("navigator.clipboard.writeText", ExchangeJson);
            snackbar.Add("Exchange JSON copied to clipboard.", Severity.Success);
        }
    }

    // Stub handlers for unimplemented IPEX actions
    Task HandleSpurn() => Task.CompletedTask;
}

<MudStack Spacing="1">
    @if (ExchangeSaid is not null)
    {
        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="min-width: 70px;">Exchange</MudText>
            <MudTooltip Text="@ExchangeSaid" Delay="300">
                <MudText Typo="Typo.caption">@Elide(ExchangeSaid, 6, 4)</MudText>
            </MudTooltip>
        </MudStack>
    }

    @* Route-aware IPEX action buttons *@
    <MudStack Row="true" Class="mt-2 flex-wrap" Spacing="1" Justify="Justify.FlexEnd">
        @switch (Route)
        {
            case "/exn/ipex/apply":
                @if (IsAlreadyOffered)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text"
                             Icon="@Icons.Material.Filled.LocalOffer">Credential Offered</MudChip>
                }
                else if (IsAlreadyGranted)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text"
                             Icon="@Icons.Material.Filled.CardGiftcard">Credential Granted</MudChip>
                }
                else
                {
                    @if (OnOfferIssuance.HasDelegate)
                    {
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.LocalOffer"
                                   OnClick="OnOfferIssuance"
                                   Disabled="@(IsOffering || IsGranting)">
                            @if (IsOffering)
                            {
                                <MudProgressCircular Color="Color.Default" Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <text>Offering...</text>
                            }
                            else
                            {
                                <text>Offer Credential</text>
                            }
                        </MudButton>
                    }
                    @if (OnOfferPresentation.HasDelegate)
                    {
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.LocalOffer"
                                   OnClick="OnOfferPresentation"
                                   Disabled="@(IsOfferingPresentation || IsGrantingPresentation || IsGranting || IsOffering)">
                            @if (IsOfferingPresentation)
                            {
                                <MudProgressCircular Color="Color.Default" Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <text>Offering...</text>
                            }
                            else
                            {
                                <text>Offer Presentation</text>
                            }
                        </MudButton>
                    }
                    @if (OnGrant.HasDelegate)
                    {
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.CardGiftcard"
                                   OnClick="OnGrant"
                                   Disabled="@(IsGranting || IsOffering)">
                            @if (IsGranting)
                            {
                                <MudProgressCircular Color="Color.Default" Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <text>Granting...</text>
                            }
                            else
                            {
                                <text>Grant Credential</text>
                            }
                        </MudButton>
                    }
                    @if (OnGrantPresentation.HasDelegate)
                    {
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Visibility"
                                   OnClick="OnGrantPresentation"
                                   Disabled="@(IsGrantingPresentation || IsGranting || IsOffering)">
                            @if (IsGrantingPresentation)
                            {
                                <MudProgressCircular Color="Color.Default" Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <text>Granting...</text>
                            }
                            else
                            {
                                <text>Grant Presentation</text>
                            }
                        </MudButton>
                    }
                    <MudTooltip Text="Not yet implemented">
                        <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Block" Disabled="true"
                                   OnClick="HandleSpurn">Reject</MudButton>
                    </MudTooltip>
                }
                break;

            case "/exn/ipex/offer":
                @if (IsAlreadyAgreed)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text"
                             Icon="@Icons.Material.Filled.Handshake">Agreed — awaiting grant</MudChip>
                }
                else if (OnAgree.HasDelegate)
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Handshake"
                               OnClick="OnAgree"
                               Disabled="@IsAgreeing">
                        @if (IsAgreeing)
                        {
                            <MudProgressCircular Color="Color.Default" Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <text>Agreeing...</text>
                        }
                        else
                        {
                            <text>Agree</text>
                        }
                    </MudButton>
                    <MudTooltip Text="Not yet implemented">
                        <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Block" Disabled="true"
                                   OnClick="HandleSpurn">Reject</MudButton>
                    </MudTooltip>
                }
                break;

            case "/exn/ipex/agree":
                @if (IsAlreadyGranted)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text"
                             Icon="@Icons.Material.Filled.CardGiftcard">Credential Granted</MudChip>
                }
                else if (OnGrant.HasDelegate)
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.CardGiftcard"
                               OnClick="OnGrant"
                               Disabled="@IsGranting">
                        @if (IsGranting)
                        {
                            <MudProgressCircular Color="Color.Default" Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <text>Granting...</text>
                        }
                        else
                        {
                            <text>Grant</text>
                        }
                    </MudButton>
                    <MudTooltip Text="Not yet implemented">
                        <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Block" Disabled="true"
                                   OnClick="HandleSpurn">Reject</MudButton>
                    </MudTooltip>
                }
                break;

            case "/exn/ipex/grant":
                @if (IsAlreadyAdmitted)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text"
                             Icon="@Icons.Material.Filled.CheckCircle">Already Admitted</MudChip>
                }
                else if (OnAdmit.HasDelegate)
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.CheckCircle"
                               OnClick="OnAdmit"
                               Disabled="@IsAdmitting">
                        @if (IsAdmitting)
                        {
                            <MudProgressCircular Color="Color.Default" Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <text>Admitting...</text>
                        }
                        else
                        {
                            <text>Admit</text>
                        }
                    </MudButton>
                }
                @if (!IsAlreadyAdmitted)
                {
                    <MudTooltip Text="Not yet implemented">
                        <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Block" Disabled="true"
                                   OnClick="HandleSpurn">Reject</MudButton>
                    </MudTooltip>
                }
                break;

            case "/exn/ipex/admit":
                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Text"
                         Icon="@Icons.Material.Filled.Done">Final state</MudChip>
                break;
        }
    </MudStack>

    <MudExpansionPanels Dense="true">
        <MudExpansionPanel Text="Raw JSON" Dense="true">
            <MudPaper Elevation="1" Class="pa-3" Style="overflow-x: auto;">
                <MudText Style="white-space: pre; font-family: monospace; font-size: 0.75rem;">
                    @ExchangeJson
                </MudText>
                <MudButton Variant="Variant.Text"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.ContentCopy"
                           OnClick="CopyJsonToClipboard">
                    Copy JSON
                </MudButton>
            </MudPaper>
        </MudExpansionPanel>
    </MudExpansionPanels>
</MudStack>
