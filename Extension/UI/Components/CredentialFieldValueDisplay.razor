@using System.Globalization
@using Extension.Models

@*
    Single render switch for credential field values. Format may come from
    credentialViewSpecs.json (camelCase customs) or the credential's own JSON
    Schema (kebab-case standards). Both flow through the same enum here.
*@

@switch (Format)
{
    case CredentialFieldFormat.Identicon when !string.IsNullOrEmpty(Value):
        <AidPrefixDisplay Prefix="@Value" DisplayNameInParentheses="true" />
        break;

    case CredentialFieldFormat.Lei when !string.IsNullOrEmpty(Value):
        <MudLink Href="@LeiSearchUrl(Value)" Target="_blank">@Value</MudLink>
        break;

    case CredentialFieldFormat.DateAsLocal:
    case CredentialFieldFormat.Date:
        @FormatDate(Value, asUtc: false)
        break;

    case CredentialFieldFormat.DateTimeAsLocal:
    case CredentialFieldFormat.DateTime:
        @FormatDateTime(Value, asUtc: false)
        break;

    case CredentialFieldFormat.DateAsUtc:
        @FormatDate(Value, asUtc: true)
        break;

    case CredentialFieldFormat.DateTimeAsUtc:
        @FormatDateTime(Value, asUtc: true)
        break;

    default:
        @Value
        break;
}

@code {
    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public CredentialFieldFormat? Format { get; set; }

    static string LeiSearchUrl(string lei) =>
        $"https://search.gleif.org/#/search/criteria%5B0%5D%5BrelId%5D=FILTER_LEIREC&criteria%5B0%5D%5BfieldId%5D=LEIREC_LEI&criteria%5B0%5D%5Bvalue%5D={lei}&criteria%5B0%5D%5Boperator%5D=MATCH&criteria%5B0%5D%5BdataType%5D=STRING&currentPage=1&perPage=15&expertMode=true#search-form";

    static string FormatDate(string? raw, bool asUtc) {
        if (raw is null) return "";
        if (!DateTimeOffset.TryParse(raw, CultureInfo.InvariantCulture, DateTimeStyles.AssumeUniversal, out var dto)) {
            return raw;
        }
        var dt = asUtc ? dto.UtcDateTime : dto.LocalDateTime;
        var formatted = dt.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
        return asUtc ? formatted + " UTC" : formatted;
    }

    static string FormatDateTime(string? raw, bool asUtc) {
        if (raw is null) return "";
        if (!DateTimeOffset.TryParse(raw, CultureInfo.InvariantCulture, DateTimeStyles.AssumeUniversal, out var dto)) {
            return raw;
        }
        if (asUtc) {
            return dto.UtcDateTime.ToString("yyyy-MM-dd HH:mm", CultureInfo.InvariantCulture) + " UTC";
        }
        return dto.LocalDateTime.ToString("g", CultureInfo.CurrentCulture);
    }
}
