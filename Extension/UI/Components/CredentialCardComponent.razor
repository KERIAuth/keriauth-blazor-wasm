@using System.Text.Json
@using Extension.Helper
@using Extension.Models
@using Extension.Services

@inject IJSRuntime js
@inject ISnackbar snackbar

@code {
    [Parameter]
    public RecursiveDictionary? Credential { get; init; }

    [Parameter]
    public CredentialViewTree? Tree { get; set; }

    [Parameter]
    public CredentialViewOptions ViewOptions { get; set; } = new();

    [Parameter]
    public string? IssuerProfileName { get; set; }

    [Parameter]
    public string? IssuerConnectionName { get; set; }

    [Parameter]
    public string? IssueeProfileName { get; set; }

    [Parameter]
    public string? IssueeConnectionName { get; set; }

    // Presentation mode: elision map
    [Parameter]
    public Dictionary<string, bool> ElisionMap { get; set; } = new();

    [Parameter]
    public EventCallback<Dictionary<string, bool>> ElisionMapChanged { get; set; }

    bool IsPresentation => ViewOptions.IsPresentation;

    // Elision-capable sections from the pipeline tree (only populated in presentation mode)
    List<CredentialViewNode> ElisionTreeSections =>
        Tree?.Children.Where(n => n.IsElisionToggleable).ToList() ?? [];

    bool IsSectionDisclosed(string sectionKey) =>
        ElisionMap.TryGetValue(sectionKey, out var disclosed) && disclosed;

    bool IsSectionUndisclosed(string sectionKey) =>
        IsPresentation && ElisionTreeSections.Any(s => s.Key == sectionKey) && !IsSectionDisclosed(sectionKey);

    async Task OnDisclosureChanged(string sectionKey, bool disclosed) {
        var newMap = new Dictionary<string, bool>(ElisionMap) { [sectionKey] = disclosed };
        ElisionMap = newMap;
        await ElisionMapChanged.InvokeAsync(newMap);
    }

    CredentialViewNode? FindNode(string path) {
        if (Tree is null) return null;
        var parts = path.Split('.');
        var current = Tree.Children;
        CredentialViewNode? found = null;
        foreach (var part in parts) {
            found = current.FirstOrDefault(n => n.Key == part);
            if (found is null) return null;
            current = found.Children;
        }
        return found;
    }

    CredentialViewNode? IssuerNode => FindNode("i");
    CredentialViewNode? IssueeNode => FindNode("a.i");

    // Paths rendered by dedicated card sections (Issuer, Issuee) — excluded from the flat Details list.
    static readonly HashSet<string> ExcludedDetailPaths = new() { "i", "a.i" };

    IEnumerable<CredentialViewNode> DetailFields {
        get {
            if (Tree is null) return [];
            var fields = FlattenValues(Tree.Children).Where(n => !ExcludedDetailPaths.Contains(n.Path));
            if (!IsPresentation) return fields;
            var undisclosed = ElisionTreeSections
                .Where(s => !IsSectionDisclosed(s.Key))
                .Select(s => s.Key)
                .ToHashSet();
            return fields.Where(f => !undisclosed.Contains(f.Path.Split('.')[0]));
        }
    }

    static IEnumerable<CredentialViewNode> FlattenValues(List<CredentialViewNode> nodes) {
        foreach (var node in nodes) {
            if (node.Kind == CredentialViewNodeKind.Value)
                yield return node;
            foreach (var child in FlattenValues(node.Children))
                yield return child;
        }
    }

    // Raw JSON
    string? CredentialJson => Credential is not null
        ? JsonSerializer.Serialize(Credential.ToObjectDictionary(), JsonOptions.Display)
        : null;

    async Task CopyJsonToClipboard() {
        if (CredentialJson is not null) {
            await js.InvokeVoidAsync("navigator.clipboard.writeText", CredentialJson);
            snackbar.Add("Credential JSON copied to clipboard.", Severity.Success);
        }
        else {
            snackbar.Add("No Credential JSON to copy.", Severity.Warning);
        }
    }
}

<MudStack Spacing="3">
    @* Disclosure controls (presentation mode only) — derived from tree's IsElisionToggleable nodes *@
    @if (IsPresentation && ElisionTreeSections.Count > 0)
    {
        <MudPaper Class="pa-3" Outlined="true">
            <MudText Typo="Typo.subtitle2" Class="mb-2"><b>Disclosure</b></MudText>
            <MudStack Spacing="1">
                @foreach (var sectionNode in ElisionTreeSections)
                {
                    var key = sectionNode.Key;
                    var saidDigest = sectionNode.SaidDigest;
                    var disclosed = IsSectionDisclosed(key);
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudCheckBox T="bool" Value="@disclosed"
                                     ValueChanged="@(val => OnDisclosureChanged(key, val))"
                                     Label="@($"Disclose {sectionNode.Label}")"
                                     Dense="true" />
                        @if (!disclosed && !string.IsNullOrEmpty(saidDigest))
                        {
                            <SaidDisplay Said="@saidDigest" />
                        }
                    </MudStack>
                }
            </MudStack>
        </MudPaper>
    }

    @* Pipeline-driven detail fields — per-section disclosure in presentation mode *@
    @if (DetailFields.Any())
    {
        <MudStack Spacing="1">
            <MudText Typo="Typo.subtitle2" Class="bt-credview-text-schema">Details</MudText>
            <MudStack Class="ml-2" Spacing="1">
                @foreach (var field in DetailFields)
                {
                    if (!string.IsNullOrEmpty(field.RawValue))
                    {
                        <MudText Typo="Typo.body2">
                            <span class="bt-credview-text-schema">@field.Label:</span>
                            <span class="bt-credview-text-acdc"><CredentialFieldValueDisplay Value="@field.RawValue" Format="@field.Format" /></span>
                        </MudText>
                    }
                }
            </MudStack>
        </MudStack>
    }

    @* Issuer section — top-level "i", always shown (not in any elision section) *@
    @if (IssuerNode is not null && !string.IsNullOrEmpty(IssuerNode.RawValue))
    {
        <MudStack Spacing="1">
            <MudText Typo="Typo.subtitle2" Class="bt-credview-text-schema">@IssuerNode.Label</MudText>
            <MudStack Class="ml-2" Spacing="2">
                <AidPrefixDisplay Prefix="@IssuerNode.RawValue" />
                @if (!string.IsNullOrEmpty(IssuerProfileName))
                {
                    <MudText Typo="Typo.body2">
                        <span class="bt-credview-text-schema">Profile:</span>
                        <span class="bt-credview-text-acdc">@IssuerProfileName</span>
                    </MudText>
                }
                @if (!string.IsNullOrEmpty(IssuerConnectionName))
                {
                    <MudText Typo="Typo.body2">
                        <span class="bt-credview-text-schema">Connected as:</span>
                        <span class="bt-credview-text-acdc">@IssuerConnectionName</span>
                    </MudText>
                }
            </MudStack>
        </MudStack>
    }

    @* Issuee section — "a.i", gated on "a" disclosure in presentation mode *@
    @if (!IsSectionUndisclosed("a") && IssueeNode is not null && !string.IsNullOrEmpty(IssueeNode.RawValue))
    {
        <MudStack Spacing="1">
            <MudText Typo="Typo.subtitle2" Class="bt-credview-text-schema">@IssueeNode.Label</MudText>
            <MudStack Class="ml-2" Spacing="2">
                <AidPrefixDisplay Prefix="@IssueeNode.RawValue" />
                @if (!string.IsNullOrEmpty(IssueeProfileName))
                {
                    <MudText Typo="Typo.body2">
                        <span class="bt-credview-text-schema">Profile:</span>
                        <span class="bt-credview-text-acdc">@IssueeProfileName</span>
                    </MudText>
                }
                @if (!string.IsNullOrEmpty(IssueeConnectionName))
                {
                    <MudText Typo="Typo.body2">
                        <span class="bt-credview-text-schema">Connected as:</span>
                        <span class="bt-credview-text-acdc">@IssueeConnectionName</span>
                    </MudText>
                }
            </MudStack>
        </MudStack>
    }

    @* Chained credentials — gated on "e" disclosure in presentation mode *@
    @if (Tree is not null && !IsSectionUndisclosed("e"))
    {
        @foreach (var chain in Tree.ChainedCredentials)
        {
            <div class="bt-chain-separator">
                <MudTooltip Text="@chain.SchemaTitle" Delay="300">
                    <MudText Class="bt-card-title">@(chain.ShortName ?? chain.SchemaTitle)</MudText>
                </MudTooltip>
            </div>
            @if (ViewOptions.DetailLevel >= CredentialDetailLevel.Detailed
                 && !string.IsNullOrEmpty(chain.SchemaDescription))
            {
                <MudText Typo="Typo.body2"><em>@chain.SchemaDescription</em></MudText>
            }
            <div class="bt-card-content">
                <CredentialCardComponent Tree="@chain"
                                          ViewOptions="@ViewOptions" />
            </div>
        }
    }

    @* Raw JSON — shown at WithTechnicalDetails *@
    @if (Credential is not null && ViewOptions.DetailLevel >= CredentialDetailLevel.WithTechnicalDetails)
    {
        <MudExpansionPanels Dense="true">
            <MudExpansionPanel Text="Raw JSON" Dense="true">
                <MudPaper Elevation="1" Class="pa-3" Style="overflow-x: auto;">
                    <MudText Style="white-space: pre; font-family: monospace; font-size: 0.75rem;">
                        @CredentialJson
                    </MudText>
                    <MudButton Variant="Variant.Text"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.ContentCopy"
                               OnClick="CopyJsonToClipboard">
                        Copy JSON
                    </MudButton>
                </MudPaper>
            </MudExpansionPanel>
        </MudExpansionPanels>
    }
</MudStack>
