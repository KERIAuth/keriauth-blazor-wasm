@using static Extension.Helper.Identicon
@using static Extension.Helper.CredentialHelper
@using System.Text.Json
@using Extension.Helper
@using Extension.Models
@using Extension.Services

@inject IJSRuntime js
@inject ISnackbar snackbar
@inject AppCache appCache

@code {
    [Parameter, EditorRequired]
    public required RecursiveDictionary Credential { get; init; }

    [Parameter, EditorRequired]
    public required CredentialViewSpec ViewSpec { get; init; }

    [Parameter]
    public CredentialViewOptions ViewOptions { get; set; } = new();

    [Parameter]
    public string? IssuerProfileName { get; set; }

    [Parameter]
    public string? IssuerConnectionName { get; set; }

    [Parameter]
    public string? IssueeProfileName { get; set; }

    [Parameter]
    public string? IssueeConnectionName { get; set; }

    // Schema properties for label/format resolution
    TypedValue? SchemaPropertiesTypeValue => Credential.GetValueByPath("schema.properties.a.oneOf");
    List<object>? SchemaProperties => SchemaPropertiesTypeValue?.Value as List<object>;
    RecursiveDictionary? SchemaProperties1 => (SchemaProperties is null || SchemaProperties.Count < 2 || SchemaProperties[1] is null)
        ? null
        : SchemaProperties[1] as RecursiveDictionary ?? RecursiveDictionary.FromObjectDictionary((Dictionary<string, object>)SchemaProperties[1]);

    // Common fields
    string? SchemaDescr => Credential.GetValueByPath("schema.description")?.Value?.ToString();
    string? IssuerLabel => Credential.GetValueByPath("schema.properties.i.description")?.Value?.ToString() ?? "Issuer";
    string? IssuerValue => Credential.GetValueByPath("sad.i")?.Value?.ToString();
    string? IssuedDate => Credential.GetValueByPath("sad.a.dt")?.Value?.ToString()?.Substring(0, 10);

    // Issuee via schema-driven helper
    SchemaFieldDisplay IssueeField => GetSchemaField(Credential, SchemaProperties1, "i");
    SchemaFieldDisplay UsageDisclaimerField => GetSchemaField(Credential, SchemaProperties1, "usageDisclaimer");
    SchemaFieldDisplay PrivacyDisclaimerField => GetSchemaField(Credential, SchemaProperties1, "privacyDisclaimer");

    // Visible fields filtered by detail level
    IEnumerable<CredentialFieldSpec> VisibleFields =>
        ViewSpec.Fields.Where(f => f.MinDetailLevel <= ViewOptions.DetailLevel);

    string? GetFieldValue(CredentialFieldSpec field) =>
        Credential.GetValueByPath($"sad.{field.Path}")?.Value?.ToString();

    string GetFieldLabel(CredentialFieldSpec field) {
        if (field.Label is not null) return field.Label;
        // Try schema description
        var pathParts = field.Path.Split('.');
        if (pathParts.Length >= 2) {
            var fieldName = pathParts[^1];
            var schemaField = GetSchemaField(Credential, SchemaProperties1, fieldName);
            if (schemaField.Label is not null) return schemaField.Label;
        }
        // Fallback: last segment of path
        return field.Path.Split('.')[^1];
    }

    string FormatField(CredentialFieldSpec field, string value) {
        if (field.Format is not null)
            return FormatFieldValue(value, field.Format);
        // Try schema format
        var pathParts = field.Path.Split('.');
        if (pathParts.Length >= 2) {
            var fieldName = pathParts[^1];
            var schemaField = GetSchemaField(Credential, SchemaProperties1, fieldName);
            if (schemaField.Format is not null)
                return FormatFieldValue(value, schemaField.Format);
        }
        return value;
    }

    bool IsLeiField(CredentialFieldSpec field) =>
        field.Path.EndsWith(".LEI") || field.Path == "a.LEI";

    string GetLeiLink(string lei) =>
        $"https://search.gleif.org/#/search/criteria%5B0%5D%5BrelId%5D=FILTER_LEIREC&criteria%5B0%5D%5BfieldId%5D=LEIREC_LEI&criteria%5B0%5D%5Bvalue%5D={lei}&criteria%5B0%5D%5Boperator%5D=MATCH&criteria%5B0%5D%5BdataType%5D=STRING&currentPage=1&perPage=15&expertMode=true#search-form";

    // Raw JSON
    string? CredentialJson => JsonSerializer.Serialize(Credential.ToObjectDictionary(), JsonOptions.Display);

    async Task CopyJsonToClipboard() {
        if (CredentialJson is not null) {
            await js.InvokeVoidAsync("navigator.clipboard.writeText", CredentialJson);
            snackbar.Add("Credential JSON copied to clipboard.", Severity.Success);
        }
        else {
            snackbar.Add("No Credential JSON to copy.", Severity.Warning);
        }
    }
}

<MudStack Spacing="3">
    @if (!string.IsNullOrEmpty(SchemaDescr))
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary"><em>@SchemaDescr</em></MudText>
    }

    @if (!string.IsNullOrEmpty(IssuedDate))
    {
        <MudText Typo="Typo.body2"><b>Issued:</b> @IssuedDate</MudText>
    }

    @* Spec-driven detail fields *@
    @if (VisibleFields.Any())
    {
        <MudStack Spacing="1">
            <MudText Typo="Typo.subtitle2"><b>Details</b></MudText>
            <MudStack Class="ml-2" Spacing="1">
                @foreach (var field in VisibleFields)
                {
                    var value = GetFieldValue(field);
                    if (!string.IsNullOrEmpty(value))
                    {
                        var label = GetFieldLabel(field);
                        @if (IsLeiField(field))
                        {
                            <MudText Typo="Typo.body2">
                                <b>@label:</b> @value
                                <MudLink Href="@GetLeiLink(value)" Target="_blank">Query LEI Details</MudLink>
                            </MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2"><b>@label:</b> @FormatField(field, value)</MudText>
                        }
                    }
                }
            </MudStack>
        </MudStack>
    }

    @* Issuer section *@
    <MudStack Spacing="1">
        <MudText Typo="Typo.subtitle2"><b>Issuer</b></MudText>
        <MudStack Class="ml-2" Spacing="2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon ViewBox="0 0 100 100" Icon="@MakeIdenticon(IssuerValue)" Class="bt-identicon" />
                <MudText Typo="Typo.body2" Style="overflow-wrap: anywhere;">
                    @IssuerLabel:<br /><b class="bt-prefix">@IssuerValue</b>
                </MudText>
            </MudStack>

            @if (!string.IsNullOrEmpty(IssuerProfileName))
            {
                <MudText Typo="Typo.body2">Profile: <b>@IssuerProfileName</b></MudText>
            }
            @if (!string.IsNullOrEmpty(IssuerConnectionName))
            {
                <MudText Typo="Typo.body2">Connected as: <b>@IssuerConnectionName</b></MudText>
            }
        </MudStack>
    </MudStack>

    @* Issuee section *@
    @if (!string.IsNullOrEmpty(IssueeField.Label) && !string.IsNullOrEmpty(IssueeField.Value))
    {
        <MudStack Spacing="1">
            <MudText Typo="Typo.subtitle2"><b>Issuee</b></MudText>
            <MudStack Class="ml-2" Spacing="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon ViewBox="0 0 100 100" Icon="@MakeIdenticon(IssueeField.Value)" Class="bt-identicon" />
                    <MudText Typo="Typo.body2" Style="overflow-wrap: anywhere;">
                        @IssueeField.Label:<br /><b class="bt-prefix">@IssueeField.Value</b>
                    </MudText>
                </MudStack>

                @if (!string.IsNullOrEmpty(IssueeProfileName))
                {
                    <MudText Typo="Typo.body2">Profile: <b>@IssueeProfileName</b></MudText>
                }
                @if (!string.IsNullOrEmpty(IssueeConnectionName))
                {
                    <MudText Typo="Typo.body2">Connected as: <b>@IssueeConnectionName</b></MudText>
                }
            </MudStack>
        </MudStack>
    }

    @* Disclaimers *@
    @if (!string.IsNullOrWhiteSpace(UsageDisclaimerField.Label))
    {
        <MudText Typo="Typo.body2"><b>@UsageDisclaimerField.Label:</b> @UsageDisclaimerField.Value</MudText>
    }
    @if (!string.IsNullOrWhiteSpace(PrivacyDisclaimerField.Label))
    {
        <MudText Typo="Typo.body2"><b>@PrivacyDisclaimerField.Label:</b> @PrivacyDisclaimerField.Value</MudText>
    }

    @* Raw JSON expansion panel *@
    <MudExpansionPanels Dense="true">
        <MudExpansionPanel Text="Raw JSON" Dense="true">
            <MudPaper Elevation="1" Class="pa-3" Style="overflow-x: auto;">
                <MudText Style="white-space: pre; font-family: monospace; font-size: 0.75rem;">
                    @CredentialJson
                </MudText>
                <MudButton Variant="Variant.Text"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.ContentCopy"
                           OnClick="CopyJsonToClipboard">
                    Copy JSON
                </MudButton>
            </MudPaper>
        </MudExpansionPanel>
    </MudExpansionPanels>
</MudStack>
