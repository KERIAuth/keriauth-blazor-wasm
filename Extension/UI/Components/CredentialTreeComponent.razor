@using static Extension.Helper.CredentialHelper
@using Extension.Helper
@using Extension.Models
@using Extension.Services

@code {
    [Parameter, EditorRequired]
    public required RecursiveDictionary Credential { get; init; }

    [Parameter, EditorRequired]
    public required CredentialViewSpec ViewSpec { get; init; }

    [Parameter]
    public CredentialViewOptions ViewOptions { get; set; } = new();

    [Parameter]
    public Dictionary<string, bool> ElisionMap { get; set; } = new();

    [Parameter]
    public EventCallback<Dictionary<string, bool>> ElisionMapChanged { get; set; }

    bool IsPresentation => ViewOptions.IsPresentation;

    // Section labels
    static readonly Dictionary<string, string> SectionLabels = new() {
        ["v"] = "Version", ["d"] = "Digest (SAID)", ["i"] = "Issuer",
        ["ri"] = "Registry ID", ["s"] = "Schema", ["a"] = "Attributes",
        ["e"] = "Edges", ["r"] = "Rules"
    };

    static readonly HashSet<string> ElisionCapableSections = ["a", "e", "r"];

    // Hidden keys from ViewSpec
    HashSet<string> HiddenKeys {
        get {
            if (ViewSpec.HiddenDetails is null) return [];
            return ViewSpec.HiddenDetails
                .Select(d => d.ToString().TrimStart('_'))
                .ToHashSet();
        }
    }

    // Get the sad section
    RecursiveDictionary? Sad => Credential.GetByPath("sad")?.Dictionary;

    bool IsSectionDisclosed(string key) =>
        ElisionMap.TryGetValue(key, out var disclosed) && disclosed;

    bool IsElisionCapable(string key) {
        if (!ElisionCapableSections.Contains(key)) return false;
        var section = Sad?.GetValueOrDefault(key);
        return section?.Type == RecursiveValueType.Dictionary
            && section.Dictionary is not null
            && section.Dictionary.ContainsKey("d");
    }

    string? GetSectionSaid(string key) {
        var section = Sad?.GetValueOrDefault(key);
        return section?.Dictionary?.GetValueOrDefault("d")?.StringValue;
    }

    async Task OnDisclosureChanged(string key, bool disclosed) {
        var newMap = new Dictionary<string, bool>(ElisionMap) { [key] = disclosed };
        ElisionMap = newMap;
        await ElisionMapChanged.InvokeAsync(newMap);
    }

    // Format a value for display
    string FormatValue(RecursiveValue value) => value.Type switch {
        RecursiveValueType.StringType => value.StringValue ?? "",
        RecursiveValueType.BooleanType => value.BooleanValue?.ToString() ?? "",
        RecursiveValueType.IntegerType => value.IntegerValue?.ToString() ?? "",
        RecursiveValueType.DoubleType => value.DoubleValue?.ToString() ?? "",
        RecursiveValueType.Null => "(null)",
        RecursiveValueType.List => $"[{value.List?.Count ?? 0} items]",
        RecursiveValueType.Dictionary => $"{{{value.Dictionary?.Count ?? 0} fields}}",
        _ => ""
    };

    // Get a field label from ViewSpec or fall back to key name
    string GetLabel(string sectionKey, string fieldKey) {
        var path = $"{sectionKey}.{fieldKey}";
        var spec = ViewSpec.Fields.FirstOrDefault(f => f.Path == path);
        return spec?.Label ?? fieldKey;
    }
}

@if (Sad is not null)
{
    <MudStack Spacing="1">
        @foreach (var kvp in Sad)
        {
            var key = kvp.Key;
            var value = kvp.Value;

            @* Skip hidden keys *@
            if (HiddenKeys.Contains(key)) continue;

            var label = SectionLabels.GetValueOrDefault(key, key);
            var isElisionCapable = IsElisionCapable(key);
            var isDict = value.Type == RecursiveValueType.Dictionary && value.Dictionary is not null;

            @* Elision-capable section with IsPresentation *@
            if (IsPresentation && isElisionCapable)
            {
                var disclosed = IsSectionDisclosed(key);
                var said = GetSectionSaid(key);

                <MudPaper Class="pa-2 mt-1" Outlined="true">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudCheckBox T="bool" Value="@disclosed"
                                     ValueChanged="@(val => OnDisclosureChanged(key, val))"
                                     Label="@($"Disclose {label}")"
                                     Dense="true" />
                        @if (!disclosed && !string.IsNullOrEmpty(said))
                        {
                            <MudText Typo="Typo.caption" Style="font-family: monospace;">
                                @ElideText(said, 12, 0)
                            </MudText>
                        }
                    </MudStack>

                    @if (disclosed && isDict)
                    {
                        <MudStack Class="ml-4 mt-1" Spacing="0">
                            @foreach (var child in value.Dictionary!)
                            {
                                var childLabel = GetLabel(key, child.Key);
                                var childValue = FormatValue(child.Value);
                                <MudStack Row="true" Spacing="2" Class="py-1">
                                    <MudText Typo="Typo.body2" Style="min-width: 120px; color: var(--mud-palette-text-secondary);"><b>@childLabel</b></MudText>
                                    <MudText Typo="Typo.body2" Style="overflow-wrap: anywhere;">@childValue</MudText>
                                </MudStack>
                            }
                        </MudStack>
                    }
                </MudPaper>
            }
            @* Dictionary section (non-presentation or not elision-capable) *@
            else if (isDict)
            {
                <MudPaper Class="pa-2 mt-1" Outlined="true">
                    <MudText Typo="Typo.subtitle2"><b>@label</b></MudText>
                    <MudStack Class="ml-4 mt-1" Spacing="0">
                        @foreach (var child in value.Dictionary!)
                        {
                            var childLabel = GetLabel(key, child.Key);
                            var childValue = FormatValue(child.Value);

                            @if (child.Value.Type == RecursiveValueType.Dictionary && child.Value.Dictionary is not null)
                            {
                                <MudPaper Class="pa-1 mt-1" Outlined="true">
                                    <MudText Typo="Typo.body2"><b>@childLabel</b></MudText>
                                    <MudStack Class="ml-4" Spacing="0">
                                        @foreach (var grandchild in child.Value.Dictionary)
                                        {
                                            <MudStack Row="true" Spacing="2" Class="py-1">
                                                <MudText Typo="Typo.body2" Style="min-width: 120px; color: var(--mud-palette-text-secondary);"><b>@grandchild.Key</b></MudText>
                                                <MudText Typo="Typo.body2" Style="overflow-wrap: anywhere;">@FormatValue(grandchild.Value)</MudText>
                                            </MudStack>
                                        }
                                    </MudStack>
                                </MudPaper>
                            }
                            else
                            {
                                <MudStack Row="true" Spacing="2" Class="py-1">
                                    <MudText Typo="Typo.body2" Style="min-width: 120px; color: var(--mud-palette-text-secondary);"><b>@childLabel</b></MudText>
                                    <MudText Typo="Typo.body2" Style="overflow-wrap: anywhere;">@childValue</MudText>
                                </MudStack>
                            }
                        }
                    </MudStack>
                </MudPaper>
            }
            @* Scalar value *@
            else
            {
                <MudStack Row="true" Spacing="2" Class="py-1">
                    <MudText Typo="Typo.body2" Style="min-width: 120px; color: var(--mud-palette-text-secondary);"><b>@label</b></MudText>
                    <MudText Typo="Typo.body2" Style="overflow-wrap: anywhere;">@FormatValue(value)</MudText>
                </MudStack>
            }
        }
    </MudStack>
}
else
{
    <MudAlert Severity="Severity.Warning">No credential data available.</MudAlert>
}
