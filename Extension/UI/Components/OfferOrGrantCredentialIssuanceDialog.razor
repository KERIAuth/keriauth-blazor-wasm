@using System.Text.Json
@using Extension.Helper
@using Extension.Models
@using Extension.Models.Messages.AppBw
@using Extension.Services
@using Extension.Services.Port
@using Extension.Services.SignifyService.Models
@using Extension.Utilities
@using static Extension.Helper.PrefixDisplay

@implements IDisposable

@inject IAppBwPortService appBwPortService
@inject ISnackbar snackbar
@inject AppCache appCache
@inject ILogger<OfferOrGrantCredentialIssuanceDialog> logger

@*
    Multi-step issue-and-offer/grant dialog. Three input modes:

      - ReviewApply: opened from a received /exn/ipex/apply notification; shows the apply, issues
        a credential, displays it, then submits offer or grant.
      - ReviewAgree: opened from a received /exn/ipex/agree notification; no new issuance,
        displays the already-issued credential from the prior offer, then submits the grant.
      - AdHoc: opened without a prior exchange; user picks issuer/holder/role, then issuance and
        offer-or-grant.

    The four visible steps (issuance step skipped in ReviewAgree mode) are:
      1. Input      — review the apply/agree, or fill in required fields
      2. Issuing    — spinner while calling RequestIssueEcrCredential (review-agree: fetches prior
                      offer to extract embedded ACDC instead)
      3. Review     — CredentialComponent + prefs, user approves/rejects
      4. Submitting — spinner while calling RequestSubmitIpexOffer / RequestSubmitIpexGrant
*@

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@TitleIcon" Color="Color.Primary" Class="mr-2" />
            @TitleLabel
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            @* Progress breadcrumb showing which of the 4 steps we're on *@
            <MudText Typo="Typo.caption" Class="bt-dialog-step">
                @StepLabel
            </MudText>

            @switch (currentStep)
            {
                case DialogStep.Input:
                    @if (Mode == DialogMode.ReviewApply)
                    {
                        @RenderReviewApply
                    }
                    else if (Mode == DialogMode.ReviewAgree)
                    {
                        @RenderReviewAgree
                    }
                    else
                    {
                        @RenderAdHocFields
                    }
                    break;

                case DialogStep.Issuing:
                    <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-4">
                        <MudProgressCircular Indeterminate="true" Size="Size.Medium" />
                        <MudText Typo="Typo.body2">@IssuingText</MudText>
                    </MudStack>
                    @if (errorMessage is not null)
                    {
                        <MudAlert Severity="Severity.Error">@errorMessage</MudAlert>
                    }
                    break;

                case DialogStep.Review:
                    @RenderCredentialReview
                    break;

                case DialogStep.Submitting:
                    <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-4">
                        <MudProgressCircular Indeterminate="true" Size="Size.Medium" />
                        <MudText Typo="Typo.body2">@SubmittingText</MudText>
                    </MudStack>
                    @if (errorMessage is not null)
                    {
                        <MudAlert Severity="Severity.Error">@errorMessage</MudAlert>
                    }
                    break;
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        @RenderActions
    </DialogActions>
</MudDialog>

@code {
    // ================= Public surface =================

    [CascadingParameter]
    private IMudDialogInstance? MudDialog { get; set; }

    [Parameter]
    public ExchangeView? ApplyExchange { get; set; }

    [Parameter]
    public ExchangeView? AgreeExchange { get; set; }

    [Parameter]
    public string? IssuerName { get; set; }

    [Parameter]
    public string? HolderName { get; set; }

    // True = offer flow (apply → offer → agree → grant → admit).
    // False = grant flow (apply → grant → admit, issuer grants a newly-issued credential directly,
    // or agree → grant reusing an existing credential from the prior offer).
    [Parameter]
    public bool IsOffer { get; set; }

    // Ad-hoc mode inputs. All null when invoked from a notification.
    [Parameter]
    public IEnumerable<Aid>? LocalAids { get; set; }

    [Parameter]
    public IEnumerable<Connection>? Connections { get; set; }

    [Parameter]
    public string? InitialIssuerPrefix { get; set; }

    [Parameter]
    public string? InitialHolderPrefix { get; set; }

    /// <summary>
    /// Structured result returned when the dialog closes on a successful submission.
    /// Submitted=true and CredentialSaid populated indicates the full flow (issuance + submission)
    /// completed. A cancel (user rejected, closed, or revoke-stub snackbar fired) returns
    /// DialogResult.Cancel() and the caller sees dialogResult.Canceled = true.
    /// </summary>
    public record IssuanceDialogResult(bool Submitted, string? CredentialSaid, string? IssuerPrefix = null, string? HolderPrefix = null, string? RoleName = null);

    // ================= Internal state =================

    enum DialogStep { Input, Issuing, Review, Submitting }
    enum DialogMode { ReviewApply, ReviewAgree, AdHoc }

    DialogStep currentStep = DialogStep.Input;
    DialogMode Mode =>
        ApplyExchange is not null ? DialogMode.ReviewApply
        : AgreeExchange is not null ? DialogMode.ReviewAgree
        : DialogMode.AdHoc;

    // Ad-hoc form state
    string? selectedIssuerPrefix;
    string? selectedHolderPrefix;
    string adHocEcrRole = "";

    // Post-issue state (also populated via agree-mode credential-fetch)
    string? issuedCredentialSaid;
    RecursiveDictionary? issuedAcdc;
    RecursiveDictionary? issuedAnc;
    RecursiveDictionary? issuedIss;

    // The wrapped credential dict passed to CredentialComponent (shape: { sad: acdc }).
    // Populated after successful issuance or after fetching the prior offer in ReviewAgree mode.
    RecursiveDictionary? credentialForReview;

    // Guards the revoke-on-cancel path: true once a credential has been issued but not yet
    // successfully submitted. Only the post-issue paths flip this; ReviewAgree mode reuses an
    // already-existing credential and leaves this false.
    bool credentialIssuedButNotSubmitted;

    string? errorMessage;

    // ================= Labels =================

    string ActionLabel => IsOffer ? "Offer credential" : "Grant credential";

    string TitleLabel => Mode switch {
        DialogMode.ReviewApply => IsOffer ? "Offer credential (from apply)" : "Grant credential (from apply)",
        DialogMode.ReviewAgree => "Grant credential (from agree)",
        _ => IsOffer ? "Issue & offer credential" : "Issue & grant credential",
    };

    string TitleIcon => IsOffer
        ? Icons.Material.Filled.LocalOffer
        : Icons.Material.Filled.CardGiftcard;

    string StepLabel => currentStep switch {
        DialogStep.Input when Mode == DialogMode.ReviewApply => "Step 1 of 4 · Review apply",
        DialogStep.Input when Mode == DialogMode.ReviewAgree => "Step 1 of 3 · Review agree",
        DialogStep.Input => "Step 1 of 4 · Required fields",
        DialogStep.Issuing when Mode == DialogMode.ReviewAgree => "Step 2 of 3 · Fetching credential",
        DialogStep.Issuing => "Step 2 of 4 · Issuing credential",
        DialogStep.Review when Mode == DialogMode.ReviewAgree => "Step 2 of 3 · Review credential",
        DialogStep.Review => "Step 3 of 4 · Review credential",
        DialogStep.Submitting when Mode == DialogMode.ReviewAgree => "Step 3 of 3 · Submitting grant",
        DialogStep.Submitting => IsOffer ? "Step 4 of 4 · Submitting offer" : "Step 4 of 4 · Submitting grant",
        _ => ""
    };

    string IssuingText => Mode == DialogMode.ReviewAgree
        ? "Fetching credential from prior offer…"
        : "Issuing credential…";

    string SubmittingText => IsOffer ? "Offering credential…" : "Granting credential…";

    // ================= Derived values =================

    string? IssuerPrefix => Mode switch {
        DialogMode.ReviewApply => ApplyExchange?.Rp,
        DialogMode.ReviewAgree => AgreeExchange?.Rp,
        _ => selectedIssuerPrefix,
    };

    string? HolderPrefix => Mode switch {
        DialogMode.ReviewApply => ApplyExchange?.I,
        DialogMode.ReviewAgree => AgreeExchange?.I,
        _ => selectedHolderPrefix,
    };

    string? ApplyRoleFromExchange =>
        ApplyExchange?.A?.GetValueByPath("a.engagementContextRole")?.Value?.ToString();

    string? EffectiveEcrRole => Mode switch {
        DialogMode.ReviewApply => ApplyRoleFromExchange,
        DialogMode.AdHoc => string.IsNullOrWhiteSpace(adHocEcrRole) ? null : adHocEcrRole,
        _ => null, // ReviewAgree: role lives inside the already-issued credential; no entry needed
    };

    string? ApplyJson => ApplyExchange is not null
        ? JsonSerializer.Serialize(ApplyExchange.Value.RawExn.ToObjectDictionary(), Helper.JsonOptions.Display)
        : null;

    string? AgreeJson => AgreeExchange is not null
        ? JsonSerializer.Serialize(AgreeExchange.Value.RawExn.ToObjectDictionary(), Helper.JsonOptions.Display)
        : null;

    string? PriorOfferSaid => AgreeExchange?.P;

    // Credential view prefs — mirrors the CredentialPage pattern.
    CredentialViewOptions PageViewOptions => new(
        DisplayType: appCache.MyPreferences.CredentialsDisplayType,
        DetailLevel: (CredentialDetailLevel)appCache.MyPreferences.CredentialsDetailLevel,
        IsJsonShown: appCache.MyPreferences.CredentialsDetailLevel >= (int)CredentialDetailLevel.WithTechnicalDetails
    );

    // Ad-hoc validation — mirrors CreateTestDataPage's ValidationRules pattern.
    List<(string Text, bool IsValid)> AdHocValidationRules {
        get {
            var rules = new List<(string, bool)>();
            if (Mode != DialogMode.AdHoc) return rules;

            rules.Add(("Issuer AID selected", !string.IsNullOrEmpty(selectedIssuerPrefix)));
            rules.Add(("Holder AID selected", !string.IsNullOrEmpty(selectedHolderPrefix)));
            rules.Add(("Issuer and holder must not be the same",
                !string.IsNullOrEmpty(selectedIssuerPrefix) && selectedIssuerPrefix != selectedHolderPrefix));
            rules.Add((AidNameValidator.Validate(adHocEcrRole) is null
                    ? "Role name valid"
                    : "Role: 32 chars or less, lowercase letters / digits / _ / -",
                AidNameValidator.Validate(adHocEcrRole) is null));
            return rules;
        }
    }

    bool AdHocAllRulesPass => AdHocValidationRules.All(r => r.IsValid);

    bool NextEnabled => Mode switch {
        DialogMode.AdHoc => AdHocAllRulesPass,
        _ => true,
    };

    // Local-or-external AID list for ad-hoc holder picker (local AIDs + connection targets).
    List<(string Prefix, string Name, bool IsLocal)> SelectableHolders {
        get {
            var result = new List<(string, string, bool)>();
            if (LocalAids is not null)
            {
                foreach (var a in LocalAids)
                {
                    result.Add((a.Prefix, a.Name, true));
                }
            }
            if (Connections is not null)
            {
                var localSet = LocalAids?.Select(a => a.Prefix).ToHashSet() ?? new HashSet<string>();
                foreach (var c in Connections)
                {
                    if (localSet.Contains(c.ReceiverPrefix)) continue;
                    result.Add((c.ReceiverPrefix, $"{c.Name} (ext)", false));
                }
            }
            return result;
        }
    }

    // ================= Lifecycle =================

    protected override async Task OnInitializedAsync() {
        // Pre-fill ad-hoc fields if the caller provided initial values.
        if (Mode == DialogMode.AdHoc)
        {
            selectedIssuerPrefix ??= InitialIssuerPrefix;
            selectedHolderPrefix ??= InitialHolderPrefix;
        }

        // Subscribe to AppCache changes so that live updates to
        // MyPreferences.CredentialsDisplayType / CredentialsDetailLevel from
        // CredentialViewPrefsComponent re-render this dialog's CredentialComponent.
        await this.SubscribeToAppCache(appCache);
    }

    public void Dispose() {
        this.UnsubscribeFromAppCache();
    }

    // ================= Step 1 sub-renders =================

    RenderFragment RenderReviewApply => __builder =>
    {
        <MudText Typo="Typo.subtitle2">Credential summary</MudText>
        <MudSimpleTable Dense="true" Elevation="0">
            <tbody>
                <tr>
                    <td><MudText Typo="Typo.caption">Schema</MudText></td>
                    <td><MudText Typo="Typo.body2">ECR (Engagement Context Role)</MudText></td>
                </tr>
                <tr>
                    <td><MudText Typo="Typo.caption">Role</MudText></td>
                    <td><MudText Typo="Typo.body2">@ApplyRoleFromExchange</MudText></td>
                </tr>
                <tr>
                    <td><MudText Typo="Typo.caption">Issuer</MudText></td>
                    <td>
                        <AidPrefixDisplay Prefix="@(IssuerPrefix ?? "")"
                                          Name="@IssuerName"
                                          ShowCopyButton="false" />
                    </td>
                </tr>
                <tr>
                    <td><MudText Typo="Typo.caption">Holder</MudText></td>
                    <td>
                        <AidPrefixDisplay Prefix="@(HolderPrefix ?? "")"
                                          Name="@HolderName"
                                          ShowCopyButton="false" />
                    </td>
                </tr>
            </tbody>
        </MudSimpleTable>
        <MudExpansionPanels Dense="true">
            <MudExpansionPanel Text="Apply request JSON" Dense="true">
                <MudPaper Elevation="1" Class="pa-3" Style="overflow-x: auto;">
                    <MudText Style="white-space: pre; font-family: monospace; font-size: 0.75rem;">
                        @ApplyJson
                    </MudText>
                </MudPaper>
            </MudExpansionPanel>
        </MudExpansionPanels>
    };

    RenderFragment RenderReviewAgree => __builder =>
    {
        <MudText Typo="Typo.subtitle2">Grant from agree</MudText>
        <MudText Typo="Typo.body2">
            The holder has agreed to receive the credential offered previously.
            No new issuance is required — the existing credential from the prior offer
            will be presented in step 2.
        </MudText>
        <MudSimpleTable Dense="true" Elevation="0">
            <tbody>
                <tr>
                    <td><MudText Typo="Typo.caption">Issuer</MudText></td>
                    <td>
                        <AidPrefixDisplay Prefix="@(IssuerPrefix ?? "")"
                                          Name="@IssuerName"
                                          ShowCopyButton="false" />
                    </td>
                </tr>
                <tr>
                    <td><MudText Typo="Typo.caption">Holder</MudText></td>
                    <td>
                        <AidPrefixDisplay Prefix="@(HolderPrefix ?? "")"
                                          Name="@HolderName"
                                          ShowCopyButton="false" />
                    </td>
                </tr>
                @if (!string.IsNullOrEmpty(PriorOfferSaid))
                {
                    <tr>
                        <td><MudText Typo="Typo.caption">Prior offer</MudText></td>
                        <td>
                            <SaidDisplay Said="@PriorOfferSaid" />
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
        <MudExpansionPanels Dense="true">
            <MudExpansionPanel Text="Agree message JSON" Dense="true">
                <MudPaper Elevation="1" Class="pa-3" Style="overflow-x: auto;">
                    <MudText Style="white-space: pre; font-family: monospace; font-size: 0.75rem;">
                        @AgreeJson
                    </MudText>
                </MudPaper>
            </MudExpansionPanel>
        </MudExpansionPanels>
    };

    RenderFragment RenderAdHocFields => __builder =>
    {
        <MudText Typo="Typo.subtitle2">Required fields</MudText>
        <MudSelect T="string" Label="Issuer"
                   Value="@selectedIssuerPrefix"
                   ValueChanged="@((string v) => { selectedIssuerPrefix = v; StateHasChanged(); })"
                   Variant="Variant.Outlined" Dense="true" Modal="true">
            @if (LocalAids is not null)
            {
                @foreach (var a in LocalAids)
                {
                    <MudSelectItem Value="@a.Prefix">
                        <AidPrefixDisplay Prefix="@a.Prefix" Name="@a.Name" ShowCopyButton="false" />
                    </MudSelectItem>
                }
            }
        </MudSelect>

        <MudSelect T="string" Label="Holder"
                   Value="@selectedHolderPrefix"
                   ValueChanged="@((string v) => { selectedHolderPrefix = v; StateHasChanged(); })"
                   Variant="Variant.Outlined" Dense="true" Modal="true">
            @foreach (var (prefix, name, _) in SelectableHolders)
            {
                <MudSelectItem Value="@prefix">
                    <AidPrefixDisplay Prefix="@prefix" Name="@name" ShowCopyButton="false" />
                </MudSelectItem>
            }
        </MudSelect>

        <MudTextField T="string" Label="Role"
                      @bind-Value="adHocEcrRole"
                      Immediate="true"
                      Variant="Variant.Outlined" Required="true"
                      RequiredError="Role is required" />

        @if (AdHocValidationRules.Count > 0)
        {
            <MudStack Spacing="0" Class="mt-1">
                @foreach (var (text, isValid) in AdHocValidationRules)
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@(isValid ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                                 Color="@(isValid ? Color.Success : Color.Error)" Size="Size.Small" />
                        <MudText Typo="Typo.body2" Color="@(isValid ? Color.Default : Color.Error)">@text</MudText>
                    </MudStack>
                }
            </MudStack>
        }
    };

    RenderFragment RenderCredentialReview => __builder =>
    {
        if (credentialForReview is null)
        {
            <MudAlert Severity="Severity.Warning">No credential data to display.</MudAlert>
            return;
        }
        <MudText Typo="Typo.subtitle2">Review the credential to be @(IsOffer ? "offered" : "granted")</MudText>
        <CredentialViewPrefsComponent />
        <CredentialComponent Credential="@credentialForReview"
                             ViewOptions="@PageViewOptions"
                             Expanded="true" />
    };

    // ================= Action bar =================

    RenderFragment RenderActions => __builder =>
    {
        switch (currentStep)
        {
            case DialogStep.Input:
                <MudButton OnClick="OnRejectClicked" Variant="Variant.Outlined" Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.Block">
                    @(Mode == DialogMode.AdHoc ? "Cancel" : "Reject application")
                </MudButton>
                <MudButton OnClick="OnNextFromInputClicked" Variant="Variant.Filled" Color="Color.Primary"
                           Disabled="@(!NextEnabled)">
                    @(Mode == DialogMode.ReviewAgree ? "Next: Review credential" : "Next: Issue credential")
                </MudButton>
                break;

            case DialogStep.Issuing:
                @* No action bar while working — Retry / Cancel only when an error is surfaced. *@
                @if (errorMessage is not null)
                {
                    <MudButton OnClick="OnRejectClicked" Variant="Variant.Outlined" Color="Color.Default">
                        Cancel
                    </MudButton>
                    <MudButton OnClick="OnNextFromInputClicked" Variant="Variant.Filled" Color="Color.Primary">
                        Retry
                    </MudButton>
                }
                break;

            case DialogStep.Review:
                <MudButton OnClick="OnRejectClicked" Variant="Variant.Outlined" Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.Block">
                    Reject
                </MudButton>
                <MudButton OnClick="OnConfirmFromReviewClicked" Variant="Variant.Filled" Color="Color.Primary">
                    @ActionLabel
                </MudButton>
                break;

            case DialogStep.Submitting:
                @if (errorMessage is not null)
                {
                    <MudButton OnClick="OnRejectClicked" Variant="Variant.Outlined" Color="Color.Default">
                        Cancel
                    </MudButton>
                    <MudButton OnClick="OnConfirmFromReviewClicked" Variant="Variant.Filled" Color="Color.Primary">
                        Retry
                    </MudButton>
                }
                break;
        }
    };

    // ================= Step transitions =================

    async Task OnNextFromInputClicked() {
        errorMessage = null;

        if (Mode == DialogMode.ReviewAgree)
        {
            // No issuance — fetch the prior offer exchange and extract the embedded credential.
            currentStep = DialogStep.Issuing;
            StateHasChanged();
            await FetchCredentialFromPriorOfferAsync();
        }
        else
        {
            // ReviewApply or AdHoc — issue a new credential.
            currentStep = DialogStep.Issuing;
            StateHasChanged();
            await IssueCredentialAsync();
        }
    }

    async Task OnConfirmFromReviewClicked() {
        errorMessage = null;
        currentStep = DialogStep.Submitting;
        StateHasChanged();

        if (IsOffer)
        {
            await SubmitOfferAsync();
        }
        else
        {
            await SubmitGrantAsync();
        }
    }

    async Task OnRejectClicked() {
        // If the user rejects after issuance but before successful submission, call the revoke
        // stub so the App can surface a "not yet implemented" snackbar — the user should understand
        // the credential has been signed and sits in the issuer's registry.
        if (credentialIssuedButNotSubmitted && issuedCredentialSaid is not null && IssuerPrefix is not null)
        {
            await TryRevokeIssuedCredentialAsync();
        }
        MudDialog?.Cancel();
    }

    // ================= RPC calls =================

    async Task IssueCredentialAsync() {
        var senderPrefix = IssuerPrefix;
        var recipientPrefix = HolderPrefix;
        var ecrRole = EffectiveEcrRole;

        if (string.IsNullOrEmpty(senderPrefix) || string.IsNullOrEmpty(recipientPrefix) || string.IsNullOrEmpty(ecrRole))
        {
            errorMessage = "Missing issuer, holder, or role.";
            currentStep = DialogStep.Input;
            StateHasChanged();
            return;
        }

        try
        {
            var response = await appBwPortService.SendRpcRequestAsync(
                AppBwMessageType.Values.RequestIssueEcrCredential,
                new { payload = new IssueEcrCredentialRequestPayload(
                    SenderNameOrPrefix: senderPrefix,
                    RecipientPrefix: recipientPrefix,
                    EcrRole: ecrRole) },
                timeout: TimeSpan.FromMinutes(3));

            if (!response.Ok)
            {
                errorMessage = $"Issue failed: {response.Error}";
                StateHasChanged();
                return;
            }

            var result = response.Result is JsonElement el
                ? JsonSerializer.Deserialize<IssueEcrCredentialResponsePayload>(el.GetRawText(), Helper.JsonOptions.PortMessaging)
                : null;

            if (result is null || !result.Success || result.Acdc is null || result.Anc is null || result.Iss is null || result.CredentialSaid is null)
            {
                errorMessage = $"Issue failed: {result?.Error ?? "Unknown error"}";
                StateHasChanged();
                return;
            }

            issuedCredentialSaid = result.CredentialSaid;
            issuedAcdc = result.Acdc;
            issuedAnc = result.Anc;
            issuedIss = result.Iss;
            credentialForReview = new RecursiveDictionary { ["sad"] = result.Acdc };
            credentialIssuedButNotSubmitted = true;

            currentStep = DialogStep.Review;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Error during credential issuance");
            errorMessage = $"Error: {ex.Message}";
            StateHasChanged();
        }
    }

    async Task FetchCredentialFromPriorOfferAsync() {
        var offerSaid = PriorOfferSaid;
        if (string.IsNullOrEmpty(offerSaid))
        {
            errorMessage = "Agree exchange has no prior offer reference.";
            currentStep = DialogStep.Input;
            StateHasChanged();
            return;
        }

        try
        {
            // Cache-first: check AppCache before RPC roundtrip
            RecursiveDictionary? offerExchange = null;
            if (appCache.MyCachedExns.TryGetValue(offerSaid, out var cachedJson))
            {
                offerExchange = JsonSerializer.Deserialize<RecursiveDictionary>(cachedJson, JsonOptions.RecursiveDictionary);
            }

            if (offerExchange is null)
            {
                // Cache miss: fetch via RPC (BackgroundWorker will cache it)
                var response = await appBwPortService.SendRpcRequestAsync(
                    AppBwMessageType.Values.RequestGetExchange,
                    new { payload = new GetExchangeRequestPayload(Said: offerSaid) },
                    timeout: TimeSpan.FromMinutes(1));

                if (!response.Ok)
                {
                    errorMessage = $"Failed to fetch prior offer: {response.Error}";
                    StateHasChanged();
                    return;
                }

                var result = response.Result is JsonElement el
                    ? JsonSerializer.Deserialize<GetExchangeResponsePayload>(el.GetRawText(), Helper.JsonOptions.PortMessaging)
                    : null;

                if (result is null || !result.Success || result.Exchange is null)
                {
                    errorMessage = $"Failed to fetch prior offer: {result?.Error ?? "Unknown error"}";
                    StateHasChanged();
                    return;
                }

                offerExchange = result.Exchange;
            }

            var offerView = ExchangeView.FromRecursiveDictionary(offerExchange);
            var acdc = offerView.E?.GetByPath("acdc")?.Dictionary;
            if (acdc is null)
            {
                errorMessage = "Prior offer does not embed an ACDC.";
                StateHasChanged();
                return;
            }

            credentialForReview = new RecursiveDictionary { ["sad"] = acdc };
            // ReviewAgree path does not produce a fresh credential on the BW, so the revoke guard
            // stays false — cancel at this point is a plain close.
            currentStep = DialogStep.Review;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Error fetching prior offer exchange");
            errorMessage = $"Error: {ex.Message}";
            StateHasChanged();
        }
    }

    async Task SubmitOfferAsync() {
        var senderPrefix = IssuerPrefix;
        var recipientPrefix = HolderPrefix;
        if (string.IsNullOrEmpty(senderPrefix) || string.IsNullOrEmpty(recipientPrefix) || issuedCredentialSaid is null)
        {
            errorMessage = "Missing data to submit offer.";
            StateHasChanged();
            return;
        }

        try
        {
            var response = await appBwPortService.SendRpcRequestAsync(
                AppBwMessageType.Values.RequestSubmitIpexOffer,
                new { payload = new SubmitIpexOfferRequestPayload(
                    SenderNameOrPrefix: senderPrefix,
                    RecipientPrefix: recipientPrefix,
                    CredentialSaid: issuedCredentialSaid,
                    ApplySaid: ApplyExchange?.D) },
                timeout: TimeSpan.FromMinutes(3));

            if (!response.Ok)
            {
                errorMessage = $"Offer failed: {response.Error}";
                StateHasChanged();
                return;
            }

            var result = response.Result is JsonElement el
                ? JsonSerializer.Deserialize<SubmitIpexOfferResponsePayload>(el.GetRawText(), Helper.JsonOptions.PortMessaging)
                : null;

            if (result is null || !result.Success)
            {
                errorMessage = $"Offer failed: {result?.Error ?? "Unknown error"}";
                StateHasChanged();
                return;
            }

            credentialIssuedButNotSubmitted = false;
            MudDialog?.Close(DialogResult.Ok(new IssuanceDialogResult(Submitted: true, CredentialSaid: issuedCredentialSaid, IssuerPrefix: IssuerPrefix, HolderPrefix: HolderPrefix, RoleName: EffectiveEcrRole)));
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Error during IPEX offer submit");
            errorMessage = $"Error: {ex.Message}";
            StateHasChanged();
        }
    }

    async Task SubmitGrantAsync() {
        var senderPrefix = IssuerPrefix;
        var recipientPrefix = HolderPrefix;
        if (string.IsNullOrEmpty(senderPrefix) || string.IsNullOrEmpty(recipientPrefix))
        {
            errorMessage = "Missing data to submit grant.";
            StateHasChanged();
            return;
        }

        // Two branches: agree-reuse (pass agreeSaid) vs post-issue (pass acdc/anc/iss).
        var payload = Mode == DialogMode.ReviewAgree
            ? new SubmitIpexGrantRequestPayload(
                SenderNameOrPrefix: senderPrefix,
                RecipientPrefix: recipientPrefix,
                AgreeSaid: AgreeExchange?.D)
            : new SubmitIpexGrantRequestPayload(
                SenderNameOrPrefix: senderPrefix,
                RecipientPrefix: recipientPrefix,
                Acdc: issuedAcdc,
                Anc: issuedAnc,
                Iss: issuedIss);

        if (Mode == DialogMode.ReviewAgree && string.IsNullOrEmpty(payload.AgreeSaid))
        {
            errorMessage = "Missing agree SAID.";
            StateHasChanged();
            return;
        }
        if (Mode != DialogMode.ReviewAgree && (payload.Acdc is null || payload.Anc is null || payload.Iss is null))
        {
            errorMessage = "Missing issued credential data.";
            StateHasChanged();
            return;
        }

        try
        {
            var response = await appBwPortService.SendRpcRequestAsync(
                AppBwMessageType.Values.RequestSubmitIpexGrant,
                new { payload },
                timeout: TimeSpan.FromMinutes(3));

            if (!response.Ok)
            {
                errorMessage = $"Grant failed: {response.Error}";
                StateHasChanged();
                return;
            }

            var result = response.Result is JsonElement el
                ? JsonSerializer.Deserialize<SubmitIpexGrantResponsePayload>(el.GetRawText(), Helper.JsonOptions.PortMessaging)
                : null;

            if (result is null || !result.Success)
            {
                errorMessage = $"Grant failed: {result?.Error ?? "Unknown error"}";
                StateHasChanged();
                return;
            }

            credentialIssuedButNotSubmitted = false;
            MudDialog?.Close(DialogResult.Ok(new IssuanceDialogResult(Submitted: true, CredentialSaid: issuedCredentialSaid, IssuerPrefix: IssuerPrefix, HolderPrefix: HolderPrefix, RoleName: EffectiveEcrRole)));
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Error during IPEX grant submit");
            errorMessage = $"Error: {ex.Message}";
            StateHasChanged();
        }
    }

    async Task TryRevokeIssuedCredentialAsync() {
        try
        {
            var response = await appBwPortService.SendRpcRequestAsync(
                AppBwMessageType.Values.RequestRevokeCredential,
                new { payload = new RevokeCredentialRequestPayload(
                    IssuerNameOrPrefix: IssuerPrefix!,
                    CredentialSaid: issuedCredentialSaid!) },
                timeout: TimeSpan.FromSeconds(30));

            var result = response.Ok && response.Result is JsonElement el
                ? JsonSerializer.Deserialize<RevokeCredentialResponsePayload>(el.GetRawText(), Helper.JsonOptions.PortMessaging)
                : null;

            // STUB: the BW handler currently returns Success=false with
            // Error="Revocation not yet implemented". Surface the user-facing warning.
            var errText = result?.Error ?? "Revocation not yet implemented";
            snackbar.Add(
                $"{errText} — issued credential remains in your issuer registry.",
                Severity.Warning);
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Error calling revoke stub");
            snackbar.Add(
                "Revocation not yet implemented — issued credential remains in your issuer registry.",
                Severity.Warning);
        }
    }
}
