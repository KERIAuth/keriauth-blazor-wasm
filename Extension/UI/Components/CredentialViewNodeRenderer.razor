@using Extension.Models
@using static Extension.Helper.Identicon

@code {
    [Parameter, EditorRequired]
    public required CredentialViewNode Node { get; init; }

    [Parameter]
    public CredentialViewOptions ViewOptions { get; set; } = new();

    [Parameter]
    public Dictionary<string, bool> DisclosureState { get; set; } = new();

    [Parameter]
    public EventCallback<(string Path, bool Disclosed)> OnDisclosureToggle { get; set; }

    [Parameter]
    public string PathPrefix { get; set; } = "";

    /// <summary>
    /// Extra indent levels added to every row this node and its descendants render. Used when
    /// this subtree is rendered inside a nested context (e.g., a chained credential) so that
    /// Node.Depth (assigned by the pipeline, relative to the credential's own tree) combines
    /// with the host's indent level.
    /// </summary>
    [Parameter]
    public int DepthOffset { get; set; }

    /// <summary>
    /// Flat map from credential SAID (sad.d) to view tree, cascaded from the root
    /// CredentialViewTreeRenderer. Used in the SaidReference case to resolve an edge
    /// `n` reference to a chained credential and render it inline.
    /// </summary>
    [CascadingParameter(Name = "ChainIndex")]
    public Dictionary<string, CredentialViewTree>? ChainIndex { get; set; }

    string NodePath => string.IsNullOrEmpty(PathPrefix) ? Node.Key : $"{PathPrefix}.{Node.Key}";

    bool IsDisclosed => DisclosureState.TryGetValue(NodePath, out var d) && d;

    async Task ToggleDisclosure(bool disclosed) {
        await OnDisclosureToggle.InvokeAsync((NodePath, disclosed));
    }

    // Indent is applied to the content column (not the whole row) via a CSS custom property,
    // so the gutter — and any checkbox sitting in it — always stays at the left edge.
    string RowStyle(int extraIndent = 0) =>
        $"--bt-indent: {(Node.Depth + DepthOffset + extraIndent) * 1.25:0.##}rem";

    // Heuristic: a 44-char string starting with an ASCII uppercase letter and otherwise made
    // of base64url chars looks like a CESR qb64 SAID/AID. Used in the Value branch to route
    // such values through SaidDisplay so they participate in the AbbreviateSaids preference.
    static bool LooksLikeSaid(string? s) {
        if (s is null || s.Length != 44) return false;
        if (s[0] < 'A' || s[0] > 'Z') return false;
        for (var i = 1; i < s.Length; i++) {
            var c = s[i];
            var ok = (c >= 'A' && c <= 'Z') || (c >= 'a' && c <= 'z')
                  || (c >= '0' && c <= '9') || c == '_' || c == '-';
            if (!ok) return false;
        }
        return true;
    }

    string DisclosureTag {
        get {
            if (!IsDisclosed) return "undisclosed";
            foreach (var child in Node.Children) {
                if (!IsFullyDisclosed(child, NodePath)) return "partially disclosed";
            }
            if (Node.ChainedTree is not null) {
                foreach (var child in Node.ChainedTree.Children) {
                    if (!IsFullyDisclosed(child, NodePath)) return "partially disclosed";
                }
            }
            return "disclosed";
        }
    }

    bool IsFullyDisclosed(CredentialViewNode node, string parentPath) {
        var myPath = string.IsNullOrEmpty(parentPath) ? node.Key : $"{parentPath}.{node.Key}";
        var isToggleable = node.IsElisionToggleable
            && (node.Kind == CredentialViewNodeKind.Dictionary
                || node.Kind == CredentialViewNodeKind.SaidReference);
        if (isToggleable && !(DisclosureState.TryGetValue(myPath, out var d) && d)) {
            return false;
        }
        foreach (var child in node.Children) {
            if (!IsFullyDisclosed(child, myPath)) return false;
        }
        if (node.ChainedTree is not null) {
            foreach (var child in node.ChainedTree.Children) {
                if (!IsFullyDisclosed(child, myPath)) return false;
            }
        }
        return true;
    }
}

@switch (Node.Kind)
{
    case CredentialViewNodeKind.Value:
        <div class="bt-credview-row" style="@RowStyle()">
            <div class="bt-credview-gutter"></div>
            <div class="bt-credview-content bt-credview-content-field bt-credview-text-schema">
                <LabelWithProvenance Label="@Node.Label"
                                     ViewSpecLabel="@Node.ViewSpecLabel"
                                     SchemaDescription="@Node.TooltipText"
                                     FieldKey="@Node.Path" />
            </div>
        </div>
        <div class="bt-credview-row" style="@RowStyle(1)">
            <div class="bt-credview-gutter"></div>
            <div class="bt-credview-content bt-credview-content-value">
                @{
                    var displayValue = Node.RawValue;
                }
                @if (Node.Format is not null)
                {
                    <CredentialFieldValueDisplay Value="@displayValue" Format="@Node.Format" />
                }
                else if (Node.ComponentHint == ComponentHints.AidPrefix && ViewOptions.IsAidPrefixDisplay)
                {
                    <AidPrefixDisplay Prefix="@Node.ComponentData" DisplayNameInParentheses="true" />
                }
                else if (LooksLikeSaid(displayValue))
                {
                    <SaidDisplay Said="@displayValue" />
                }
                else
                {
                    <span class="bt-credview-text-acdc">@displayValue</span>
                }
            </div>
        </div>
        break;

    case CredentialViewNodeKind.Dictionary:
        @if (Node.IsElisionToggleable && ViewOptions.IsPresentation)
        {
            <div class="bt-credview-row" style="@RowStyle()">
                <div class="bt-credview-gutter">
                    <MudCheckBox T="bool" Value="@IsDisclosed"
                                 ValueChanged="@(val => ToggleDisclosure(val))"
                                 Dense="true" />
                </div>
                <div class="bt-credview-content bt-credview-content-field">
                    <span class="bt-credview-text-schema"><b>@($"{Node.Label}")</b></span>
                    <span class="bt-credview-disclosure-tag">[@DisclosureTag]</span>
                </div>
            </div>
            @if (!IsDisclosed && !string.IsNullOrEmpty(Node.SaidDigest))
            {
                <div class="bt-credview-row" style="@RowStyle(1)">
                    <div class="bt-credview-gutter"></div>
                    <div class="bt-credview-content bt-credview-content-value bt-credview-text-acdc"><SaidDisplay Said="@Node.SaidDigest" /></div>
                </div>
            }
            @if (IsDisclosed)
            {
                @foreach (var child in Node.Children)
                {
                    <CredentialViewNodeRenderer Node="@child"
                                                ViewOptions="@ViewOptions"
                                                DisclosureState="@DisclosureState"
                                                OnDisclosureToggle="@OnDisclosureToggle"
                                                PathPrefix="@NodePath"
                                                DepthOffset="@DepthOffset" />
                }
            }
        }
        else
        {
            <div class="bt-credview-row" style="@RowStyle()">
                <div class="bt-credview-gutter"></div>
                <div class="bt-credview-content bt-credview-content-field bt-credview-text-schema">
                    <LabelWithProvenance Label="@Node.Label"
                                         ViewSpecLabel="@Node.ViewSpecLabel"
                                         SchemaDescription="@Node.TooltipText"
                                         FieldKey="@Node.Path" />
                </div>
            </div>
            @foreach (var child in Node.Children)
            {
                <CredentialViewNodeRenderer Node="@child"
                                            ViewOptions="@ViewOptions"
                                            DisclosureState="@DisclosureState"
                                            OnDisclosureToggle="@OnDisclosureToggle"
                                            PathPrefix="@NodePath"
                                            DepthOffset="@DepthOffset" />
            }
        }
        break;

    case CredentialViewNodeKind.Array:
        <div class="bt-credview-row" style="@RowStyle()">
            <div class="bt-credview-gutter"></div>
            <div class="bt-credview-content bt-credview-content-field bt-credview-text-schema">
                <LabelWithProvenance Label="@Node.Label"
                                     ViewSpecLabel="@Node.ViewSpecLabel"
                                     SchemaDescription="@Node.TooltipText"
                                     FieldKey="@Node.Path" />
            </div>
        </div>
        @foreach (var child in Node.Children)
        {
            <CredentialViewNodeRenderer Node="@child"
                                        ViewOptions="@ViewOptions"
                                        DisclosureState="@DisclosureState"
                                        OnDisclosureToggle="@OnDisclosureToggle"
                                        PathPrefix="@NodePath"
                                        DepthOffset="@DepthOffset" />
        }
        break;

    case CredentialViewNodeKind.SaidReference:
        // If this reference's SAID matches a chained credential in the tree, we render
        // that credential inline (indented) instead of the raw SAID digest. Always
        // consumes the chain from top-level, regardless of disclosure state.
        var matchedChain = Node.SaidDigest is { Length: > 0 } refSaid
            && ChainIndex is not null
            && ChainIndex.TryGetValue(refSaid, out var mc)
            ? mc
            : null;
        @if (Node.IsElisionToggleable && ViewOptions.IsPresentation)
        {
            <div class="bt-credview-row" style="@RowStyle()">
                <div class="bt-credview-gutter">
                    <MudCheckBox T="bool" Value="@IsDisclosed"
                                 ValueChanged="@(val => ToggleDisclosure(val))"
                                 Dense="true" />
                </div>
                <div class="bt-credview-content bt-credview-content-field">
                    <span class="bt-credview-text-schema">
                        <LabelWithProvenance Label="@Node.Label"
                                             ViewSpecLabel="@Node.ViewSpecLabel"
                                             SchemaDescription="@Node.TooltipText"
                                             FieldKey="@Node.Path" />
                    </span>
                    <span class="bt-credview-disclosure-tag">[@DisclosureTag]</span>
                </div>
            </div>
            @if (IsDisclosed && matchedChain is not null)
            {
                <CredentialViewTreeRenderer Tree="@matchedChain"
                                             ViewOptions="@ViewOptions"
                                             DisclosureState="@DisclosureState"
                                             OnDisclosureToggle="@OnDisclosureToggle"
                                             DepthOffset="@(Node.Depth + DepthOffset + 1)"
                                             IsNested="true"
                                             PathPrefix="@($"{NodePath}/")" />
            }
            else
            {
                <div class="bt-credview-row" style="@RowStyle(1)">
                    <div class="bt-credview-gutter"></div>
                    <div class="bt-credview-content bt-credview-content-value bt-credview-text-acdc"><SaidDisplay Said="@Node.SaidDigest" /></div>
                </div>
            }
        }
        else
        {
            <div class="bt-credview-row" style="@RowStyle()">
                <div class="bt-credview-gutter"></div>
                <div class="bt-credview-content bt-credview-content-field bt-credview-text-schema">
                    <LabelWithProvenance Label="@Node.Label"
                                         ViewSpecLabel="@Node.ViewSpecLabel"
                                         SchemaDescription="@Node.TooltipText"
                                         FieldKey="@Node.Path" />
                </div>
            </div>
            @if (matchedChain is not null)
            {
                <CredentialViewTreeRenderer Tree="@matchedChain"
                                             ViewOptions="@ViewOptions"
                                             DisclosureState="@DisclosureState"
                                             OnDisclosureToggle="@OnDisclosureToggle"
                                             DepthOffset="@(Node.Depth + DepthOffset + 1)"
                                             IsNested="true"
                                             PathPrefix="@($"{NodePath}/")" />
            }
            else
            {
                <div class="bt-credview-row" style="@RowStyle(1)">
                    <div class="bt-credview-gutter"></div>
                    <div class="bt-credview-content bt-credview-content-value bt-credview-text-acdc"><SaidDisplay Said="@Node.SaidDigest" /></div>
                </div>
            }
        }
        break;

    case CredentialViewNodeKind.ChainedCredential:
        @if (Node.ChainedTree is not null)
        {
            <CredentialViewTreeRenderer Tree="@Node.ChainedTree"
                                         ViewOptions="@ViewOptions"
                                         DisclosureState="@DisclosureState"
                                         OnDisclosureToggle="@OnDisclosureToggle"
                                         DepthOffset="@(Node.Depth + DepthOffset + 1)"
                                         IsNested="true"
                                         PathPrefix="@($"{NodePath}/")" />
        }
        break;
}

