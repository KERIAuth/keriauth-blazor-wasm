@using Extension.Models
@using static Extension.Helper.Identicon

@code {
    [Parameter, EditorRequired]
    public required CredentialViewNode Node { get; init; }

    [Parameter]
    public CredentialViewOptions ViewOptions { get; set; } = new();

    [Parameter]
    public Dictionary<string, bool> DisclosureState { get; set; } = new();

    [Parameter]
    public EventCallback<(string Path, bool Disclosed)> OnDisclosureToggle { get; set; }

    [Parameter]
    public string PathPrefix { get; set; } = "";

    string NodePath => string.IsNullOrEmpty(PathPrefix) ? Node.Key : $"{PathPrefix}.{Node.Key}";

    bool IsDisclosed => DisclosureState.TryGetValue(NodePath, out var d) && d;

    async Task ToggleDisclosure(bool disclosed) {
        await OnDisclosureToggle.InvokeAsync((NodePath, disclosed));
    }

    string IndentClass => Node.Depth > 0 ? "ml-4" : "";
}

@switch (Node.Kind)
{
    case CredentialViewNodeKind.Value:
        <MudStack Row="true" Spacing="2" Class="@($"py-1 {IndentClass}")">
            <MudTooltip Text="@Node.TooltipText" Delay="500" Arrow="true" Placement="Placement.Top">
                <MudText Typo="Typo.body2" Style="min-width: 120px; color: var(--mud-palette-text-secondary);"><b>@Node.Label</b></MudText>
            </MudTooltip>
            @if (Node.ComponentHint == ComponentHints.AidPrefix && ViewOptions.IsAidPrefixDisplay)
            {
                <AidPrefixDisplay Prefix="@Node.ComponentData" ShowCopyButton="false" />
            }
            else
            {
                <MudText Typo="Typo.body2" Style="overflow-wrap: anywhere;">@(Node.FormattedValue ?? Node.RawValue)</MudText>
            }
        </MudStack>
        break;

    case CredentialViewNodeKind.Dictionary:
        @if (Node.IsElisionToggleable && ViewOptions.IsPresentation)
        {
            <MudPaper Class="@($"pa-2 mt-1 {IndentClass}")" Outlined="true">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudCheckBox T="bool" Value="@IsDisclosed"
                                 ValueChanged="@(val => ToggleDisclosure(val))"
                                 Label="@($"Disclose {Node.Label}")"
                                 Dense="true" />
                    @if (!IsDisclosed && !string.IsNullOrEmpty(Node.SaidDigest))
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-family: monospace;">
                            @TruncateSaid(Node.SaidDigest)
                        </MudText>
                    }
                </MudStack>
                @if (IsDisclosed)
                {
                    <MudStack Class="ml-4 mt-1" Spacing="0">
                        @foreach (var child in Node.Children)
                        {
                            <CredentialViewNodeRenderer Node="@child"
                                                        ViewOptions="@ViewOptions"
                                                        DisclosureState="@DisclosureState"
                                                        OnDisclosureToggle="@OnDisclosureToggle"
                                                        PathPrefix="@NodePath" />
                        }
                    </MudStack>
                }
            </MudPaper>
        }
        else
        {
            <MudPaper Class="@($"pa-2 mt-1 {IndentClass}")" Outlined="true">
                <MudTooltip Text="@Node.TooltipText" Delay="500" Arrow="true" Placement="Placement.Top">
                    <MudText Typo="Typo.subtitle2"><b>@Node.Label</b></MudText>
                </MudTooltip>
                <MudStack Class="ml-4 mt-1" Spacing="0">
                    @foreach (var child in Node.Children)
                    {
                        <CredentialViewNodeRenderer Node="@child"
                                                    ViewOptions="@ViewOptions"
                                                    DisclosureState="@DisclosureState"
                                                    OnDisclosureToggle="@OnDisclosureToggle"
                                                    PathPrefix="@NodePath" />
                    }
                </MudStack>
            </MudPaper>
        }
        break;

    case CredentialViewNodeKind.Array:
        <MudPaper Class="@($"pa-2 mt-1 {IndentClass}")" Outlined="true">
            <MudText Typo="Typo.subtitle2"><b>@Node.Label</b></MudText>
            <MudStack Class="ml-4 mt-1" Spacing="0">
                @foreach (var child in Node.Children)
                {
                    <CredentialViewNodeRenderer Node="@child"
                                                ViewOptions="@ViewOptions"
                                                DisclosureState="@DisclosureState"
                                                OnDisclosureToggle="@OnDisclosureToggle"
                                                PathPrefix="@NodePath" />
                }
            </MudStack>
        </MudPaper>
        break;

    case CredentialViewNodeKind.SaidReference:
        @if (Node.IsElisionToggleable && ViewOptions.IsPresentation)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="@($"py-1 {IndentClass}")">
                <MudCheckBox T="bool" Value="@IsDisclosed"
                             ValueChanged="@(val => ToggleDisclosure(val))"
                             Label="@Node.Label"
                             Dense="true" />
                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-family: monospace;">
                    @TruncateSaid(Node.SaidDigest)
                </MudText>
            </MudStack>
        }
        else
        {
            <MudStack Row="true" Spacing="2" Class="@($"py-1 {IndentClass}")">
                <MudText Typo="Typo.body2" Style="min-width: 120px; color: var(--mud-palette-text-secondary);"><b>@Node.Label</b></MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-family: monospace;">
                    @TruncateSaid(Node.SaidDigest)
                </MudText>
            </MudStack>
        }
        break;

    case CredentialViewNodeKind.ChainedCredential:
        @if (Node.ChainedTree is not null)
        {
            <CredentialViewTreeRenderer Tree="@Node.ChainedTree"
                                         ViewOptions="@ViewOptions"
                                         DisclosureState="@DisclosureState"
                                         OnDisclosureToggle="@OnDisclosureToggle" />
        }
        break;
}

@code {
    static string TruncateSaid(string? said) {
        if (string.IsNullOrEmpty(said)) return "";
        return said.Length > 12 ? $"{said[..12]}…" : said;
    }
}
