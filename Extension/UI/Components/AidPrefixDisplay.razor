@using static Extension.Helper.Identicon
@using Extension.Services
@inject IJSRuntime js
@inject AppCache appCache

@* Displays an AID prefix with identicon, abbreviated text, abbreviated tooltip, and optional name/alias. 
// TODO P3: consider adding option to show a full-prefix tooltip
*@

<div class="bt-aid-prefix-display">
@if( !string.IsNullOrEmpty(Prefix)) {
    <MudTooltip Text="@ElideText(Prefix)" Delay="500" Arrow="true" Style="display:flex; align-items:center;" Class="bt-prefix">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            @if (TextPosition == TextSide.Left)
            {
                @TextBlock
            }
            @if (ShowIdenticon)
            {
                <MudIcon ViewBox="0 0 100 100" Icon="@MakeIdenticon(Prefix)" Class="bt-identicon" Style="@IdenticonStyle" />
            }
            @if (TextPosition == TextSide.Right)
            {
                @TextBlock
            }
        </MudStack>
    </MudTooltip>
    if (ShowCopyButton)
        {
        <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                       Size="Size.Small"
                       OnClick="CopyToClipboard"
                       Class="bt-aid-copy"
                       Style="padding: 0px !important;"
                       aria-label="Copy prefix" />
        }
    }
</div>

@code {
    public enum TextSide { Right, Left }

    [Parameter, EditorRequired]
    public string Prefix { get; set; } = "";

    [Parameter]
    public string? Name { get; set; }

    [Parameter]
    public int HeadChars { get; set; } = 4;

    [Parameter]
    public int TailChars { get; set; } = 4;

    [Parameter]
    public bool ShowIdenticon { get; set; } = true;

    [Parameter]
    public bool ShowCopyButton { get; set; } = true;

    [Parameter]
    public string IdenticonStyle { get; set; } = "width: 2.5rem; height: 2.5rem;";

    [Parameter]
    public bool ShowName { get; set; } = true;

    [Parameter]
    public bool ShowPrefix { get; set; } = true;

    [Parameter]
    public string? TextClass { get; set; }

    [Parameter]
    public string? TextStyle { get; set; }

    [Parameter]
    public TextSide TextPosition { get; set; } = TextSide.Right;

    [Parameter]
    public bool DisplayNameInParentheses { get; set; }

    // Auto-resolve name from AppCache when Name is not explicitly passed.
    // Priority: user's profile (AID) name → connection name → null.
    string? AutoResolvedName =>
        appCache.Aids?.FirstOrDefault(a => a.Prefix == Prefix)?.Name
        ?? appCache.MyConnections?.FirstOrDefault(c => c.ReceiverPrefix == Prefix)?.Name;

    string? EffectiveName => Name ?? AutoResolvedName;

    string? DisplayName => DisplayNameInParentheses && EffectiveName is not null
        ? $"({EffectiveName})"
        : EffectiveName;

    string TextBlockClass => $"{(TextPosition == TextSide.Left ? "bt-aid-text bt-aid-text-left" : "bt-aid-text bt-aid-text-right")}{(TextClass is not null ? $" {TextClass}" : "")}";

    bool ShowTextBlock => ShowName && DisplayName is not null || ShowPrefix;

    RenderFragment TextBlock => __builder =>
    {
        if (!ShowTextBlock) return;
        <div class="@TextBlockClass" style="@TextStyle">
        @if (ShowName && DisplayName is not null)
        {
            <MudText Typo="Typo.caption" Class="bt-aid-name">@DisplayName</MudText>
        }
        @if (ShowPrefix)
        {
            <span class="bt-aid-prefix-text">@Elide(Prefix, HeadChars, TailChars)</span>
        }
        </div>
    };

    async Task CopyToClipboard()
    {
        await js.InvokeVoidAsync("navigator.clipboard.writeText", Prefix);
    }
}