@page "/OfferPasskey.html"
@layout Layouts.MainLayout
@using Extension.Services.Storage
@using static Extension.AppConfig

@inject NavigationManager navManager
@inject ILogger<OfferPasskeyPage> logger
@inject IJSRuntime js
@inject AppCache appCache
@inject IStorageService storageService

@code {
    private MudButton? createPasskeyButton;
    private bool _shouldFocusButton = true;

    protected override void OnInitialized()
    {
        logger.LogInformation("OfferPasskeyPage OnInitialized");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_shouldFocusButton && createPasskeyButton is not null)
        {
            _shouldFocusButton = false;
            // allow time for animation
            await Task.Delay(100);
            await createPasskeyButton.FocusAsync();
        }
    }

    async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            await DeclineOffer();
        }
    }

    async Task AcceptOffer()
    {
        logger.LogInformation("User accepted passkey offer");
        await PersistWasPasskeySuggested();
        navManager.NavigateTo(Routes.Paths.AddPasskey);
    }

    async Task DeclineOffer()
    {
        logger.LogInformation("User declined passkey offer");
        await PersistWasPasskeySuggested();
        navManager.NavigateTo(Routes.Paths.Index);
    }

    async Task PersistWasPasskeySuggested()
    {
        var selectedDigest = appCache.MyPreferences.KeriaPreference.SelectedKeriaConnectionDigest;
        if (string.IsNullOrEmpty(selectedDigest))
        {
            logger.LogWarning("PersistWasPasskeySuggested: No selected KERIA connection digest");
            return;
        }

        var configs = appCache.MyKeriaConnectConfigs;
        if (!configs.Configs.TryGetValue(selectedDigest, out var currentConfig))
        {
            logger.LogWarning("PersistWasPasskeySuggested: Config not found for digest {Digest}", selectedDigest);
            return;
        }

        var updatedConfig = currentConfig with { WasPasskeySuggested = true };
        var updatedConfigs = new Dictionary<string, KeriaConnectConfig>(configs.Configs) {
            [selectedDigest] = updatedConfig
        };
        var storeResult = await storageService.SetItem(new KeriaConnectConfigs {
            Configs = updatedConfigs,
            IsStored = true
        });
        if (storeResult.IsFailed)
        {
            logger.LogError("PersistWasPasskeySuggested: Failed to store config: {Errors}", string.Join(", ", storeResult.Errors));
            return;
        }

        await appCache.WaitForAppCache([() => appCache.MyKeriaConnectConfigs.Configs.TryGetValue(selectedDigest, out var c) && c.WasPasskeySuggested]);
    }
}

<div id="@this.GetType().Name" class="bt-body-page" @onkeydown="HandleKeyDown" tabindex="0">
    <MudStack Class="bt-main">
        <div class="bt-main-inside-scroll">
            <PageHeading Title="Create a passkey?" />
            <MudStack Class="mt-4">
                <MudText>
                    You may now (or later) create a convenient passkey that lets you unlock @AppConfig.ProductName instead of typing your passcode.
                </MudText>
                <MudText Class="mt-4">
                    You must still securely store and protect your passcode, as it will be required at some point.
                </MudText>
            </MudStack>
        </div>
    </MudStack>
    <MudStack Row="true" class="bt-button-tray">
        <MudSpacer />
        <MudButton Variant="Variant.Text" OnClick="DeclineOffer">Maybe later</MudButton>
        <MudButton @ref="createPasskeyButton" Variant="Variant.Filled" Color="Color.Primary" OnClick="AcceptOffer">Create passkey</MudButton>
    </MudStack>
</div>
