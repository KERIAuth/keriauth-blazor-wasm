@page "/TestCredential.html"
@layout Layouts.MainLayout
@using Extension.Models
@using Extension.Models.Storage
@using Extension.Services
@using Extension.Services.Storage
@inherits AuthenticatedPageBase
@implements IDisposable

@using static Extension.Helper.PreviousPage

@inject NavigationManager navManager
@inject IStorageService storageService
@inject IJSRuntime js
@inject ILogger<TestCredentialPage> logger
@inject AppCache appCache
@inject ICredentialViewSpecService viewSpecService

@code {
    List<RecursiveDictionary> credentials = [];
    bool isLoaded;
    int selectedIndex = -1;

    protected override async Task OnInitializedAsync()
    {
        InitializeAppCache(appCache);
        await this.SubscribeToAppCache(appCache, onChanged: async () => await LoadCredentials());
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadCredentials();
        isLoaded = true;
    }

    async Task LoadCredentials()
    {
        try
        {
            var cached = await storageService.GetItem<CachedCredentials>(StorageArea.Session);
            if (cached.IsSuccess && cached.Value?.RawJson is not null)
            {
                credentials = Helper.CredentialHelper.DeserializeCredentialsRawJson(cached.Value.RawJson);
            }
            else
            {
                credentials = [];
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Error loading credentials");
            credentials = [];
        }
    }

    void SelectCredential(int index)
    {
        selectedIndex = selectedIndex == index ? -1 : index;
    }

    public void Dispose()
    {
        this.UnsubscribeFromAppCache();
    }
}

<div id="@this.GetType().Name" class="bt-body-page">
    <MudStack Class="bt-main">
        <div class="bt-main-inside-scroll">
            <PageHeading Title="Test Credential Component" />

            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                Developer page for testing CredentialComponent behavior.
                Select a credential to view it with the new component.
            </MudText>

            @if (isLoaded)
            {
                @if (credentials.Any())
                {
                    <MudText Typo="Typo.subtitle2" Class="mb-1">Credentials (@credentials.Count)</MudText>

                    <MudExpansionPanels MultiExpansion="true" Class="credential-panels">
                        @for (int i = 0; i < credentials.Count; i++)
                        {
                            var index = i;
                            var credential = credentials[index];
                            <CredentialComponent Credential="@credential"
                                                  IsSelected="@(selectedIndex == index)"
                                                  OnClick="@(() => SelectCredential(index))" />
                        }
                    </MudExpansionPanels>
                }
                else
                {
                    <MudAlert Severity="Severity.Info">No credentials in session storage. Authenticate and load credentials first.</MudAlert>
                }
            }
        </div>
    </MudStack>
    <MudStack Row="true" class="bt-button-tray">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBackIosNew" Variant="Variant.Text" OnClick='@(async () => await GoBack(js))' Class="justify-start" />
        <MudSpacer></MudSpacer>
    </MudStack>
</div>
