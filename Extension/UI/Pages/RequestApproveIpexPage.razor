@page "/RequestApproveIpex.html"
@layout Layouts.DialogLayout
@inherits Extension.UI.Components.TabDialogPageBase

@using Extension.Helper
@using Extension.Models
@using Extension.Models.Messages.AppBw
@using Extension.Models.Messages.BwApp
@using Extension.Models.Messages.BwApp.Requests
@using Extension.Models.Storage
@using Extension.Services
@using Extension.Services.Storage
@using Extension.Services.SignifyService.Models
@using FluentResults
@using MudBlazor

@inject ILogger<RequestApproveIpexPage> logger
@inject ISnackbar snackbar
@inject IStorageService storageService
@inject AppCache appCache
@inject IJSRuntime js

@code {
    private MudButton? approveButton;

    // Page-specific properties
    string? SelectedPrefix { get; set; }
    string? SelectedAlias { get; set; }
    RecursiveDictionary? SelectedCredentialOrNothing { get; set; }

    // IPEX request details
    IpexKind ipexKind;
    bool isPresentation;
    string PageTitle = "Unknown IPEX Request";
    string PageDescription = "Unrecognized request type.";

    // Apply-specific fields
    string? SchemaSaid { get; set; }
    string? RequestRecipientPrefix { get; set; }
    RecursiveDictionary? Attributes { get; set; }

    // Agree-specific fields
    string? OfferSaid { get; set; }

    // Admit-specific fields
    string? GrantSaid { get; set; }

    string? RequestPayloadForDisplay { get; set; } // TODO P1 this is just a placeholder to have something on the UI for now, do a proper job of displaying the request details instead of dumping the raw JSON

    // Presentation-specific fields
    List<RecursiveDictionary> matchingCredentials = [];
    string? selectedCredentialSaid;
    Dictionary<string, bool> elisionMap = new();
    void OnSelectedCredentialSaidChanged(string? credSaid) {
        selectedCredentialSaid = credSaid;
    }

    string? ProfileNameForPrefix(string? prefix) =>
        prefix is null ? null : appCache?.Aids?.FirstOrDefault(a => a.Prefix == prefix)?.Name;

    bool IsPresentationApply => isPresentation && ipexKind == IpexKind.Apply;

    // Computed properties
    bool IsApproveDisabled => IsPresentationApply
        ? selectedCredentialSaid is null
        : SelectedPrefix is null;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        logger.LogInformation("OnInitializedAsync");

        // Peek at pending request type first to avoid false error logs from cascading attempts
        var pendingType = AppCache.NextPendingBwAppRequest?.Type;
        switch (pendingType)
        {
            case BwAppMessageType.Values.RequestIpexApply:
                {
                    var applyPayload = await InitializeFromPendingRequestAsync<RequestIpexApplyPayload>(
                        BwAppMessageType.Values.RequestIpexApply);
                    if (applyPayload is null) return;
                    ipexKind = IpexKind.Apply;
                    isPresentation = applyPayload.IsPresentation;
                    SchemaSaid = applyPayload.SchemaSaid;
                    RequestRecipientPrefix = applyPayload.RecipientPrefix;
                    Attributes = applyPayload.Attributes;
                    RequestPayloadForDisplay = applyPayload.ToString(); // TODO P1 do a proper job of displaying the request details instead of dumping the raw JSON, this is just a placeholder to have something on the UI for now
                    break;
                }
            case BwAppMessageType.Values.RequestIpexAgree:
                {
                    var agreePayload = await InitializeFromPendingRequestAsync<RequestIpexAgreePayload>(
                        BwAppMessageType.Values.RequestIpexAgree);
                    if (agreePayload is null) return;
                    ipexKind = IpexKind.Agree;
                    isPresentation = agreePayload.IsPresentation;
                    OfferSaid = agreePayload.OfferSaid;
                    RequestRecipientPrefix = agreePayload.RecipientPrefix;
                    break;
                }
            case BwAppMessageType.Values.RequestIpexAdmitFromPage:
                {
                    var admitPayload = await InitializeFromPendingRequestAsync<RequestIpexAdmitPayload>(
                        BwAppMessageType.Values.RequestIpexAdmitFromPage);
                    if (admitPayload is null) return;
                    ipexKind = IpexKind.Admit;
                    isPresentation = admitPayload.IsPresentation;
                    GrantSaid = admitPayload.GrantSaid;
                    RequestRecipientPrefix = admitPayload.RecipientPrefix;
                    break;
                }
            default:
                logger.LogError("OnInitializedAsync: Unexpected pending request type: {Type}", pendingType ?? "null");
                return;
        }

        // Derive page heading and description from (ipexKind, isPresentation) tuple
        (PageTitle, PageDescription) = (ipexKind, isPresentation) switch
        {
            (IpexKind.Apply, false) => (
                "approve credential application",
                "The page requests you to apply for a credential from an issuer."),
            (IpexKind.Apply, true) => (
                "present credential",
                "The page requests you to present a credential held by the indicated profile. (apply)"),
            (IpexKind.Agree, false) => (
                "agree to offered credential and its accuracy",
                "The page is requesting y   ou to carefully review and agree to credential issuance offer."),
            (IpexKind.Agree, true) => (
                "agree to offered credential presentation",
                "The page requests you to agree to credential presentation offer and its accuracy."),
            (IpexKind.Admit, false) => (
                "admit issued credential into your wallet",
                "The page requests you to acknowledge and admit receipt of granted credential."),
            (IpexKind.Admit, true) => (
                "admit granted credential presentation into your wallet",
                "The page requests you to acknowledge receipt of presented credential."),
            _ => LogUnexpectedKindAndReturn()
        };

        logger.LogInformation("OnInitializedAsync: ipexKind={IpexKind}, isPresentation={IsPresentation}, recipient={Recipient}",
            ipexKind, isPresentation, RequestRecipientPrefix);

        if (IsPresentationApply)
        {
            await LoadMatchingCredentials();
        }

        await LoadActiveTabAsync();

        IsInitialized = true;
        StateHasChanged();
    }

    (string, string) LogUnexpectedKindAndReturn()
    {
        logger.LogError("Unexpected IpexKind={Kind}, isPresentation={IsPresentation}", ipexKind, isPresentation);
        return ("Unknown IPEX Request", "Unrecognized request type.");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && approveButton is not null)
        {
            await approveButton.FocusAsync();
        }
    }

    async Task<Result> Approve()
    {
        await BeginActionAsync();

        if (TabId <= 0)
        {
            var error = new ValidationError("TabId", "Invalid tab ID");
            snackbar.Add(error.Message, Severity.Error);
            Layout?.EndAction();
            return Result.Fail(error);
        }

        if (SelectedPrefix is null || SelectedAlias is null)
        {
            var error = new ValidationError("Selection", "Identifier selection is incomplete");
            snackbar.Add(error.Message, Severity.Error);
            Layout?.EndAction();
            return Result.Fail(error);
        }

        try
        {
            logger.LogInformation("Approve: ipexKind={IpexKind}, senderPrefix={Prefix}", ipexKind, SelectedPrefix);

            switch (ipexKind)
            {
                case IpexKind.Apply when IsPresentationApply:
                    {
                        if (selectedCredentialSaid is null)
                        {
                            snackbar.Add("Please select a credential to present", Severity.Warning);
                            Layout?.EndAction();
                            return Result.Fail("No credential selected");
                        }
                        // TODO P1 Path (b): When this page is invoked from a web page request via content script,
                        // the presentation result (elided ACDC) also needs to be sent back to the requesting page
                        // through the content script port. The rp (receiving party) prefix from the original request
                        // is needed for routing. Currently only the KERIA agent-agent path (a) is implemented below.
                        // Send grant presentation RPC directly (credential already selected + disclosure configured)
                        var response = await AppBwPortService.SendRpcRequestAsync(
                            AppBwMessageType.Values.RequestIpexGrantPresentation,
                            new
                            {
                                payload = new IpexGrantPresentationRequestPayload(
                                SenderNameOrPrefix: RequestRecipientPrefix!,
                                RecipientPrefix: "TODO_VERIFIER", // TODO P2 since verifier info is not currently included in the request, this is just a placeholder and should be updated when that info is added to the request
                                ApplySaid: PageRequestId,
                                CredentialSaid: selectedCredentialSaid,
                                ElisionMap: elisionMap)
                            },
                            timeout: TimeSpan.FromMinutes(3));
                        if (!response.Ok)
                        {
                            snackbar.Add($"Grant presentation failed: {response.Error}", Severity.Error);
                            Layout?.EndAction();
                            return Result.Fail(response.Error ?? "Grant presentation failed");
                        }
                        break;
                    }
                case IpexKind.Apply:
                    {
                        var approvalPayload = new IpexApplyApprovalPayload(
                            SenderPrefix: SelectedPrefix,
                            RecipientPrefix: RequestRecipientPrefix!,
                            SchemaSaid: SchemaSaid!,
                            Attributes: Attributes
                        );
                        var message = new AppBwReplyIpexApplyApprovalMessage(TabId, OriginStr, PageRequestId, approvalPayload);
                        await AppBwPortService.SendToBackgroundWorkerAsync(message);
                        break;
                    }
                case IpexKind.Agree:
                    {
                        var approvalPayload = new IpexAgreeApprovalPayload(
                            SenderPrefix: SelectedPrefix,
                            RecipientPrefix: RequestRecipientPrefix!,
                            OfferSaid: OfferSaid!
                        );
                        var message = new AppBwReplyIpexAgreeApprovalMessage(TabId, OriginStr, PageRequestId, approvalPayload);
                        await AppBwPortService.SendToBackgroundWorkerAsync(message);
                        break;
                    }
                case IpexKind.Admit:
                    {
                        var approvalPayload = new IpexAdmitApprovalPayload(
                            SenderPrefix: SelectedPrefix,
                            RecipientPrefix: RequestRecipientPrefix!,
                            GrantSaid: GrantSaid!
                        );
                        var message = new AppBwReplyIpexAdmitApprovalMessage(TabId, OriginStr, PageRequestId, approvalPayload);
                        await AppBwPortService.SendToBackgroundWorkerAsync(message);
                        break;
                    }
                default:
                    logger.LogError("Approve: Unexpected ipexKind={IpexKind}", ipexKind);
                    return Result.Fail("Unexpected IPEX kind");
            }

            MarkAsReplied();
            await ClearPendingRequestAsync();
            await WaitForAppCacheClearAsync();
            await ReturnToPriorUIAsync();
            return Result.Ok();
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Failed to send IPEX approval");
            snackbar.Add($"Failed to send approval: {ex.Message}", Severity.Error);
            Layout?.EndAction();
            return Result.Fail(new JavaScriptInteropError("ApproveIpex", ex.Message, ex));
        }
    }

    async Task Cancel()
    {
        await CancelAndReturnAsync("User canceled IPEX request");
    }

    async Task LoadMatchingCredentials()
    {
        try
        {
            var cached = await storageService.GetItem<CachedCredentials>(StorageArea.Session);
            if (cached.IsSuccess && cached.Value?.RawJson is not null)
            {
                var allCredentials = CredentialHelper.DeserializeCredentialsRawJson(cached.Value.RawJson);

                if (SchemaSaid is not null)
                {
                    matchingCredentials = CredentialHelper.FilterCredentials(
                        allCredentials, [("sad.s", SchemaSaid)]);

                    if (RequestRecipientPrefix is not null)
                    {
                        matchingCredentials = CredentialHelper.FilterCredentials(
                            matchingCredentials, [("sad.a.i", RequestRecipientPrefix)]);
                    }
                }
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Error loading matching credentials");
            matchingCredentials = [];
        }
    }

    void SelectCredential(string? credSaid)
    {
        selectedCredentialSaid = credSaid;
        elisionMap = new();
    }

    void OnElisionMapChanged(Dictionary<string, bool> map)
    {
        elisionMap = map;
        // TODO P2 this log is just for debugging during development, set to Info before release
        logger.LogWarning("Elision map updated: {Map}", System.Text.Json.JsonSerializer.Serialize(elisionMap));
    }

    private async Task HandleIdOrCredChanged((string selectedPrefix, string selectedAlias, RecursiveDictionary? selectedCredentialOrNothing, WebsiteConfig? websiteConfig) value)
    {
        logger.LogInformation("HandleIdOrCredChanged: prefix={Prefix}, alias={Alias}", value.selectedPrefix, value.selectedAlias);
        SelectedPrefix = value.selectedPrefix;
        SelectedAlias = value.selectedAlias;
        SelectedCredentialOrNothing = value.selectedCredentialOrNothing;
        StateHasChanged();
        if (approveButton is not null)
        {
            await approveButton.FocusAsync();
        }
    }

    private async Task ApproveHandler()
    {
        var result = await Approve();
        if (result.IsFailed)
        {
            logger.LogError("IPEX approval failed: {error}", result.Errors.FirstOrDefault()?.Message);
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" || e.Code == "NumpadEnter")
        {
            await ApproveHandler();
        }
    }

    async Task CopyJsonToClipboard()
    {
        if (RequestPayloadForDisplay is not null)
        {
            await js.InvokeVoidAsync("navigator.clipboard.writeText", RequestPayloadForDisplay);
            snackbar.Add("Credential JSON copied to clipboard.", Severity.Success);
        }
        else
        {
            snackbar.Add("No Credential JSON to copy.", Severity.Warning);
        }
    }

}

@if (IsInitialized)
{
    <div id="@this.GetType().Name" class="bt-body-page">
        <MudStack Class="bt-main">
            <div class="bt-main-inside-scroll">
                <PageHeading Title="@($"Request to {PageTitle}")" />

                @if (ActiveTab is not null)
                {
                    <TabInteractionDisplay ActiveTab=@ActiveTab />
                }
                else
                {
                    <MudText Typo="Typo.body1" Class="mb-4">Unknown Page (tab not found)</MudText>
                }

                <MudText Class="ml-9" Typo="Typo.body2">@PageDescription</MudText>

                @if (IsPresentationApply)
                {
                    <div id="presentation-path" class="ml-9 mb-3">
                        @* // TODO P2 if we knew the verifier's (requestor's) prefix and profile name, we could show that here
                        <AidPrefixDisplay Prefix="@conn.SenderPrefix"
                                          Name="@(ProfileNameForPrefix(conn.SenderPrefix))"
                                          TextPosition="AidPrefixDisplay.TextSide.Left"
                                          ShowCopyButton="false" />
                        <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Style="margin: 0 4px; opacity: 0.5;" />
                        *@
                        @{
                            var KnownByYouAs = "(" + ProfileNameForPrefix(RequestRecipientPrefix) + ")";
                            <AidPrefixDisplay Prefix="@RequestRecipientPrefix"
                                              Name="@KnownByYouAs"
                                              ShowCopyButton="false" />
                        }

                    </div>

                    <MudExpansionPanels Dense="true" Class="ml-9 mt-0 mb-0">
                        <MudExpansionPanel Text="Request details" Dense="true">
                            <MudPaper Elevation="1" Class="pa-3" Style="overflow-x: auto;">
                                <MudText Style="white-space: pre; font-family: monospace; font-size: 0.75rem; text-wrap:auto;">
                                    @RequestPayloadForDisplay
                                </MudText>
                                <MudButton Variant="Variant.Text"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.ContentCopy"
                                           OnClick="CopyJsonToClipboard">
                                    Copy JSON
                                </MudButton>
                            </MudPaper>
                        </MudExpansionPanel>
                    </MudExpansionPanels>

                    <CredentialPresentationSelector MatchingCredentials="@matchingCredentials"
                                                       SchemaSaid="@SchemaSaid"
                                                       SelectedCredentialSaidChanged="@OnSelectedCredentialSaidChanged"
                                                       ElisionMapChanged="@OnElisionMapChanged" />
                }

                @if (!IsPresentationApply)
                {
                <WebsiteConfigDisplay OriginStr="@OriginStr" IsOriginShown="false" IsCredentialShown="false" IsAutoSignShown="false" ValueChanged="async (v) => await HandleIdOrCredChanged(v)" />

                <MudText Class="bt-section-title">Request data:</MudText>
                <MudPaper Elevation="1" Class="pa-3 mb-4" Style="max-height: 200px; overflow-y: auto; background-color: var(--mud-palette-background-grey);">
                    @if (RequestRecipientPrefix is not null)
                    {
                        <MudText Typo="Typo.body2"><strong>Recipient:</strong> <span class="bt-prefix">@RequestRecipientPrefix</span></MudText>
                    }

                    @switch (ipexKind)
                    {
                        case IpexKind.Apply:
                            <MudText Typo="Typo.body2"><strong>Schema SAID:</strong> <span class="bt-prefix">@SchemaSaid</span></MudText>
                            @if (Attributes is not null)
                            {
                                <MudText Typo="Typo.body2" Class="mt-2"><strong>Attributes:</strong></MudText>
                                <pre style="font-family: monospace; font-size: 0.875rem; word-break: break-all; white-space: pre-wrap; padding-left: 8px; margin: 0;">@(System.Text.Json.JsonSerializer.Serialize(Attributes, Helper.JsonOptions.DisplayIndented))</pre>
                            }
                            break;
                        case IpexKind.Agree:
                            <MudText Typo="Typo.body2"><strong>Offer SAID:</strong> <span class="bt-prefix">@OfferSaid</span></MudText>
                            break;
                        case IpexKind.Admit:
                            <MudText Typo="Typo.body2"><strong>Grant SAID:</strong> <span class="bt-prefix">@GrantSaid</span></MudText>
                            break;
                        default:
                            <MudAlert Severity="Severity.Warning">Unexpected IPEX kind: @ipexKind</MudAlert>
                            break;
                    }
                </MudPaper>
                }
                

            </div>
        </MudStack>

        <MudStack Row="true" class="bt-button-tray">
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="@(async (_) => await Cancel())">Reject</MudButton>
            <MudButton @ref="approveButton"
                       Disabled="IsApproveDisabled"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="ApproveHandler"
                       @onkeydown="HandleKeyDown">
                Approve
            </MudButton>
        </MudStack>
    </div>
}
