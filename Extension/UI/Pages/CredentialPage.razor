@page "/Credential.html"
@layout Layouts.MainLayout
@using Extension.Models
@using Extension.Models.Storage
@using Extension.Services
@using Extension.Services.Storage
@inherits AuthenticatedPageBase
@implements IDisposable

@using static Extension.Helper.PreviousPage

@inject NavigationManager navManager
@inject IStorageService storageService
@inject IJSRuntime js
@inject ILogger<CredentialPage> logger
@inject AppCache appCache

@code {
    [SupplyParameterFromQuery]
    public string? Said { get; set; }

    RecursiveDictionary? credential;
    bool isLoaded;
    bool showDisplaySettings;

    CredentialViewOptions PageViewOptions => new(
        DisplayType: appCache.MyPreferences.CredentialsDisplayType,
        DetailLevel: appCache.MyPreferences.CredentialsDetailLevel,
        IsJsonShown: appCache.MyPreferences.CredentialsDetailLevel >= 9
    );

    protected override async Task OnInitializedAsync()
    {
        InitializeAppCache(appCache);
        await this.SubscribeToAppCache(appCache, onChanged: async () => await LoadCredential());
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadCredential();
        isLoaded = true;
    }

    async Task LoadCredential()
    {
        try
        {
            var cached = await storageService.GetItem<CachedCredentials>(StorageArea.Session);
            if (cached.IsSuccess && cached.Value?.Credentials is not null)
            {
                var credentials = Helper.CredentialHelper.DeserializeCredentialsDict(cached.Value.Credentials);
                credential = credentials.FirstOrDefault(c =>
                    c.GetValueByPath("sad.d")?.Value?.ToString() == Said);
            }
            else
            {
                credential = null;
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Error loading credential {Said}", Said);
            credential = null;
        }
    }

    public void Dispose()
    {
        this.UnsubscribeFromAppCache();
    }
}

<div id="@this.GetType().Name" class="bt-body-page">
    <MudStack Class="bt-main">
        <div class="bt-main-inside-scroll">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <PageHeading Title="Credential" />
                <MudIconButton Icon="@Icons.Material.Filled.Settings"
                               Size="Size.Small"
                               OnClick="@(() => showDisplaySettings = !showDisplaySettings)" />
            </MudStack>

            @if (showDisplaySettings)
            {
                <CredentialViewPrefsComponent />
            }

            @if (isLoaded)
            {
                @if (credential is not null)
                {
                    <CredentialComponent Credential="@credential" ViewOptions="@PageViewOptions" Expanded="true" />
                }
                else
                {
                    <MudAlert Severity="Severity.Warning">Credential not found: @Said</MudAlert>
                }
            }
        </div>
    </MudStack>
    <MudStack Row="true" class="bt-button-tray">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBackIosNew" Variant="Variant.Text" OnClick='@(async () => await GoBack(js))' Class="justify-start" />
        <MudSpacer></MudSpacer>
    </MudStack>
</div>
