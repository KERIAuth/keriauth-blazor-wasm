@page "/Credential.html"
@layout Layouts.MainLayout
@using System.Text.Json
@using Extension.Models
@using Extension.Models.Messages.AppBw
@using Extension.Models.Storage
@using Extension.Services
@using Extension.Services.Storage
@using Extension.Services.Port
@inherits AuthenticatedPageBase
@implements IDisposable

@using static Extension.Helper.PreviousPage

@inject NavigationManager navManager
@inject IStorageGateway storageGateway
@inject IJSRuntime js
@inject ILogger<CredentialPage> logger
@inject ISnackbar snackbar
@inject AppCache appCache
@inject IAppBwPortService appBwPortService

@code {
    [SupplyParameterFromQuery]
    public string? Said { get; set; }

    [SupplyParameterFromQuery(Name = "isPresentation")]
    public bool IsPresentation { get; set; }

    [SupplyParameterFromQuery(Name = "intent")]
    public string? Intent { get; set; }

    [SupplyParameterFromQuery(Name = "applySaid")]
    public string? ApplySaid { get; set; }

    [SupplyParameterFromQuery(Name = "senderPrefix")]
    public string? SenderPrefix { get; set; }

    [SupplyParameterFromQuery(Name = "recipientPrefix")]
    public string? RecipientPrefix { get; set; }

    RecursiveDictionary? credential;
    bool isLoaded;
    bool isSubmitting;
    Dictionary<string, bool> elisionMap = new();

    bool HasIntent => Intent is "offer" or "grant";
    string IntentLabel => Intent == "offer" ? "Offer presentation" : "Grant presentation";

    CredentialViewOptions PageViewOptions => new(
        DisplayType: appCache.MyPreferences.CredentialsDisplayType,
        DetailLevel: (CredentialDetailLevel)appCache.MyPreferences.CredentialsDetailLevel,
        IsPresentation: IsPresentation,
        IsJsonShown: appCache.MyPreferences.CredentialsDetailLevel >= (int)CredentialDetailLevel.WithTechnicalDetails
    );

    protected override async Task OnInitializedAsync()
    {
        InitializeAppCache(appCache);
        await this.SubscribeToAppCache(appCache, () => { LoadCredential(); return Task.CompletedTask; });
    }

    protected override Task OnParametersSetAsync()
    {
        LoadCredential();
        isLoaded = true;
        return Task.CompletedTask;
    }

    void LoadCredential()
    {
        credential = appCache.MyCachedCredentials
            .FirstOrDefault(c => c.GetValueByPath("sad.d")?.Value?.ToString() == Said);
    }

    void OnElisionMapChanged(Dictionary<string, bool> newMap)
    {
        elisionMap = newMap;
    }

    async Task SubmitPresentation()
    {
        if (isSubmitting || !HasIntent || Said is null || ApplySaid is null
            || SenderPrefix is null || RecipientPrefix is null) return;

        isSubmitting = true;
        var isOffer = Intent == "offer";
        var actionLabel = isOffer ? "Offer" : "Grant";

        try {
            var response = await appBwPortService.SendRpcRequestAsync(
                AppBwMessageType.Values.RequestIpexGrantPresentation,
                new { payload = new IpexGrantPresentationRequestPayload(
                    SenderNameOrPrefix: SenderPrefix,
                    RecipientPrefix: RecipientPrefix,
                    ApplySaid: ApplySaid,
                    CredentialSaid: Said,
                    ElisionMap: elisionMap,
                    IsOffer: isOffer) },
                timeout: TimeSpan.FromMinutes(3));

            if (!response.Ok) {
                snackbar.Add($"{actionLabel} presentation failed: {response.Error}", Severity.Error);
                return;
            }

            var grantResult = response.Result is JsonElement grantJsonEl
                ? JsonSerializer.Deserialize<IpexGrantResponsePayload>(grantJsonEl.GetRawText(), Helper.JsonOptions.PortMessaging)
                : null;

            if (grantResult is not null && grantResult.Success) {
                snackbar.Add($"Credential presentation {(isOffer ? "offered" : "granted")}", Severity.Success);
                await GoBack(js);
            } else {
                snackbar.Add($"{actionLabel} presentation failed: {grantResult?.Error ?? "Unknown error"}", Severity.Error);
            }
        }
        catch (Exception ex) {
            logger.LogError(ex, "Error during IPEX {Action} presentation", actionLabel);
            snackbar.Add($"Error {(isOffer ? "offering" : "granting")} credential presentation", Severity.Error);
        }
        finally {
            isSubmitting = false;
        }
    }

    public void Dispose()
    {
        this.UnsubscribeFromAppCache();
    }
}

<div id="@this.GetType().Name" class="bt-body-page">
    <MudStack Class="bt-main">
        <div class="bt-main-inside-scroll">
            <PageHeading Title="Credential" />
            <CredentialViewPrefsComponent />

            @if (isLoaded)
            {
                @if (credential is not null)
                {
                    <CredentialComponent Credential="@credential"
                                         ViewOptions="@PageViewOptions"
                                         IsExpandable="false"
                                         ElisionMapChanged="@OnElisionMapChanged" />
                }
                else
                {
                    <MudAlert Severity="Severity.Warning">Credential not found: @Said</MudAlert>
                }
            }
        </div>
    </MudStack>
    <MudStack Row="true" class="bt-button-tray">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBackIosNew" Variant="Variant.Text" OnClick='@(async () => await GoBack(js))' Class="justify-start" />
        <MudSpacer></MudSpacer>
        @if (HasIntent && credential is not null)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="SubmitPresentation"
                       Disabled="@isSubmitting">
                @if (isSubmitting)
                {
                    <MudProgressCircular Color="Color.Default" Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <text>Submitting...</text>
                }
                else
                {
                    @IntentLabel
                }
            </MudButton>
        }
    </MudStack>
</div>
