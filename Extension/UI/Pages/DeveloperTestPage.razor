    // Schema verification state
    private List<SchemaVerifyResult> _schemaVerifyResults = [];
    private bool _schemaVerifyRunning;

    async Task RunSchemaVerificationAsync()
    {
        _schemaVerifyRunning = true;
        _schemaVerifyResults = [];
        StateHasChanged();
        try
        {
            var response = await appBwPortService.SendRpcRequestAsync(
                AppBwMessageType.Values.RequestVerifySchemas,
                new { },
                TimeSpan.FromSeconds(120));

            if (response.Ok && response.Result is System.Text.Json.JsonElement resultElement)
            {
                var parsed = System.Text.Json.JsonSerializer.Deserialize<VerifySchemasResponse>(
                    resultElement.GetRawText());
                if (parsed?.Results is not null)
                {
                    _schemaVerifyResults = parsed.Results;
                    var matches = _schemaVerifyResults.Count(r => r.Match);
                    var mismatches = _schemaVerifyResults.Count(r => !r.Match && r.Error is null);
                    var errors = _schemaVerifyResults.Count(r => r.Error is not null);
                    var severity = (mismatches > 0 || errors > 0)
                        ? MudBlazor.Severity.Warning
                        : MudBlazor.Severity.Normal;
                    snackbar.Add($"Schemas: {matches} MATCH, {mismatches} MISMATCH, {errors} ERROR", severity);
                }
                else
                {
                    snackbar.Add($"Schema verification failed: {parsed?.Error ?? "unknown"}", MudBlazor.Severity.Error);
                }
            }
            else
            {
                snackbar.Add($"Schema verification failed: {response.Error ?? "RPC error"}", MudBlazor.Severity.Error);
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, nameof(RunSchemaVerificationAsync) + " failed");
            snackbar.Add($"Schema verification error: {ex.Message}", MudBlazor.Severity.Error);
        }
        finally
        {
            _schemaVerifyRunning = false;
            StateHasChanged();
        }
    }

    // Saider verification state
    private record SaidifyRow(string Path, int Depth, string? StoredSaid, string? ComputedSaid, string Status);
    private record EdgeRefRow(string EdgePath, string ReferencedSaid, string Status);
    private record ChainUsageRow(string ChainPath, string ChainSaid, string Status);

    private string? _selectedCredentialSaid;
    private List<SaidifyRow> _saidifyResults = [];
    private List<EdgeRefRow> _edgeRefResults = [];
    private List<ChainUsageRow> _chainUsageResults = [];
    private bool _saidifyRunning;

    static string BuildPath(string prefix, string segment) =>
        string.IsNullOrEmpty(prefix) ? segment : $"{prefix}.{segment}";

    void OnSaidifyCredentialSelected(string? said)
    {
        _selectedCredentialSaid = said;
        _saidifyResults = [];
        _edgeRefResults = [];
        _chainUsageResults = [];
    }

    async Task RunSaidifyVerificationAsync()
    {
        if (string.IsNullOrEmpty(_selectedCredentialSaid)) return;
        _saidifyRunning = true;
        _saidifyResults = [];
        _edgeRefResults = [];
        _chainUsageResults = [];
        try
        {
            var cred = appCache.MyCachedCredentials.FirstOrDefault(
                c => c.QueryPath("sad.d")?.StringValue == _selectedCredentialSaid);
            if (cred is null)
            {
                snackbar.Add("Credential not found in cache", MudBlazor.Severity.Error);
                return;
            }

            // chainIndex: path -> sad.d of every credential in the tree (root + all chains, recursively)
            var chainIndex = new List<(string Path, string Said)>();
            // edgeRefs: every descendant 'n' field across the whole tree
            var edgeRefs = new List<(string EdgePath, string RefSaid)>();

            await WalkCredentialAsync(cred, pathPrefix: "", depth: 0, chainIndex, edgeRefs);

            // Resolve edge references — each 'n' value should match some credential's sad.d
            foreach (var (edgePath, refSaid) in edgeRefs)
            {
                var match = chainIndex.FirstOrDefault(c => c.Said == refSaid);
                var status = match.Said is not null ? $"MATCHED → {match.Path}" : "UNMATCHED";
                _edgeRefResults.Add(new EdgeRefRow(edgePath, refSaid, status));
            }

            // Back-check — every non-root chained credential should appear in some edge's 'n'
            var referencedSaids = edgeRefs.Select(e => e.RefSaid).ToHashSet();
            foreach (var (path, said) in chainIndex)
            {
                if (path == "(root)") continue;
                if (string.IsNullOrEmpty(said)) continue;
                var status = referencedSaids.Contains(said) ? "USED" : "ORPHAN";
                _chainUsageResults.Add(new ChainUsageRow(path, said, status));
            }

            var passes = _saidifyResults.Count(r => r.Status == "PASS");
            var fails = _saidifyResults.Count(r => r.Status == "FAIL");
            var nas = _saidifyResults.Count - passes - fails;
            var unmatched = _edgeRefResults.Count(r => r.Status == "UNMATCHED");
            var orphans = _chainUsageResults.Count(r => r.Status == "ORPHAN");
            var severity = (fails > 0 || unmatched > 0 || orphans > 0)
                ? MudBlazor.Severity.Warning
                : MudBlazor.Severity.Normal;
            snackbar.Add(
                $"Saidify: {passes} PASS, {fails} FAIL, {nas} N/A — refs: {unmatched} UNMATCHED, chains: {orphans} ORPHAN",
                severity);
        }
        catch (Exception ex)
        {
            logger.LogError(ex, nameof(RunSaidifyVerificationAsync) + " failed");
            snackbar.Add($"Saidify error: {ex.Message}", MudBlazor.Severity.Error);
        }
        finally
        {
            _saidifyRunning = false;
        }
    }

    async Task WalkCredentialAsync(
        RecursiveDictionary credential,
        string pathPrefix,
        int depth,
        List<(string Path, string Said)> chainIndex,
        List<(string EdgePath, string RefSaid)> edgeRefs)
    {
        var sad = credential.QueryPath("sad")?.Dictionary;
        if (sad is null) return;

        var credSaid = sad.QueryPath("d")?.StringValue ?? "";
        chainIndex.Add((string.IsNullOrEmpty(pathPrefix) ? "(root)" : pathPrefix, credSaid));

        foreach (var kv in sad)
        {
            var sectionKey = kv.Key;
            var sectionDict = kv.Value.Dictionary;
            if (sectionDict is null) continue;
            if (!sectionDict.ContainsKey("d")) continue;

            await SaidifySectionAsync(sectionDict, BuildPath(pathPrefix, sectionKey), depth);
        }

        var edgeDict = sad.QueryPath("e")?.Dictionary;
        if (edgeDict is not null)
        {
            CollectNReferences(edgeDict, BuildPath(pathPrefix, "sad.e"), edgeRefs);
        }

        var chains = credential.QueryPath("chains")?.List;
        if (chains is null) return;
        for (var i = 0; i < chains.Count; i++)
        {
            var chainDict = chains[i].Dictionary;
            if (chainDict is null) continue;
            var childPath = BuildPath(pathPrefix, $"chains[{i}]");
            await WalkCredentialAsync(chainDict, childPath, depth + 1, chainIndex, edgeRefs);
        }
    }

    async Task SaidifySectionAsync(RecursiveDictionary sectionDict, string pathKey, int depth)
    {
        var storedSaid = sectionDict.QueryPath("d")?.StringValue ?? "";
        var clone = new RecursiveDictionary();
        foreach (var entry in sectionDict)
        {
            clone[entry.Key] = entry.Key == "d"
                ? new RecursiveValue { StringValue = "" }
                : entry.Value;
        }

        var rpc = await appBwPortService.SendRequestAsync<RequestSaidifyPayload, SaidifyResponse>(
            new AppBwRequestSaidifyMessage(clone));

        string? computed;
        string status;
        if (rpc.IsFailed || rpc.Value is null)
        {
            computed = null;
            var msg = rpc.IsFailed
                ? (rpc.Errors.Count > 0 ? rpc.Errors[0].Message : "RPC failed")
                : "Null response";
            status = $"ERROR: {msg}";
        }
        else if (!rpc.Value.Success)
        {
            computed = null;
            status = $"ERROR: {rpc.Value.Error ?? "unknown"}";
        }
        else
        {
            computed = rpc.Value.Said;
            status = string.IsNullOrEmpty(storedSaid)
                ? "N/A"
                : (computed == storedSaid ? "PASS" : "FAIL");
        }

        _saidifyResults.Add(new SaidifyRow(pathKey, depth, storedSaid, computed, status));
    }

    // Walks a dict tree collecting every descendant string-valued 'n' field as an edge reference.
    // Per ACDC spec, the 'n' field of an edge node holds the SAID of the referenced credential.
    static void CollectNReferences(
        RecursiveDictionary dict,
        string pathPrefix,
        List<(string EdgePath, string RefSaid)> refs)
    {
        foreach (var kv in dict)
        {
            var childPath = $"{pathPrefix}.{kv.Key}";
            if (kv.Key == "n" && kv.Value.StringValue is { Length: > 0 } nVal)
            {
                refs.Add((childPath, nVal));
            }
            if (kv.Value.Dictionary is { } nestedDict)
            {
                CollectNReferences(nestedDict, childPath, refs);
            }
        }
    }
}

