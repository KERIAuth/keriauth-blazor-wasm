                                     Dense="true" />
                    }
                </MudStack>
                <MudStack Row="true" Class="ml-4" Spacing="2">
                    <MudLink OnClick="@ShowMigrationNoticeBanner" Disabled="@(_selectedMigrationTypes.Count == 0)">Show migration notice banner</MudLink>
