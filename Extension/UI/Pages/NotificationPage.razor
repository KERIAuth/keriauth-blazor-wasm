@page "/Notification.html"
@layout Layouts.MainLayout
@using System.Text.Json
@using Extension.Models
@using Extension.Models.Messages.AppBw
@using Extension.Services
@using Extension.Services.SignifyService.Models
@using Extension.Services.Storage
@using Extension.Services.Port
@using Extension.UI.Components
@using Extension.Helper
@inherits AuthenticatedPageBase
@implements IDisposable

@using static Extension.Helper.PreviousPage

@inject ILogger<NotificationPage> logger
@inject NavigationManager navManager
@inject IJSRuntime js
@inject ISnackbar snackbar
@inject AppCache appCache
@inject IAppBwPortService appBwPortService
@inject IDialogService dialogService

@code {
    [SupplyParameterFromQuery]
    public string? Id { get; set; }

    Notification? notification;
    bool isLoaded;

    // Exchange state
    ExchangeView? exchangeData;
    bool isLoadingExchange;
    string? exchangeLoadError;

    // Agree→Grant inline flow: credential from prior offer
    RecursiveDictionary? priorOfferCredential;
    bool isFetchingPriorOffer;
    bool isGrantSubmitted;

    // Apply action completion state
    string? completedActionLabel;
    string? completedCredentialSaid;
    RecursiveDictionary? completedCredential;

    // IPEX action state
    bool IsAdmitting { get; set; }
    bool IsAlreadyAdmitted { get; set; }
    bool IsAgreeing { get; set; }
    bool IsAlreadyAgreed { get; set; }
    bool IsOffering { get; set; }
    bool IsAlreadyOffered { get; set; }
    bool IsGranting { get; set; }
    bool IsAlreadyGranted { get; set; }
    bool IsGrantingPresentation { get; set; }
    bool IsOfferingPresentation { get; set; }
    bool IsProcessing { get; set; }

    // View options for embedded credential display
    CredentialViewOptions CredentialViewOpts => new(
        DisplayType: appCache.MyPreferences.CredentialsDisplayType,
        DetailLevel: (CredentialDetailLevel)appCache.MyPreferences.CredentialsDetailLevel,
        IsJsonShown: appCache.MyPreferences.CredentialsDetailLevel >= (int)CredentialDetailLevel.WithTechnicalDetails
    );

    protected override async Task OnInitializedAsync() {
        InitializeAppCache(appCache);
        await this.SubscribeToAppCache(appCache, () => { LoadNotification(); return Task.CompletedTask; });
    }

    protected override async Task OnParametersSetAsync() {
        LoadNotification();
        isLoaded = true;
        if (notification is not null && exchangeData is null && !isLoadingExchange) {
            await LoadExchange();
        }
        // Auto-mark as read on entry. Fire-and-forget without setting IsProcessing,
        // which would disable the Delete button until mark-as-read completes.
        // Safe: SendEventAsync is non-blocking and exceptions are caught inline.
        if (notification is not null && !notification.IsRead) {
            _ = AutoMarkAsReadAsync();
        }
    }

    async Task AutoMarkAsReadAsync() {
        try {
            await appBwPortService.SendEventAsync(
                AppBwMessageType.Values.RequestMarkNotification,
                new { said = notification!.Id });
        } catch (Exception ex) {
            logger.LogWarning(ex, "Auto-mark-as-read failed");
        }
    }

    void LoadNotification() {
        notification = appCache.MyNotifications.Items.FirstOrDefault(n => n.Id == Id);
    }

    async Task LoadExchange() {
        if (notification?.ExchangeSaid is null) {
            exchangeLoadError = "No exchange SAID available";
            return;
        }

        isLoadingExchange = true;
        exchangeLoadError = null;

        try {
            RecursiveDictionary? exchange = null;
            if (appCache.MyCachedExns.TryGetValue(notification.ExchangeSaid, out var cachedRawJson)) {
                exchange = JsonSerializer.Deserialize<RecursiveDictionary>(cachedRawJson, JsonOptions.RecursiveDictionary);
            }

            if (exchange is null) {
                var response = await appBwPortService.SendRpcRequestAsync(
                    AppBwMessageType.Values.RequestGetExchange,
                    new { payload = new { said = notification.ExchangeSaid } },
                    timeout: TimeSpan.FromMinutes(3));

                if (!response.Ok) {
                    exchangeLoadError = response.Error ?? "Failed to load exchange details";
                    return;
                }

                var exchangeResult = response.Result is JsonElement jsonEl
                    ? JsonSerializer.Deserialize<GetExchangeResponsePayload>(jsonEl.GetRawText(), JsonOptions.PortMessaging)
                    : null;

                if (exchangeResult is not null && exchangeResult.Success && exchangeResult.Exchange is not null) {
                    exchange = exchangeResult.Exchange;
                } else {
                    exchangeLoadError = exchangeResult?.Error ?? "Unknown error loading exchange";
                    return;
                }
            }

            if (exchange is not null) {
                exchangeData = ExchangeView.FromRecursiveDictionary(exchange);

                if (notification.Route == "/exn/ipex/grant") {
                    var credSaid = exchangeData.Value.E?.GetValueByPath("acdc.d")?.Value?.ToString();
                    if (credSaid is not null) {
                        IsAlreadyAdmitted = appCache.MyCachedCredentials.Any(c =>
                            c.GetValueByPath("sad.d")?.Value?.ToString() == credSaid);
                    }
                }

                // For agree notifications, fetch the credential from the prior offer
                if (notification.Route == "/exn/ipex/agree") {
                    // Fire-and-forget: fetches in background, updates priorOfferCredential, triggers re-render.
                    // Safe: FetchPriorOfferCredential has internal try/catch and logs on failure.
                    _ = FetchPriorOfferCredential();
                }
            }
        }
        catch (Exception ex) {
            logger.LogError(ex, "Error fetching exchange details");
            exchangeLoadError = "Error loading exchange details";
        }
        finally {
            isLoadingExchange = false;
        }
    }

    async Task FetchPriorOfferCredential() {
        if (exchangeData is null) return;
        var priorOfferSaid = exchangeData.Value.P;
        if (string.IsNullOrEmpty(priorOfferSaid)) return;

        isFetchingPriorOffer = true;
        StateHasChanged();

        try {
            RecursiveDictionary? offerExchange = null;
            if (appCache.MyCachedExns.TryGetValue(priorOfferSaid, out var cachedRaw)) {
                offerExchange = JsonSerializer.Deserialize<RecursiveDictionary>(cachedRaw, JsonOptions.RecursiveDictionary);
            }

            if (offerExchange is null) {
                var response = await appBwPortService.SendRpcRequestAsync(
                    AppBwMessageType.Values.RequestGetExchange,
                    new { payload = new { said = priorOfferSaid } },
                    timeout: TimeSpan.FromMinutes(3));

                if (response.Ok) {
                    var result = response.Result is JsonElement el
                        ? JsonSerializer.Deserialize<GetExchangeResponsePayload>(el.GetRawText(), JsonOptions.PortMessaging)
                        : null;
                    if (result is not null && result.Success && result.Exchange is not null) {
                        offerExchange = result.Exchange;
                    }
                }
            }

            if (offerExchange is not null) {
                var offerView = ExchangeView.FromRecursiveDictionary(offerExchange);
                var acdc = offerView.E?.GetByPath("acdc")?.Dictionary;
                if (acdc is not null) {
                    priorOfferCredential = new RecursiveDictionary { ["sad"] = acdc };
                }
            }
        }
        catch (Exception ex) {
            logger.LogWarning(ex, "Error fetching prior offer credential");
        }
        finally {
            isFetchingPriorOffer = false;
            StateHasChanged();
        }
    }

    // --- IPEX Action Handlers ---

    async Task AdmitCredential() {
        if (IsAdmitting || exchangeData is null || notification is null) return;

        var view = exchangeData.Value;
        var issuerPrefix = view.I;
        var recipientPrefix = view.Rp;

        if (recipientPrefix is null || !appCache.Aids.Any(a => a.Prefix == recipientPrefix)) {
            snackbar.Add("Could not find matching AID for this grant", Severity.Error);
            return;
        }
        if (notification.ExchangeSaid is null || issuerPrefix is null) {
            snackbar.Add("Missing exchange data for admit", Severity.Error);
            return;
        }

        IsAdmitting = true;
        try {
            var response = await appBwPortService.SendRpcRequestAsync(
                AppBwMessageType.Values.RequestIpexAdmit,
                new { payload = new IpexAdmitRequestPayload(
                    SenderNameOrPrefix: recipientPrefix,
                    RecipientPrefix: issuerPrefix,
                    GrantSaid: notification.ExchangeSaid) },
                timeout: TimeSpan.FromMinutes(2));

            if (!response.Ok) {
                snackbar.Add($"Admit failed: {response.Error}", Severity.Error);
                return;
            }

            var admitResult = response.Result is JsonElement admitJsonEl
                ? JsonSerializer.Deserialize<IpexAdmitResponsePayload>(admitJsonEl.GetRawText(), JsonOptions.PortMessaging)
                : null;

            if (admitResult is not null && admitResult.Success) {
                IsAlreadyAdmitted = true;
                snackbar.Add("Credential admitted", Severity.Success);
                if (!notification.IsRead) await MarkAsRead();
            } else {
                snackbar.Add($"Admit failed: {admitResult?.Error ?? "Unknown error"}", Severity.Error);
            }
        }
        catch (Exception ex) {
            logger.LogError(ex, "Error during IPEX admit");
            snackbar.Add("Error admitting credential", Severity.Error);
        }
        finally { IsAdmitting = false; }
    }

    async Task AgreeToOffer() {
        if (IsAgreeing || exchangeData is null || notification is null) return;

        var view = exchangeData.Value;
        var userPrefix = view.Rp;
        var offerSenderPrefix = view.I;

        if (userPrefix is null || !appCache.Aids.Any(a => a.Prefix == userPrefix)) {
            snackbar.Add("Could not find matching AID for this offer", Severity.Error);
            return;
        }
        if (notification.ExchangeSaid is null || offerSenderPrefix is null) {
            snackbar.Add("Missing exchange data for agree", Severity.Error);
            return;
        }

        IsAgreeing = true;
        try {
            var response = await appBwPortService.SendRpcRequestAsync(
                AppBwMessageType.Values.RequestIpexAgree,
                new { payload = new IpexAgreeRequestPayload(
                    SenderNameOrPrefix: userPrefix,
                    RecipientPrefix: offerSenderPrefix,
                    OfferSaid: notification.ExchangeSaid) },
                timeout: TimeSpan.FromMinutes(2));

            if (!response.Ok) {
                snackbar.Add($"Agree failed: {response.Error}", Severity.Error);
                return;
            }

            var agreeResult = response.Result is JsonElement agreeJsonEl
                ? JsonSerializer.Deserialize<IpexAgreeResponsePayload>(agreeJsonEl.GetRawText(), JsonOptions.PortMessaging)
                : null;

            if (agreeResult is not null && agreeResult.Success) {
                IsAlreadyAgreed = true;
                snackbar.Add("Agreed to offer", Severity.Success);
                if (!notification.IsRead) await MarkAsRead();
            } else {
                snackbar.Add($"Agree failed: {agreeResult?.Error ?? "Unknown error"}", Severity.Error);
            }
        }
        catch (Exception ex) {
            logger.LogError(ex, "Error during IPEX agree");
            snackbar.Add("Error agreeing to offer", Severity.Error);
        }
        finally { IsAgreeing = false; }
    }

    async Task OfferCredential() {
        if (IsOffering || exchangeData is null || notification is null) return;

        var view = exchangeData.Value;
        if (view.Rp is null || view.I is null) {
            snackbar.Add("Missing data from Apply exchange", Severity.Error);
            return;
        }
        if (!appCache.Aids.Any(a => a.Prefix == view.Rp)) {
            snackbar.Add("Could not find matching AID for this apply", Severity.Error);
            return;
        }

        IsOffering = true;
        try {
            var parameters = new DialogParameters<OfferOrGrantCredentialIssuanceDialog> {
                { x => x.ApplyExchange, view },
                { x => x.IsOffer, true }
            };
            var options = new DialogOptions {
                CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true,
                BackdropClick = false, CloseButton = true, Position = DialogPosition.Center
            };
            var dialog = await dialogService.ShowAsync<OfferOrGrantCredentialIssuanceDialog>("Offer credential", parameters, options);
            var dialogResult = await dialog.Result;

            if (dialogResult is null || dialogResult.Canceled) return;

            var result = dialogResult.Data as OfferOrGrantCredentialIssuanceDialog.IssuanceDialogResult;
            if (result is not null && result.Submitted) {
                IsAlreadyOffered = true;
                SetCompletedAction("Offered Credential", result.CredentialSaid);
                snackbar.Add("Credential offered", Severity.Success);
                if (!notification.IsRead) await MarkAsRead();
            }
        }
        catch (Exception ex) {
            logger.LogError(ex, "Error during IPEX offer dialog");
            snackbar.Add("Error offering credential", Severity.Error);
        }
        finally { IsOffering = false; }
    }

    async Task GrantCredentialFromApply() {
        if (IsGranting || exchangeData is null || notification is null) return;

        var view = exchangeData.Value;
        if (view.Rp is null || view.I is null) {
            snackbar.Add("Missing data from Apply exchange", Severity.Error);
            return;
        }
        if (!appCache.Aids.Any(a => a.Prefix == view.Rp)) {
            snackbar.Add("Could not find matching AID for this apply", Severity.Error);
            return;
        }

        IsGranting = true;
        try {
            var parameters = new DialogParameters<OfferOrGrantCredentialIssuanceDialog> {
                { x => x.ApplyExchange, view },
                { x => x.IsOffer, false }
            };
            var options = new DialogOptions {
                CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true,
                BackdropClick = false, CloseButton = true, Position = DialogPosition.Center
            };
            var dialog = await dialogService.ShowAsync<OfferOrGrantCredentialIssuanceDialog>("Grant credential", parameters, options);
            var dialogResult = await dialog.Result;

            if (dialogResult is null || dialogResult.Canceled) return;

            var result = dialogResult.Data as OfferOrGrantCredentialIssuanceDialog.IssuanceDialogResult;
            if (result is not null && result.Submitted) {
                IsAlreadyGranted = true;
                SetCompletedAction("Granted Credential", result.CredentialSaid);
                snackbar.Add("Credential granted", Severity.Success);
                if (!notification.IsRead) await MarkAsRead();
            }
        }
        catch (Exception ex) {
            logger.LogError(ex, "Error during IPEX grant-from-apply dialog");
            snackbar.Add("Error granting credential", Severity.Error);
        }
        finally { IsGranting = false; }
    }

    async Task SubmitGrantFromAgree() {
        if (IsGranting || exchangeData is null || notification is null) return;

        var view = exchangeData.Value;
        if (view.Rp is null || !appCache.Aids.Any(a => a.Prefix == view.Rp)) {
            snackbar.Add("Could not find matching AID for this agree", Severity.Error);
            return;
        }
        if (view.I is null || view.D is null) {
            snackbar.Add("Missing exchange data for grant", Severity.Error);
            return;
        }

        IsGranting = true;
        try {
            var response = await appBwPortService.SendRpcRequestAsync(
                AppBwMessageType.Values.RequestSubmitIpexGrant,
                new { payload = new SubmitIpexGrantRequestPayload(
                    SenderNameOrPrefix: view.Rp,
                    RecipientPrefix: view.I,
                    AgreeSaid: view.D) },
                timeout: TimeSpan.FromMinutes(3));

            if (!response.Ok) {
                snackbar.Add($"Grant failed: {response.Error}", Severity.Error);
                return;
            }

            var grantResult = response.Result is JsonElement grantJsonEl
                ? JsonSerializer.Deserialize<SubmitIpexGrantResponsePayload>(grantJsonEl.GetRawText(), JsonOptions.PortMessaging)
                : null;

            if (grantResult is not null && grantResult.Success) {
                isGrantSubmitted = true;
                IsAlreadyGranted = true;
                snackbar.Add("Credential granted", Severity.Success);
                if (!notification.IsRead) await MarkAsRead();
            } else {
                snackbar.Add($"Grant failed: {grantResult?.Error ?? "Unknown error"}", Severity.Error);
            }
        }
        catch (Exception ex) {
            logger.LogError(ex, "Error during IPEX grant from agree");
            snackbar.Add("Error granting credential", Severity.Error);
        }
        finally { IsGranting = false; }
    }

    // TODO P2: Presentation flow should stay on this NotificationPage instead of navigating to
    // CredentialPage. Render the matching credential inline with isPresentation=true, elision
    // checkboxes, and a Submit button — same UX as CredentialPage's intent flow but without
    // leaving the notification context. After a presentation is offered or granted, show the
    // result inline (like the credential issuance post-action display): heading "Offered
    // Presentation" or "Granted Presentation", then the credential component showing what
    // was disclosed.
    void NavigateToPresentation(bool isOffer) {
        if (exchangeData is null || notification is null) return;

        var view = exchangeData.Value;
        var schemaSaid = view.A?.GetValueByPath("s")?.Value?.ToString();
        var holderPrefix = view.Rp;
        var verifierPrefix = view.I;
        var applySaid = notification.ExchangeSaid;

        if (schemaSaid is null || holderPrefix is null || verifierPrefix is null || applySaid is null) {
            snackbar.Add("Missing data from Apply exchange", Severity.Error);
            return;
        }

        var matching = CredentialHelper.FilterCredentials(
            appCache.MyCachedCredentials.ToList(), [("sad.s", schemaSaid), ("sad.a.i", holderPrefix)]);

        if (matching.Count == 0) {
            snackbar.Add("No matching credentials found for this presentation request", Severity.Warning);
            return;
        }

        var credSaid = matching[0].GetValueByPath("sad.d")?.Value?.ToString();
        if (credSaid is null) return;

        var intent = isOffer ? "offer" : "grant";
        navManager.NavigateTo(
            $"{Routes.Paths.Credential}?said={credSaid}&isPresentation=true&intent={intent}&applySaid={applySaid}&senderPrefix={holderPrefix}&recipientPrefix={verifierPrefix}");
    }

    async Task MarkAsRead() {
        if (notification is null || IsProcessing) return;
        IsProcessing = true;
        try {
            await appBwPortService.SendEventAsync(
                AppBwMessageType.Values.RequestMarkNotification,
                new { said = notification.Id });
            await appCache.WaitForAppCache([
                () => appCache.MyNotifications.Items.Any(n => n.Id == notification.Id && n.IsRead)
            ]);
        }
        catch (Exception ex) {
            logger.LogWarning(ex, "Error marking notification as read");
        }
        finally { IsProcessing = false; }
    }

    bool _isDeleting;

    async Task DeleteNotification() {
        if (notification is null || _isDeleting) return;
        _isDeleting = true;
        var notifId = notification.Id;
        try {
            await appBwPortService.SendEventAsync(
                AppBwMessageType.Values.RequestDeleteNotification,
                new { said = notifId });
            snackbar.Add("Notification deleted", Severity.Info);
            // Navigate back immediately — don't wait for AppCache update, which would
            // trigger LoadNotification() and show "Notification not found" before GoBack.
            navManager.NavigateTo(Routes.Paths.Notifications);
        }
        catch (Exception ex) {
            logger.LogError(ex, "Error deleting notification");
            snackbar.Add("Error deleting notification", Severity.Error);
            _isDeleting = false;
        }
    }

    void SetCompletedAction(string label, string? credentialSaid) {
        completedActionLabel = label;
        completedCredentialSaid = credentialSaid;
        completedCredential = credentialSaid is not null
            ? appCache.MyCachedCredentials.FirstOrDefault(c =>
                c.GetValueByPath("sad.d")?.Value?.ToString() == credentialSaid)
            : null;
    }

    // Pretty-printed JSON for apply attributes
    string? ApplyAttributesJson => exchangeData?.A is not null
        ? JsonSerializer.Serialize(exchangeData.Value.A.ToObjectDictionary(), JsonOptions.Display)
        : null;

    public void Dispose() {
        this.UnsubscribeFromAppCache();
    }
}

<div id="@this.GetType().Name" class="bt-body-page">
    <MudStack Class="bt-main">
        <div class="bt-main-inside-scroll">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-wrap">
                <PageHeading Title="Notification" />
                @if (notification?.ExchangeSaid is not null)
                {
                    var prefixes = appCache.GetExchangePrefixes(notification.ExchangeSaid);
                    <div class="d-flex align-center" style="gap: 0.25rem;">
                        <AidPrefixDisplay Prefix="@(prefixes.Sender ?? "")"
                                          TextPosition="AidPrefixDisplay.TextSide.Left"
                                          ShowCopyButton="false" />
                        <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Style="opacity: 0.5;" />
                        <AidPrefixDisplay Prefix="@(prefixes.Target ?? "")"
                                          ShowCopyButton="false" />
                    </div>
                }
            </MudStack>

            @if (isLoaded)
            {
                @if (notification is null)
                {
                    <MudAlert Severity="Severity.Warning">Notification not found: @Id</MudAlert>
                }
                else
                {
                    <MudStack Spacing="2">
                        <LoadingDiv IsLoading="@isLoadingExchange">
                            @if (exchangeLoadError is not null)
                            {
                                <MudAlert Severity="Severity.Warning" Dense="true">@exchangeLoadError</MudAlert>
                            }
                            else if (exchangeData is not null)
                            {
                                @* Exchange header — shared across all routes *@
                                <NotificationExchangeDetail Exchange="@exchangeData.Value"
                                                            Route="@notification.Route"
                                                            ShowActions="false"
                                                            CredentialExpandable="false"
                                                            IsAdmitting="@IsAdmitting"
                                                            IsAlreadyAdmitted="@IsAlreadyAdmitted"
                                                            IsAgreeing="@IsAgreeing"
                                                            IsAlreadyAgreed="@IsAlreadyAgreed"
                                                            IsOffering="@IsOffering"
                                                            IsAlreadyOffered="@IsAlreadyOffered"
                                                            IsGranting="@IsGranting"
                                                            IsAlreadyGranted="@IsAlreadyGranted"
                                                            IsGrantingPresentation="@IsGrantingPresentation"
                                                            IsOfferingPresentation="@IsOfferingPresentation" />

                                @* Route-specific content below the shared header *@
                                @* TODO P2: On re-navigation to a completed apply notification, detect that an
                                   offer or grant was already submitted for this exchange SAID. This requires
                                   scanning MyCachedExns for a child exchange whose P (prior) field matches
                                   this notification's exchange SAID, then determining the action type (offer vs
                                   grant, issuance vs presentation) from the child's route. Once detected, set
                                   completedActionLabel and completedCredentialSaid so the post-action UI shows
                                   on page load, not just during the same session. *@
                                @switch (notification.Route)
                                {
                                    case "/exn/ipex/apply":
                                        @* Apply: show attributes as pretty-printed JSON *@
                                        @if (completedActionLabel is not null)
                                        {
                                            <MudText Class="bt-exchange-type">Application</MudText>
                                        }
                                        else
                                        {
                                            <MudText Typo="Typo.subtitle2" Class="bt-credview-text-schema">Step 1: Review the application</MudText>
                                        }
                                        @if (ApplyAttributesJson is not null)
                                        {
                                            <MudPaper Class="pa-3" Style="overflow-x: auto;">
                                                <MudText Style="white-space: pre; font-family: monospace; font-size: 0.75rem;">
                                                    @ApplyAttributesJson
                                                </MudText>
                                            </MudPaper>
                                        }
                                        @if (completedActionLabel is not null)
                                        {
                                            <MudText Class="bt-exchange-type">@completedActionLabel</MudText>
                                            @if (completedCredential is not null)
                                            {
                                                <CredentialViewPrefsComponent />
                                                <CredentialComponent Credential="@completedCredential"
                                                                     ViewOptions="@CredentialViewOpts"
                                                                     IsExpandable="false" />
                                            }
                                        }
                                        else if (!IsAlreadyOffered && !IsAlreadyGranted)
                                        {
                                            <MudText Typo="Typo.subtitle2" Class="bt-credview-text-schema">Step 2: Choose an action</MudText>
                                        }
                                        break;

                                    case "/exn/ipex/agree":
                                        @* Agree→Grant: inline full-page flow *@
                                        <MudText Typo="Typo.body2">The holder has agreed to receive the credential offered previously.</MudText>
                                        @if (isFetchingPriorOffer)
                                        {
                                            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                                        }
                                        else if (priorOfferCredential is not null)
                                        {
                                            <MudText Typo="Typo.subtitle2" Class="bt-credview-text-schema">Review the credential to be granted</MudText>
                                            <CredentialViewPrefsComponent />
                                            <CredentialComponent Credential="@priorOfferCredential"
                                                                 ViewOptions="@CredentialViewOpts"
                                                                 IsExpandable="false" />
                                        }
                                        break;
                                }
                            }
                        </LoadingDiv>
                    </MudStack>
                }
            }
        </div>
    </MudStack>
    <MudStack Row="true" class="bt-button-tray">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBackIosNew" Variant="Variant.Text" OnClick='@(async () => await GoBack(js))' Class="justify-start" />
        @if (notification is not null)
        {
            <MudButton Variant="Variant.Outlined" OnClick="DeleteNotification"
                       Disabled="@_isDeleting">Delete notification</MudButton>
        }
        <MudSpacer></MudSpacer>
        @if (notification is not null && exchangeData is not null)
        {
            @switch (notification.Route)
            {
                case "/exn/ipex/apply":
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OfferCredential"
                               Disabled="@(IsOffering || IsGranting || IsAlreadyOffered || IsAlreadyGranted)">
                        @(IsOffering ? "Offering..." : "Offer credential...")
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => NavigateToPresentation(isOffer: true))"
                               Disabled="@(IsOfferingPresentation || IsGrantingPresentation || IsGranting || IsOffering || IsAlreadyOffered || IsAlreadyGranted)">
                        @(IsOfferingPresentation ? "Offering..." : "Offer presentation")
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => GrantCredentialFromApply())"
                               Disabled="@(IsGranting || IsOffering || IsAlreadyOffered || IsAlreadyGranted)">
                        @(IsGranting ? "Granting..." : "Grant credential...")
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => NavigateToPresentation(isOffer: false))"
                               Disabled="@(IsGrantingPresentation || IsGranting || IsOffering || IsAlreadyOffered || IsAlreadyGranted)">
                        @(IsGrantingPresentation ? "Granting..." : "Grant presentation")
                    </MudButton>
                    break;

                case "/exn/ipex/offer":
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AgreeToOffer"
                               Disabled="@(IsAgreeing || IsAlreadyAgreed)">
                        @(IsAgreeing ? "Agreeing..." : "Agree")
                    </MudButton>
                    break;

                case "/exn/ipex/agree":
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SubmitGrantFromAgree"
                               Disabled="@(IsGranting || isGrantSubmitted || IsAlreadyGranted)">
                        @(IsGranting ? "Granting..." : "Grant credential")
                    </MudButton>
                    break;

                case "/exn/ipex/grant":
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AdmitCredential"
                               Disabled="@(IsAdmitting || IsAlreadyAdmitted)">
                        @(IsAdmitting ? "Admitting..." : "Admit")
                    </MudButton>
                    break;
            }
        }
    </MudStack>
</div>
