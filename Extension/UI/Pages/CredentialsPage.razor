@page "/Credentials.html"
@layout Layouts.MainLayout
@using Extension.Models
@using Extension.Services
@using Extension.Services.Storage
@inherits AuthenticatedPageBase
@implements IDisposable

@using System.Collections.Immutable
@using static Extension.Helper.CredentialHelper
@using static Extension.Helper.PrefixDisplay
@using static Extension.Helper.PreviousPage

@inject NavigationManager navManager
@inject IStorageGateway storageGateway
@inject IJSRuntime js
@inject ILogger<CredentialsPage> logger
@inject AppCache appCache
@inject ICredentialViewSpecService viewSpecService

@code {
    // computed properties
    bool IsCredentialsFetched => appCache.MyPollingState.CredentialsLastFetchedUtc is not null;
    string selectedViewDefId =>
        appCache.MyPreferences.SelectedViewDefIds.TryGetValue(nameof(CredentialsPage), out var savedId) && CredentialViewDefs.Any(v => v.Id == savedId)
            ? savedId
            : ViewDefIds.CredAll;

    // reactive properties — read directly from AppCache on every render
    List<RecursiveDictionary> credentials => appCache.MyCachedCredentials.ToList();
    string SelectedPrefix => appCache.SelectedPrefix ?? "";

    // Sort
    List<SortSet<RecursiveDictionary>> credentialSortSets =
        [new("IssuedDate", [new SortExpression<RecursiveDictionary>(c => c.GetValueByPath("sad.a.dt")?.Value?.ToString() ?? "", Descending: true)])];

    // Filter predicates for ViewDefs
    bool IsHeldByPrefix(RecursiveDictionary c) =>
        !string.IsNullOrEmpty(SelectedPrefix) && c.GetValueByPath("sad.a.i")?.Value as string == SelectedPrefix;

    bool IsIssuedByPrefix(RecursiveDictionary c) =>
        !string.IsNullOrEmpty(SelectedPrefix) && c.GetValueByPath("sad.i")?.Value as string == SelectedPrefix;

    static bool IsRevoked(RecursiveDictionary c) {
        var et = c.GetValueByPath("status.et")?.Value?.ToString();
        return et is "rev" or "brv";
    }

    bool IsRevokedByPrefix(RecursiveDictionary c) =>
        IsRevoked(c) && (IsHeldByPrefix(c) || IsIssuedByPrefix(c));



    // ViewDef
    List<FilterSet<RecursiveDictionary>> ProfileSubtotalFilterSets =>
    [
        new("Held", [IsHeldByPrefix]),
        new("Issued", [IsIssuedByPrefix])
    ];

    List<ViewDef<RecursiveDictionary>> CredentialViewDefs =>
    [
        new(ViewDefIds.CredHeld, "Held (active profile)",
            FilterSets: [new("Held", [IsHeldByPrefix])],
            SubtotalFilterSets: ProfileSubtotalFilterSets,
            CountStyle: CountStyle.OfSubTotal,
            SortSets: credentialSortSets),
        new(ViewDefIds.CredIssued, "Issued (active profile)",
            FilterSets: [new("Issued", [IsIssuedByPrefix])],
            SubtotalFilterSets: ProfileSubtotalFilterSets,
            CountStyle: CountStyle.OfSubTotal,
            SortSets: credentialSortSets),
        new(ViewDefIds.CredRevokedProfile, "Revoked (active profile)",
            FilterSets: [new("Revoked", [IsRevokedByPrefix])],
            SubtotalFilterSets: ProfileSubtotalFilterSets,
            CountStyle: CountStyle.OfSubTotal,
            SortSets: credentialSortSets),
        new(ViewDefIds.CredHeldOrIssued, "All (active profile)",
            FilterSets: [
                new("Held", [IsHeldByPrefix]),
                new("Issued", [IsIssuedByPrefix]),
                new("Revoked", [IsRevokedByPrefix])
            ],
            CountStyle: CountStyle.ForProfile,
            SortSets: credentialSortSets),
        new(ViewDefIds.CredRevokedAll, "Revoked (all)",
            FilterSets: [new("Revoked", [IsRevoked])],
            CountStyle: CountStyle.Total,
            SortSets: credentialSortSets),
        new(ViewDefIds.CredAll, "All",
            CountStyle: CountStyle.Total,
            SortSets: credentialSortSets)
    ];

    ViewDef<RecursiveDictionary>? SelectedViewDef => CredentialViewDefs.FirstOrDefault(v => v.Id == selectedViewDefId);
    List<RecursiveDictionary> FilteredCredentials => ViewDefHelper.Apply(credentials, SelectedViewDef);

    int? SubtotalCount => SelectedViewDef?.SubtotalFilterSets is { Count: > 0 }
        ? ViewDefHelper.ApplySubtotalCount(credentials, SelectedViewDef)
        : (int?)null;

    // Deferred-render gate: keep the credential list out of the first synchronous render so
    // navigation feels snappy. Each MudExpansionPanel + CredentialComponent is heavy; rendering
    // ~30 of them in one synchronous pass blocks the UI noticeably. First render shows page chrome
    // + spinner; OnAfterRender flips the flag and triggers a second render for the list.
    bool _renderContent;

    protected override async Task OnInitializedAsync()
    {
        logger.LogInformation($"OnInitializedAsync");

        // Initialize base class for authentication-based render suppression
        InitializeAppCache(appCache);

        // Subscribe to AppCache changes - will trigger StateHasChanged which re-evaluates
        // the computed credentials property from appCache.MyCachedCredentials
        await this.SubscribeToAppCache(appCache);

    }

    protected override void OnAfterRender(bool firstRender) {
        if (firstRender && !_renderContent) {
            _renderContent = true;
            StateHasChanged();
        }
    }

    async Task OnViewDefChanged(string newId)
    {
        var updatedIds = new Dictionary<string, string>(appCache.MyPreferences.SelectedViewDefIds)
        {
            [nameof(CredentialsPage)] = newId
        };
        await storageGateway.SetItem(appCache.MyPreferences with { SelectedViewDefIds = updatedIds });
    }

    protected override void OnParametersSet()
    {
    }

    // Summary helpers for list rendering
    string ShortName(RecursiveDictionary c) {
        var schemaSaid = c.GetValueByPath("sad.s")?.Value?.ToString() ?? "";
        return viewSpecService.GetOrCreateFallback(schemaSaid).ShortName;
    }

    string Subtitle(RecursiveDictionary c) {
        var lei = c.GetValueByPath("sad.a.LEI")?.Value?.ToString();
        var issuer = c.GetValueByPath("sad.i")?.Value?.ToString();
        return lei is not null && lei.Length > 8
            ? $"LEI: {ElideText(lei, 8, 0)}"
            : (!string.IsNullOrEmpty(issuer) ? ElideText(issuer, 12, 0) : "Unknown Issuer");
    }

    string RoleOrContext(RecursiveDictionary c) {
        var ecr = c.GetValueByPath("sad.a.engagementContextRole")?.Value?.ToString();
        var oor = c.GetValueByPath("sad.a.officialRole")?.Value?.ToString();
        return ecr ?? oor ?? "";
    }

    string RowStyle(RecursiveDictionary c) =>
        $"background-color: {GetBackgroundColor(c, appCache.MyPreferences.IsDarkTheme)};";

    void NavigateToCredential(RecursiveDictionary credential)
    {
        var said = credential.GetValueByPath("sad.d")?.Value?.ToString();
        if (said is not null)
        {
            navManager.NavigateTo($"{Routes.Paths.Credential}?said={said}");
        }
    }

    public void Dispose()
    {
        this.UnsubscribeFromAppCache();
    }
}


<div id="@this.GetType().Name" class="bt-body-page">
    <MudStack Class="bt-main">
        <div class="bt-main-inside-scroll">
            <PageHeading Title="Credentials" InfoTooltip="" />
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <ViewSelector T="RecursiveDictionary"
                              ViewDefs="@CredentialViewDefs"
                              SelectedViewDefId="@selectedViewDefId"
                              SelectedViewDefIdChanged="@OnViewDefChanged"
                              FilteredCount="@(IsCredentialsFetched ? FilteredCredentials.Count : (int?)null)"
                              SubtotalCount="@(IsCredentialsFetched ? SubtotalCount : null)"
                              TotalCount="@(IsCredentialsFetched ? credentials.Count : (int?)null)" />
            </MudStack>

            @if (!_renderContent)
            {
                <div style="display:flex; align-items:center; justify-content:center; padding: 48px;">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                </div>
            }
            else if (IsCredentialsFetched)
            {
                @if (FilteredCredentials.Any())
                {
                    <MudStack Spacing="1">
                        @foreach (var credential in FilteredCredentials)
                        {
                            var roleCtx = RoleOrContext(credential);
                            <MudPaper Class="pa-3 bt-clickable" Style="@RowStyle(credential)"
                                      @onclick="@(() => NavigateToCredential(credential))">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudText Class="bt-card-title">@ShortName(credential)</MudText>
                                    <MudText Typo="Typo.caption">
                                        @Subtitle(credential)@if (!string.IsNullOrEmpty(roleCtx)) { <text> &bull; @roleCtx</text> }
                                    </MudText>
                                </MudStack>
                            </MudPaper>
                        }
                    </MudStack>
                }
                else
                {
                    <MudAlert Severity="Severity.Info">No credentials found.</MudAlert>
                }
            }
        </div>
    </MudStack>
    <MudStack Row="true" class="bt-button-tray">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBackIosNew" Variant="Variant.Text" OnClick='@(async () => await GoBack(js))' Class="justify-start" />
        <MudSpacer></MudSpacer>
    </MudStack>
</div>
