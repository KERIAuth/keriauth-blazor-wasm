@page "/CreateTestData.html"
@using Extension.Helper
@using Extension.Models
@using Extension.Models.Messages.AppBw
@using Extension.Models.Storage
@using Extension.Services
@using Extension.Services.Port
@using Extension.Services.SignifyService.Models
@using static Extension.AppConfig;
@using Extension.Services.Storage
@using Extension.Utilities
@using static Extension.Helper.PreviousPage
@inject NavigationManager navManager
@inject IJSRuntime js
@inject ILogger<CreateTestDataPage> logger
@inject AppCache appCache
@inject IAppBwPortService appBwPortService
@inject IStorageGateway storageGateway
@inject IDialogService dialogService
@inject ISnackbar snackbar

@implements IDisposable

@code
{
    enum StepStatus { Blank, Running, Success, Error }

    // Section 1: Prime AIDs
    StepStatus goStatus;
    string? goError;
    string prepend = "";

    // Progress tracking — drives Running→Success/Error transitions
    PrimeDataProgress? currentProgress;
    IDisposable? _progressSubscription;

    // Section 2: IPEX Workflows
    StepStatus ipexStatus;
    string? ipexError;
    bool isPresentation;
    string? selectedDiscloserPrefix;
    string? selectedDiscloseePrefix;
    IpexWorkflow? selectedWorkflow;
    string ipexEcrRole = "";

    List<Aid> AllAids => appCache.Aids;
    List<Connection> AllConnections => appCache.MyConnections ?? [];

    string DiscloserLabel => (isPresentation ? "Discloser, Holder" : "Discloser, Issuer");
    string DiscloseeLabel => (isPresentation ? "Disclosee, Verifier" : "Disclosee, Holder");

    // All selectable AIDs: local identifiers + external connection targets
    List<(string Prefix, string Name, bool IsLocal)> AllSelectableAids
    {
        get
        {
            var result = AllAids.Select(a => (a.Prefix, a.Name, IsLocal: true)).ToList();
            var localPrefixes = new HashSet<string>(AllAids.Select(a => a.Prefix));
            var external = AllConnections
                .Where(c => !localPrefixes.Contains(c.ReceiverPrefix))
                .GroupBy(c => c.ReceiverPrefix)
                .Select(g => (g.Key, g.First().Name, IsLocal: false));
            result.AddRange(external);
            return result;
        }
    }

    bool IsLocalPrefix(string? prefix) => prefix is not null && AllAids.Any(a => a.Prefix == prefix);

    string GetSelectableAidDisplay(string prefix)
    {
        var entry = AllSelectableAids.FirstOrDefault(a => a.Prefix == prefix);
        var name = entry.Name ?? prefix;
        var suffix = entry.IsLocal ? "" : " (ext)";
        return $"{name}{suffix} ({ElideText(prefix, 8, 0)})";
    }

    bool HasConnectionFrom(string? sender, string? receiver) =>
        sender is not null && receiver is not null &&
        AllConnections.Any(c => c.SenderPrefix == sender && c.ReceiverPrefix == receiver);

    bool HasMutualLocalConnection =>
        HasConnectionFrom(selectedDiscloserPrefix, selectedDiscloseePrefix) &&
        HasConnectionFrom(selectedDiscloseePrefix, selectedDiscloserPrefix);

    static bool IsMultiStepWorkflow(IpexWorkflow? wf) => wf is not (
        IpexWorkflow.Apply
        or IpexWorkflow.Offer
        or IpexWorkflow.Grant
        or null);

    static bool WorkflowIncludesApplyGrant(IpexWorkflow? wf) => wf is
        IpexWorkflow.ApplyGrant
        or IpexWorkflow.ApplyGrantAdmit;

    static bool WorkflowIncludesApply(IpexWorkflow? wf) => wf is
        IpexWorkflow.Apply
        or IpexWorkflow.ApplyOffer
        or IpexWorkflow.ApplyOfferAgree
        or IpexWorkflow.ApplyOfferAgreeGrant
        or IpexWorkflow.ApplyOfferAgreeGrantAdmit
        or IpexWorkflow.ApplyGrant
        or IpexWorkflow.ApplyGrantAdmit;

    static bool WorkflowIncludesOfferOrGrant(IpexWorkflow? wf) => wf is
        IpexWorkflow.Offer 
        or IpexWorkflow.OfferAgree
        or IpexWorkflow.OfferAgreeGrant
        or IpexWorkflow.OfferAgreeGrantAdmit
        or IpexWorkflow.Grant 
        or IpexWorkflow.ApplyOffer
        or IpexWorkflow.ApplyOfferAgree or IpexWorkflow.ApplyOfferAgreeGrant
        or IpexWorkflow.ApplyOfferAgreeGrantAdmit or IpexWorkflow.GrantAdmit
        or IpexWorkflow.ApplyGrant
        or IpexWorkflow.ApplyGrantAdmit;

    // Validation rules: only rules relevant to current selection, with pass/fail
    List<(string Text, bool IsValid)> ValidationRules
    {
        get
        {
            var rules = new List<(string, bool)>();
            if (selectedDiscloserPrefix is null || selectedDiscloseePrefix is null || selectedWorkflow is null)
                return rules;

            rules.Add(("Discloser and disclosee must not be the same",
                selectedDiscloserPrefix != selectedDiscloseePrefix));

            if (IsMultiStepWorkflow(selectedWorkflow))
            {
                rules.Add(("Multi-step workflows require both AIDs to be local profiles",
                    IsLocalPrefix(selectedDiscloserPrefix) && IsLocalPrefix(selectedDiscloseePrefix)));
                rules.Add(("Multi-step workflows require mutual connections between AIDs",
                    HasMutualLocalConnection));
            }
            else
            {
                // Single-step: check the needed connection direction
                if (WorkflowIncludesApply(selectedWorkflow))
                {
                    rules.Add(("Disclosee must have connection to discloser (for apply)",
                        HasConnectionFrom(selectedDiscloseePrefix, selectedDiscloserPrefix)));
                }
                if (WorkflowIncludesOfferOrGrant(selectedWorkflow))
                {
                    rules.Add(("Discloser must have connection to disclosee (for offer, grant)",
                        HasConnectionFrom(selectedDiscloserPrefix, selectedDiscloseePrefix)));
                }
            }

            return rules;
        }
    }

    bool AllRulesPass => ValidationRules.Count == 0 || ValidationRules.All(r => r.IsValid);

    bool IpexGoEnabled =>
        !string.IsNullOrWhiteSpace(ipexEcrRole) &&
        selectedWorkflow is not null &&
        selectedDiscloserPrefix is not null &&
        selectedDiscloseePrefix is not null &&
        AllRulesPass &&
        ipexStatus != StepStatus.Running;

    static string WorkflowDisplayName(IpexWorkflow wf) => wf switch
    {
        IpexWorkflow.Apply => "⬆apply",
        IpexWorkflow.Offer => "⬇offer",
        IpexWorkflow.Grant => "⬇grant",

        IpexWorkflow.ApplyOfferAgreeGrantAdmit => "⬆apply  ⬇offer  ⬆agree  ⬇grant  ⬆admit",
        IpexWorkflow.ApplyOfferAgreeGrant => "⬆apply  ⬇offer  ⬆agree  ⬇grant",
        IpexWorkflow.ApplyOfferAgree => "⬆apply  ⬇offer  ⬆agree",
        IpexWorkflow.ApplyOffer => "⬆apply  ⬇offer",
        
        IpexWorkflow.ApplyGrantAdmit => "⬆apply  ⬇grant  ⬆admit",
        IpexWorkflow.ApplyGrant => "⬆apply  ⬇grant",

        IpexWorkflow.OfferAgreeGrantAdmit => "⬇offer  ⬆agree  ⬇grant  ⬆admit",
        IpexWorkflow.OfferAgreeGrant => "⬇offer  ⬆agree  ⬇grant",
        IpexWorkflow.OfferAgree => "⬇offer  ⬆agree",
        
        IpexWorkflow.GrantAdmit => "⬇grant  ⬆admit",
        
        _ => wf.ToString()
    };

    protected override async Task OnInitializedAsync()
    {
        await this.SubscribeToAppCache(appCache);
        _progressSubscription = storageGateway.Subscribe<PrimeDataProgress>(
            new ProgressObserver(this), StorageArea.Session);
        logger.LogInformation("OnInitializedAsync");
        ipexEcrRole = GenerateRandomRole();
        selectedWorkflow = IpexWorkflow.Apply;
        SelectDefaults();

        // Restore saved test prefs from the active KERIA config
        await LoadTestPrefsAsync();

        // Restore state from any in-progress or recently-completed operation
        var existing = await storageGateway.GetItem<PrimeDataProgress>(StorageArea.Session);
        if (existing.IsSuccess && existing.Value is { } progress)
            ApplyProgress(progress);
    }

    void ApplyProgress(PrimeDataProgress value)
    {
        currentProgress = value;
        var op = value.Operation;
        if (value.IsComplete || value.IsError)
        {
            var status = value.IsComplete ? StepStatus.Success : StepStatus.Error;
            var error = value.IsError ? value.Description : null;
            SetOperationStatus(op, status, error);
        }
        else
        {
            // Still running — show spinner for the correct section
            SetOperationStatus(op, StepStatus.Running, null);
            _activeOp = op;
        }
    }

    void SetOperationStatus(PrimeDataOperation op, StepStatus status, string? error)
    {
        switch (op)
        {
            case PrimeDataOperation.Go:
                goStatus = status;
                goError = error;
                break;
            case PrimeDataOperation.Ipex:
                ipexStatus = status;
                ipexError = error;
                break;
        }
    }

    PrimeDataOperation _activeOp = PrimeDataOperation.None;

    class ProgressObserver(CreateTestDataPage page) : IObserver<PrimeDataProgress>
    {
        public void OnNext(PrimeDataProgress value)
        {
            page.currentProgress = value;
            var op = value.Operation;
            if (value.IsComplete || value.IsError)
            {
                page.SetOperationStatus(op, value.IsComplete ? StepStatus.Success : StepStatus.Error,
                    value.IsError ? value.Description : null);
                page._activeOp = PrimeDataOperation.None;
            }
            page.InvokeAsync(page.StateHasChanged);
        }
        public void OnError(Exception error) { }
        public void OnCompleted() { }
    }

    void SelectDefaults()
    {
        var aids = AllSelectableAids;
        // Default discloser: first external, or first AID
        var firstExternal = aids.FirstOrDefault(a => !a.IsLocal);
        var firstLocal = aids.FirstOrDefault(a => a.IsLocal);
        selectedDiscloserPrefix = firstExternal.Prefix ?? firstLocal.Prefix;
        // Default disclosee: first local AID different from discloser
        selectedDiscloseePrefix = aids
            .Where(a => a.IsLocal && a.Prefix != selectedDiscloserPrefix)
            .Select(a => a.Prefix)
            .FirstOrDefault() ?? firstLocal.Prefix;
    }

    static string GenerateRandomRole()
    {
        return Random.Shared.Next(1000, 10000).ToString();
    }

    // Cached issue credentials prefs for passing to dialog
    IssueCredentialsTestPrefs? _issueCredentialsPrefs;

    async Task LoadTestPrefsAsync()
    {
        var ctxResult = await GetCurrentConfigContextAsync();
        if (ctxResult.IsFailed) return;
        var (_, _, config) = ctxResult.Value;
        if (config.TestPrefs?.CreateIpex is { } ipexPrefs)
        {
            isPresentation = ipexPrefs.IsPresentation;
            if (ipexPrefs.DiscloserPrefix is not null)
                selectedDiscloserPrefix = ipexPrefs.DiscloserPrefix;
            if (ipexPrefs.Workflow is not null)
                selectedWorkflow = ipexPrefs.Workflow;
            if (ipexPrefs.DiscloseePrefix is not null)
                selectedDiscloseePrefix = ipexPrefs.DiscloseePrefix;
            if (!string.IsNullOrEmpty(ipexPrefs.RoleName))
                ipexEcrRole = ipexPrefs.RoleName;
        }
        _issueCredentialsPrefs = config.TestPrefs?.IssueCredentials;
    }

    async Task SaveCreateIpexPrefsAsync()
    {
        var prefs = new CreateIpexTestPrefs
        {
            IsPresentation = isPresentation,
            DiscloserPrefix = selectedDiscloserPrefix,
            Workflow = selectedWorkflow,
            DiscloseePrefix = selectedDiscloseePrefix,
            RoleName = ipexEcrRole
        };
        await SaveTestPrefsAsync(createIpex: prefs);
    }

    async Task SaveIssueCredentialsPrefsAsync(IssueCredentialsTestPrefs prefs)
    {
        _issueCredentialsPrefs = prefs;
        await SaveTestPrefsAsync(issueCredentials: prefs);
    }

    async Task SaveTestPrefsAsync(CreateIpexTestPrefs? createIpex = null, IssueCredentialsTestPrefs? issueCredentials = null)
    {
        var ctxResult = await GetCurrentConfigContextAsync();
        if (ctxResult.IsFailed)
        {
            logger.LogWarning("SaveTestPrefsAsync: skipped — {Errors}", string.Join(", ", ctxResult.Errors));
            return;
        }
        var (configs, digest, config) = ctxResult.Value;

        var existing = config.TestPrefs ?? new PerConfigTestPrefs();
        var updated = existing with
        {
            CreateIpex = createIpex ?? existing.CreateIpex,
            IssueCredentials = issueCredentials ?? existing.IssueCredentials
        };

        var updatedConfig = config with { TestPrefs = updated };
        var updatedConfigs = configs with
        {
            Configs = new Dictionary<string, KeriaConnectConfig>(configs.Configs) { [digest] = updatedConfig }
        };
        var setResult = await storageGateway.SetItem(updatedConfigs);
        if (setResult.IsFailed)
            logger.LogWarning("SaveTestPrefsAsync: SetItem failed — {Errors}", string.Join(", ", setResult.Errors));
        else
            logger.LogInformation("SaveTestPrefsAsync: saved TestPrefs for digest {Digest}", digest[..8]);
    }

    async Task<Result<(KeriaConnectConfigs configs, string digest, KeriaConnectConfig config)>> GetCurrentConfigContextAsync()
    {
        var prefsResult = await storageGateway.GetItem<Preferences>();
        if (prefsResult.IsFailed || prefsResult.Value is null)
            return Result.Fail("Could not fetch preferences");

        var selectedDigest = prefsResult.Value.SelectedKeriaConnectionDigest;
        if (string.IsNullOrEmpty(selectedDigest))
            return Result.Fail("No KERIA connection selected");

        var configsResult = await storageGateway.GetItem<KeriaConnectConfigs>();
        if (configsResult.IsFailed || configsResult.Value is null)
            return Result.Fail("Could not fetch KERIA configs");

        if (!configsResult.Value.Configs.TryGetValue(selectedDigest, out var config))
            return Result.Fail($"No config for digest {selectedDigest[..8]}");

        return Result.Ok((configsResult.Value, selectedDigest, config));
    }

    async Task OnGo()
    {
        goStatus = StepStatus.Running;
        goError = null;
        currentProgress = null;
        _activeOp = PrimeDataOperation.Go;
        StateHasChanged();

        try
        {
            var response = await appBwPortService.SendRpcRequestAsync(
                AppBwMessageType.Values.RequestPrimeDataGo,
                new { payload = new PrimeDataGoPayload(prepend) },
                TimeSpan.FromSeconds(10));

            if (!response.Ok)
            {
                goStatus = StepStatus.Error;
                goError = response.Error ?? "Failed to start operation";
                _activeOp = PrimeDataOperation.None;
            }
            // On success, BW acknowledged — progress observer will drive status from here
        }
        catch (Exception ex)
        {
            goStatus = StepStatus.Error;
            goError = ex.Message;
            _activeOp = PrimeDataOperation.None;
        }

        StateHasChanged();
    }

    async Task OnIpexGo()
    {
        if (selectedDiscloserPrefix is null || selectedDiscloseePrefix is null || selectedWorkflow is null) return;

        ipexStatus = StepStatus.Running;
        ipexError = null;
        currentProgress = null;
        _activeOp = PrimeDataOperation.Ipex;
        StateHasChanged();

        try
        {
            var payload = new PrimeDataIpexPayload(
                selectedDiscloserPrefix,
                selectedDiscloseePrefix,
                selectedWorkflow.Value,
                ipexEcrRole,
                isPresentation);

            var response = await appBwPortService.SendRpcRequestAsync(
                AppBwMessageType.Values.RequestPrimeDataIpex,
                new { payload },
                TimeSpan.FromSeconds(10));

            if (!response.Ok)
            {
                ipexStatus = StepStatus.Error;
                ipexError = response.Error ?? "Failed to start operation";
                _activeOp = PrimeDataOperation.None;
            }
            // On success, BW acknowledged — progress observer will drive status from here
        }
        catch (Exception ex)
        {
            ipexStatus = StepStatus.Error;
            ipexError = ex.Message;
            _activeOp = PrimeDataOperation.None;
        }

        StateHasChanged();
    }

    void OnReset()
    {
        goStatus = StepStatus.Blank;
        goError = null;
        ipexStatus = StepStatus.Blank;
        ipexError = null;
        currentProgress = null;
        _activeOp = PrimeDataOperation.None;
        ipexEcrRole = GenerateRandomRole();
        StateHasChanged();
    }

    async Task OpenAdHocIssuanceDialog(bool isOffer)
    {
        var parameters = new DialogParameters<OfferOrGrantCredentialIssuanceDialog>
        {
            { x => x.IsOffer, isOffer },
            { x => x.LocalAids, appCache.Aids },
            { x => x.Connections, appCache.MyConnections },
            { x => x.InitialIssuerPrefix, _issueCredentialsPrefs?.Ecr?.IssuerPrefix },
            { x => x.InitialHolderPrefix, _issueCredentialsPrefs?.Ecr?.HolderPrefix },
            { x => x.InitialSediIssuerPrefix, _issueCredentialsPrefs?.Sedi?.IssuerPrefix },
            { x => x.InitialSediIssueePrefix, _issueCredentialsPrefs?.Sedi?.IssueePrefix },
        };
        var options = new DialogOptions {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            BackdropClick = false,
            CloseButton = true,
            Position = DialogPosition.Center,
        };
        var title = isOffer ? "Issue & offer credential" : "Issue & grant credential";
        var dialog = await dialogService.ShowAsync<OfferOrGrantCredentialIssuanceDialog>(title, parameters, options);
        var dialogResult = await dialog.Result;

        if (dialogResult is not null && !dialogResult.Canceled) {
            var result = dialogResult.Data as OfferOrGrantCredentialIssuanceDialog.IssuanceDialogResult;
            if (result is not null && result.Submitted) {
                snackbar.Add($"Credential {(isOffer ? "offered" : "granted")} successfully", Severity.Success);
                var existing = _issueCredentialsPrefs ?? new IssueCredentialsTestPrefs();
                IssueCredentialsTestPrefs? updated;
                switch (result.Kind) {
                    case OfferOrGrantCredentialIssuanceDialog.IssuanceKind.Ecr:
                        updated = existing with {
                            Ecr = new IssueEcrTestPrefs {
                                IssuerPrefix = result.IssuerPrefix,
                                HolderPrefix = result.HolderPrefix,
                                RoleName = result.RoleName ?? ""
                            }
                        };
                        break;
                    case OfferOrGrantCredentialIssuanceDialog.IssuanceKind.Sedi:
                        var existingSedi = existing.Sedi ?? new IssueSediTestPrefs();
                        updated = existing with {
                            Sedi = existingSedi with {
                                IssuerPrefix = result.IssuerPrefix,
                                IssueePrefix = result.HolderPrefix
                            }
                        };
                        break;
                    default:
                        logger.LogWarning("OpenAdHocIssuanceDialog: unhandled IssuanceKind {Kind}", result.Kind);
                        updated = null;
                        break;
                }
                if (updated is not null) {
                    await SaveIssueCredentialsPrefsAsync(updated);
                }
            }
        }
    }

    public void Dispose()
    {
        _progressSubscription?.Dispose();
        this.UnsubscribeFromAppCache();
        GC.SuppressFinalize(this);
    }
}

<div id="@this.GetType().Name" class="bt-body-page">
    <div class="d-flex gap-3 bt-main">
        <div class="bt-main-inside-scroll">
            <PageHeading Title="Create test data" />
            <MudExpansionPanels>
                <MudExpansionPanel>
                    <TitleContent>
                        <MudText Class="bt-pref-group-label0">
                            Create chain of vLEI credentials (from GEDA to Person)
                        </MudText>
                    </TitleContent>
                    <ChildContent>
                        <MudStack Class="ml-5">
                            <MudTextField T="string" Label="Prepend to profile names (optional)" @bind-Value="prepend" Variant="Variant.Outlined"
                                          Validation="@((string v) => AidNameValidator.ValidateOptional(v))" />
                        </MudStack>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="ml-5">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       OnClick="OnGo" Disabled="@(goStatus == StepStatus.Running || AidNameValidator.ValidateOptional(prepend) is not null)">
                                Go
                            </MudButton>
                            @if (goStatus == StepStatus.Running)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                @if (currentProgress is not null && !currentProgress.IsComplete && !currentProgress.IsError)
                                {
                                    <MudText Typo="Typo.body2">Step @currentProgress.Step of @currentProgress.TotalSteps: @currentProgress.Description</MudText>
                                }
                            }
                            @if (goStatus == StepStatus.Success)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                            }
                            @if (goStatus == StepStatus.Error)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Title="@goError" />
                                <MudText Color="Color.Error" Typo="Typo.body2">@goError</MudText>
                            }
                        </MudStack>
                    </ChildContent>
                </MudExpansionPanel>
                <MudExpansionPanel>
                    <TitleContent>
                        <MudText Class="bt-pref-group-label0">
                            Create IPEX credential workflows with ECR
                        </MudText>
                    </TitleContent>
                    <ChildContent>
                        <MudStack Class="ml-5" Spacing="2">
                            <MudRadioGroup T="bool" @bind-Value="@isPresentation" @bind-Value:after="SaveCreateIpexPrefsAsync">
                                <MudRadio T="bool" Value="false" Color="Color.Primary">Credential issuance</MudRadio>
                                <MudRadio T="bool" Value="true" Color="Color.Primary">Credential presentation</MudRadio>
                            </MudRadioGroup>
                            <MudSelect Label="@DiscloserLabel" @bind-value="@selectedDiscloserPrefix"
                                       @bind-value:after="SaveCreateIpexPrefsAsync"
                                       Variant="Variant.Outlined"
                                       Dense="true"
                                       Modal="true">
                                @foreach (var (prefix, name, isLocal) in AllSelectableAids)
                                {
                                    <MudSelectItem Value="@prefix">
                                        <AidPrefixDisplay Prefix="@prefix" Name="@(name + (isLocal ? "" : " (ext)"))" ShowCopyButton="false" />
                                    </MudSelectItem>
                                }
                            </MudSelect>

                            <MudSelect T="IpexWorkflow?" Label="Workflow" @bind-value="@selectedWorkflow"
                                       @bind-value:after="SaveCreateIpexPrefsAsync"
                                       Variant="Variant.Outlined" Placeholder="Select workflow">
                                @foreach (var wf in Enum.GetValues<IpexWorkflow>())
                                {
                                    <MudSelectItem T="IpexWorkflow?" Value="wf">
                                        @WorkflowDisplayName(wf)
                                    </MudSelectItem>
                                }
                            </MudSelect>

                            <MudSelect Label="@DiscloseeLabel" @bind-value="@selectedDiscloseePrefix"
                                       @bind-value:after="SaveCreateIpexPrefsAsync"
                                       Variant="Variant.Outlined"
                                       Dense="true"
                                       Modal="true">
                                @foreach (var (prefix, name, isLocal) in AllSelectableAids)
                                {
                                    <MudSelectItem T="string" Value="prefix">
                                        <AidPrefixDisplay Prefix="@prefix" Name="@(name + (isLocal ? "" : " (ext)"))" ShowCopyButton="false" />
                                    </MudSelectItem>
                                }
                            </MudSelect>

                            <MudTextField T="string" Label="Role" @bind-Value="@ipexEcrRole" @bind-Value:after="SaveCreateIpexPrefsAsync"
                                          Variant="Variant.Outlined" Required="true" RequiredError="Role is required" />
                            @if (ValidationRules.Count > 0)
                            {
                                <MudStack Spacing="0" Class="mt-1">
                                    @foreach (var (text, isValid) in ValidationRules)
                                    {
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@(isValid? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                                                     Color="@(isValid ? Color.Success : Color.Error)" Size="Size.Small" />
                                            <MudText Typo="Typo.body2" Color="@(isValid? Color.Default: Color.Error)">@text</MudText>
                                        </MudStack>
                                    }
                                </MudStack>
                            }
                            <MudText Color="Color.Warning" Typo="Typo.body2" Class="mt-1">
                                Note:  KERIA does not generate notifications for non-initiator IPEX messages (offer, agree, admit) when sender and recipient are under the same agent.
                            </MudText>

                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                           OnClick="OnIpexGo" Disabled="@(!IpexGoEnabled)">
                                    Go
                                </MudButton>
                                @if (ipexStatus == StepStatus.Running)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                    @if (currentProgress is not null && !currentProgress.IsComplete && !currentProgress.IsError)
                                    {
                                        <MudText Typo="Typo.body2">Step @currentProgress.Step of @currentProgress.TotalSteps: @currentProgress.Description</MudText>
                                    }
                                }
                                @if (ipexStatus == StepStatus.Success)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                                }
                                @if (ipexStatus == StepStatus.Error)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Title="@ipexError" />
                                    <MudText Color="Color.Error" Typo="Typo.body2">@ipexError</MudText>
                                }
                            </MudStack>
                        </MudStack>
                    </ChildContent>
                </MudExpansionPanel>
                <MudExpansionPanel>
                    <TitleContent>
                        <MudText Class="bt-pref-group-label0">
                            Issue Credentials
                        </MudText>
                    </TitleContent>
                    <ChildContent>
                        <MudStack Class="ml-5" Spacing="2">
                            <MudText Typo="Typo.body2">
                                Issue a credential ad-hoc and offer or grant it. Opens the multi-step
                                issuance dialog where you select issuer, holder, and role.
                            </MudText>
                            <MudStack Row="true" Spacing="2">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                           OnClick="@(() => OpenAdHocIssuanceDialog(isOffer: true))"
                                           Disabled="@(!appCache.IsConnectedToKeria)">
                                    Issue &amp; Offer
                                </MudButton>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                           OnClick="@(() => OpenAdHocIssuanceDialog(isOffer: false))"
                                           Disabled="@(!appCache.IsConnectedToKeria)">
                                    Issue &amp; Grant
                                </MudButton>
                            </MudStack>
                        </MudStack>
                    </ChildContent>
                </MudExpansionPanel>
            </MudExpansionPanels>
        </div>
    </div>
    <MudStack Row="true" class="bt-button-tray">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBackIosNew" Variant="Variant.Text" OnClick='@(async () => await GoBack(js))' Class="justify-start" />
        <MudSpacer />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OnReset" Disabled="@(goStatus == StepStatus.Running || ipexStatus == StepStatus.Running)">Reset</MudButton>
    </MudStack>
</div>
