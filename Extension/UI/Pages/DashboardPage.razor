@page "/Dashboard.html"
@using Extension.Models
@using Extension.Services.Storage
@inherits AuthenticatedPageBase
@inject NavigationManager navManager
@inject IJSRuntime js
@inject ILogger<DashboardPage> logger
@inject AppCache appCache

@implements IDisposable

@using Extension.Services.SignifyService.Models

@code {
    // reactive properties — all read from AppCache sub-caches, updated automatically via Changed
    int IdentifiersCount => appCache.Aids.Count;
    int NumWebsites => appCache.MyWebsiteConfigList.WebsiteList.Count;
    int NumCredentialsTotal => appCache.MyCachedCredentials.Count;
    int NumNotificationsTotal => appCache.MyNotifications.Items.Count;

    List<RecursiveDictionary> FilteredCredentials => CredentialHelper.FilterCredentials(
        appCache.MyCachedCredentials.ToList(),
        [("sad.a.i", SelectedPrefix), ("sad.i", SelectedPrefix)]);
    int NumCredentialsThisProfile => FilteredCredentials.Count;

    int NumNotificationsThisProfile => appCache.MyNotifications.Items
        .Count(n => n.TargetPrefix == SelectedPrefix || n.SenderPrefix == SelectedPrefix);

    string KeriaConnectStatusText => appCache.IsConnectedToKeria ? "Connected to" : appCache.IsAuthenticated ? "Not Connected with" : "Locked. Configured to";
    Color KeriaConnectStatusColor => appCache.IsConnectedToKeria ? Color.Success : appCache.IsAuthenticated ? Color.Warning : Color.Error;
    string SelectedPrefix => appCache.SelectedPrefix ?? "";

    // Pluralized labels
    string ProfilesLabel => IdentifiersCount == 1 ? "Profile" : "Profiles";
    string WebsitesLabel => NumWebsites == 1 ? "Website" : "Websites";
    string CredentialsTotalLabel => NumCredentialsTotal == 1 ? "Credential" : "Credentials";
    string NotificationsTotalLabel => NumNotificationsTotal == 1 ? "Notification" : "Notifications";
    string CredentialsProfileLabel => NumCredentialsThisProfile == 1 ? "Credential" : "Credentials";
    string NotificationsProfileLabel => NumNotificationsThisProfile == 1 ? "Notification" : "Notifications";

    string SelectedIdenticon => Helper.Identicon.MakeIdenticon(SelectedPrefix);
    string? SelectedAlias => SelectedAid?.Name ?? (string.IsNullOrEmpty(SelectedPrefix) ? "none" : "");

    Aid? SelectedAid => appCache?.MyCachedIdentifiers?.IdentifiersList?
        .SelectMany(id => id.Aids)
        .FirstOrDefault(aid => aid.Prefix == SelectedPrefix);

    protected override async Task OnInitializedAsync()
    {
        logger.LogInformation($"OnInitializedAsync");

        // Initialize base class for authentication-based render suppression
        InitializeAppCache(appCache);

        // Subscribe to AppCache changes — all counts are reactive computed properties,
        // so StateHasChanged is sufficient (no callback needed).
        await this.SubscribeToAppCache(appCache);
    }

    public void Dispose()
    {
        this.UnsubscribeFromAppCache();
        GC.SuppressFinalize(this);
    }
}

<div id="@this.GetType().Name" class="bt-body-page">
    <div class="d-flex gap-3 bt-main">
        <div class="bt-main-inside-scroll" style="align-items:center; justify-content: center; display:flex; flex-direction:column;">
            <PageHeading Title="Dashboard" />
            <MudStack AlignItems="AlignItems.Center" Class="mudstack-full-width">
                <!-- Independent of selected profile -->
                <MudStack Class="bt-home-background-box" Style="background: var(--mud-palette-background-gray); width: -webkit-fill-available; padding:0.714rem;">
                    <!-- Connected to KERIA -->
                    <MudStack Row>
                        <div Class="mudtext-half-width-left">
                            <MudText Typo="Typo.body1">@KeriaConnectStatusText</MudText>
                        </div>
                        <MudText Class="mudtext-half-width-right">
                            <MudTooltip Text="@appCache.SessionKeriaAlias">
                                <MudLink OnClick="() => navManager.NavigateTo(Routes.Paths.KeriaConfigs)">KERIA Service</MudLink>
                            </MudTooltip>
                        </MudText>
                    </MudStack>
                    <!-- Profiles -->
                    <MudStack Row>
                        <MudText Class="mudtext-half-width-left bt-home-status-number">@IdentifiersCount</MudText>
                        <MudText Class="mudtext-half-width-right">
                            <MudLink OnClick="() => navManager.NavigateTo(Routes.Paths.Profiles)">@ProfilesLabel</MudLink>
                        </MudText>
                    </MudStack>
                    <!-- Websites -->
                    <MudStack Row>
                        <MudText Class="mudtext-half-width-left bt-home-status-number">@NumWebsites</MudText>
                        <MudText Class="mudtext-half-width-right">
                            <MudLink OnClick="() => navManager.NavigateTo(Routes.Paths.Websites)">@WebsitesLabel</MudLink>
                        </MudText>
                    </MudStack>
                    <!-- Credentials (all) -->
                    <MudStack Row>
                        <MudText Class="mudtext-half-width-left bt-home-status-number">@NumCredentialsTotal</MudText>
                        <MudText Class="mudtext-half-width-right">
                            <MudLink OnClick="() => navManager.NavigateTo(Routes.Paths.Credentials)">@CredentialsTotalLabel</MudLink>
                        </MudText>
                    </MudStack>
                    <!-- Notifications (all) -->
                    <MudStack Row>
                        <MudText Class="mudtext-half-width-left bt-home-status-number">@NumNotificationsTotal</MudText>
                        <MudText Class="mudtext-half-width-right">
                            <MudLink OnClick="() => navManager.NavigateTo(Routes.Paths.Notifications)">@NotificationsTotalLabel</MudLink>
                        </MudText>
                    </MudStack>
                </MudStack>
                <!-- Depending on selected Profile -->
                <MudStack Class="bt-home-background-box" Style="background: var(--mud-palette-action-default-hover); width: -webkit-fill-available; padding:0.714rem;">
                    <!-- Selected Profile -->
                    <MudStack Row>
                        <MudText Class="mudtext-half-width-left bt-home-status-number">@SelectedAlias</MudText>
                        <MudText Class="mudtext-half-width-right">
                            <MudLink OnClick='() => navManager.NavigateTo(Routes.Paths.Profile + "?prefix=" + SelectedPrefix)'>Selected profile</MudLink>
                        </MudText>
                    </MudStack>
                    <!-- Credentials (selected profile) -->
                    <MudStack Row>
                        <MudText Class="mudtext-half-width-left bt-home-status-number">@NumCredentialsThisProfile</MudText>
                        <MudText Class="mudtext-half-width-right">
                            <MudLink OnClick="() => navManager.NavigateTo(Routes.Paths.Credentials)">@CredentialsProfileLabel</MudLink>
                        </MudText>
                    </MudStack>
                    <!-- Notifications (selected profile) -->
                    <MudStack Row>
                        <MudText Class="mudtext-half-width-left bt-home-status-number">@NumNotificationsThisProfile</MudText>
                        <MudText Class="mudtext-half-width-right">
                            <MudLink OnClick="() => navManager.NavigateTo(Routes.Paths.Notifications)">@NotificationsProfileLabel</MudLink>
                        </MudText>
                    </MudStack>
                </MudStack>
            </MudStack>
        </div>
    </div>
</div>
