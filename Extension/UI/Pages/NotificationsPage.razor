@page "/Notifications.html"
@using Extension.Models
@using Extension.Models.Messages.AppBw
@using Extension.Services.Storage
@using Extension.Services.Port
@inherits AuthenticatedPageBase
@implements IDisposable

@inject ILogger<NotificationsPage> logger
@inject NavigationManager navManager
@inject IStorageGateway storageGateway
@inject IJSRuntime js
@inject ISnackbar snackbar
@inject AppCache appCache
@inject IAppBwPortService appBwPortService

@code {
    bool IsProcessing { get; set; }
    bool IsNotificationsLoading => appCache.MyPollingState.NotificationsLastFetchedUtc is null;
    // Profile-dependent views filter by sender/target prefixes resolved from CachedExns.
    // Counts for these views aren't meaningful until all exns are cached.
    bool IsProfileFilteredView => selectedViewDefId is ViewDefIds.NotifTarget or ViewDefIds.NotifSender
        or ViewDefIds.NotifUnreadProfile or ViewDefIds.NotifProfile;
    bool IsFilteredCountLoading => IsNotificationsLoading || (IsProfileFilteredView && !appCache.IsAllExnsCached);
    bool IsSubtotalCountLoading => IsNotificationsLoading || !appCache.IsAllExnsCached;
    string selectedViewDefId =>
        appCache.MyPreferences.SelectedViewDefIds.TryGetValue(nameof(NotificationsPage), out var savedId) && NotificationViewDefs.Any(v => v.Id == savedId)
            ? savedId
            : ViewDefIds.NotifAll;

    List<Notification> AllNotifications => appCache?.MyNotifications?.Items ?? [];

    int UnreadCount => AllNotifications.Count(n => !n.IsRead);

    // ViewDef
    List<FilterSet<Notification>> ProfileSubtotalFilterSets =>
    [
        new("Target", [(Notification n) => appCache.GetTargetPrefix(n.ExchangeSaid) == appCache.SelectedPrefix]),
        new("Sender", [(Notification n) => appCache.GetSenderPrefix(n.ExchangeSaid) == appCache.SelectedPrefix])
    ];

    List<ViewDef<Notification>> NotificationViewDefs =>
    [
        new(ViewDefIds.NotifTarget, "Target (active profile)",
            FilterSets: [new("Target", [(Notification n) => appCache.GetTargetPrefix(n.ExchangeSaid) == appCache.SelectedPrefix])],
            SubtotalFilterSets: ProfileSubtotalFilterSets,
            CountStyle: CountStyle.OfSubTotal,
            SortSets: [new("DateTime", [new SortExpression<Notification>(n => n.DateTime, Descending: true)])]),

        new(ViewDefIds.NotifSender, "Sender (active profile)",
            FilterSets: [new("Sender", [(Notification n) => appCache.GetSenderPrefix(n.ExchangeSaid) == appCache.SelectedPrefix])],
            SubtotalFilterSets: ProfileSubtotalFilterSets,
            CountStyle: CountStyle.OfSubTotal,
            SortSets: [new("DateTime", [new SortExpression<Notification>(n => n.DateTime, Descending: true)])]),

        new(ViewDefIds.NotifUnreadProfile, "Unread (active profile)",
            FilterSets: [new("Target", [(Notification n) => appCache.GetTargetPrefix(n.ExchangeSaid) == appCache.SelectedPrefix && !n.IsRead]),
                         new("Sender", [(Notification n) => appCache.GetSenderPrefix(n.ExchangeSaid) == appCache.SelectedPrefix && !n.IsRead])],
            SubtotalFilterSets: ProfileSubtotalFilterSets,
            CountStyle: CountStyle.OfSubTotal,
            SortSets: [new("DateTime", [new SortExpression<Notification>(n => n.DateTime, Descending: true)])]),

        new(ViewDefIds.NotifProfile, "All (active profile)",
            FilterSets: [new("Target", [(Notification n) => appCache.GetTargetPrefix(n.ExchangeSaid) == appCache.SelectedPrefix]),
                         new("Sender", [(Notification n) => appCache.GetSenderPrefix(n.ExchangeSaid) == appCache.SelectedPrefix])],
            SubtotalFilterSets: ProfileSubtotalFilterSets,
            CountStyle: CountStyle.OfSubTotal,
            SortSets: [new("DateTime", [new SortExpression<Notification>(n => n.DateTime, Descending: true)])]),
        
        new(ViewDefIds.NotifUnreadAll, "All unread",
            FilterSets: [new("Unread", [(Notification n) => !n.IsRead])],
            CountStyle: CountStyle.Total,
            SortSets: [new("DateTime", [new SortExpression<Notification>(n => n.DateTime, Descending: true)])]),
        
        new(ViewDefIds.NotifAll, "All",
            CountStyle: CountStyle.Total,
            SortSets: [new("DateTime", [new SortExpression<Notification>(n => n.DateTime, Descending: true)])])
    ];

    ViewDef<Notification>? SelectedViewDef => NotificationViewDefs.FirstOrDefault(v => v.Id == selectedViewDefId);

    // ViewDef-filtered list (profile-based filtering + sorting)
    List<Notification> ViewDefFilteredNotifications => ViewDefHelper.Apply(AllNotifications, SelectedViewDef);

    int? SubtotalCount => SelectedViewDef?.SubtotalFilterSets is { Count: > 0 }
        ? ViewDefHelper.ApplySubtotalCount(AllNotifications, SelectedViewDef)
        : (int?)null;

    // Route/ReadStatus filtering state (composes on top of ViewDef)
    string? FilterRoute { get; set; }
    bool? FilterReadStatus { get; set; }

    List<string> AvailableRoutes => ViewDefFilteredNotifications
        .Select(n => n.Route)
        .Where(r => !string.IsNullOrEmpty(r))
        .Distinct()
        .OrderBy(r => r)
        .ToList();

    List<Notification> FilteredNotifications {
        get {
            IEnumerable<Notification> filtered = ViewDefFilteredNotifications;
            if (FilterRoute is not null) {
                filtered = filtered.Where(n => n.Route == FilterRoute);
            }
            if (FilterReadStatus is not null) {
                filtered = filtered.Where(n => n.IsRead == FilterReadStatus.Value);
            }
            return filtered.ToList();
        }
    }

    bool IsFiltering => FilterRoute is not null || FilterReadStatus is not null;


    string RouteLabel(string route, Notification? notification = null) {
        if (route == "/exn/ipex/apply") return "Credential Request \u2013 Apply";

        var ipexStep = route switch {
            "/exn/ipex/offer" => "Offer",
            "/exn/ipex/agree" => "Agree",
            "/exn/ipex/grant" => "Grant",
            "/exn/ipex/admit" => "Admit",
            _ => null
        };
        if (ipexStep is not null) {
            // Pure lookup — flow type is precomputed in AppCache from MyCachedExns (RebuildExchangePrefixes).
            // No async, no JSON parse, no StateHasChanged cascade. When CachedExns updates, AppCache rebuilds
            // and fires its Changed event, naturally re-rendering the page with refined labels.
            var flowType = appCache.GetExchangeFlowType(notification?.ExchangeSaid);
            var flowLabel = flowType switch {
                IpexFlowType.Issuance => "Credential Issuance",
                IpexFlowType.Presentation => "Credential Presentation",
                _ => "Credential"
            };
            return $"{flowLabel} \u2013 {ipexStep}";
        }
        return route switch {
            "/multisig/iss" => "Multisig Issuance",
            "/multisig/icp" => "Multisig Inception",
            "/multisig/rot" => "Multisig Rotation",
            "/multisig/exn" => "Multisig Exchange",
            _ => route
        };
    }

    static string RouteIcon(string route) => route switch {
        "/exn/ipex/grant" => Icons.Material.Filled.CardGiftcard,
        "/exn/ipex/admit" => Icons.Material.Filled.CheckCircle,
        "/exn/ipex/apply" => Icons.Material.Filled.Assignment,
        "/exn/ipex/offer" => Icons.Material.Filled.LocalOffer,
        "/exn/ipex/agree" => Icons.Material.Filled.Handshake,
        "/multisig/iss" => Icons.Material.Filled.GroupWork,
        "/multisig/icp" => Icons.Material.Filled.Groups,
        "/multisig/rot" => Icons.Material.Filled.RotateRight,
        "/multisig/exn" => Icons.Material.Filled.SwapHoriz,
        _ => Icons.Material.Filled.Notifications
    };

    // Mark-all-as-read state
    bool IsMarkingAll { get; set; }
    int MarkAllProgress { get; set; }
    int MarkAllTotal { get; set; }

    // Deferred-render gate: keep the heavy notification list out of the first synchronous render
    // so navigation feels snappy. Blazor doesn't paint until OnInitializedAsync completes AND the
    // first synchronous render builds the entire DOM. With ~77 notifications each rendering several
    // MudBlazor components, that single render can block the UI for noticeable time. The first render
    // shows page chrome + a spinner; OnAfterRenderAsync flips this flag and triggers a second render
    // for the list. End-to-end render time is similar, but perceived navigation latency drops sharply.
    bool _renderContent;

    protected override async Task OnInitializedAsync() {
        logger.LogInformation("OnInitializedAsync");
        InitializeAppCache(appCache);
        await this.SubscribeToAppCache(appCache);

        // Request BW to start notification burst polling (if not already active).
        // Fire-and-forget: App observes updated notifications via CachedNotifications storage observer.
        try {
            await appBwPortService.SendEventAsync(AppBwMessageType.Values.RequestPollNotifications);
        }
        catch (Exception ex) {
            logger.LogWarning(ex, "Failed to send RequestPollNotifications event");
        }
    }

    protected override void OnAfterRender(bool firstRender) {
        if (firstRender && !_renderContent) {
            _renderContent = true;
            StateHasChanged();
        }
    }

    async Task OnViewDefChanged(string newId) {
        var updatedIds = new Dictionary<string, string>(appCache.MyPreferences.SelectedViewDefIds)
        {
            [nameof(NotificationsPage)] = newId
        };
        await storageGateway.SetItem(appCache.MyPreferences with { SelectedViewDefIds = updatedIds });
    }

    async Task MarkAsRead(Notification notification) {
        if (IsProcessing) return;
        IsProcessing = true;

        var notifId = notification.Id;
        try {
            // Fire-and-forget: BW marks the notification in KERIA and refreshes CachedNotifications.
            // App observes the update via storage observer.
            await appBwPortService.SendEventAsync(
                AppBwMessageType.Values.RequestMarkNotification,
                new { said = notifId });

            await appCache.WaitForAppCache([
                () => appCache.MyNotifications.Items.Any(n => n.Id == notifId && n.IsRead)
            ]);
            snackbar.Add("Marked as read", Severity.Info);
        }
        catch (Exception ex) {
            logger.LogError(ex, "Error marking notification as read");
            snackbar.Add("Error marking notification", Severity.Error);
        }
        finally {
            IsProcessing = false;
        }
    }

    async Task DeleteNotification(Notification notification) {
        if (IsProcessing) return;
        IsProcessing = true;

        var notifId = notification.Id;
        try {
            // Fire-and-forget: BW deletes the notification in KERIA and refreshes CachedNotifications.
            // App observes the update via storage observer.
            await appBwPortService.SendEventAsync(
                AppBwMessageType.Values.RequestDeleteNotification,
                new { said = notifId });

            await appCache.WaitForAppCache([
                () => !appCache.MyNotifications.Items.Any(n => n.Id == notifId)
            ]);
            snackbar.Add("Notification deleted", Severity.Info);
        }
        catch (Exception ex) {
            logger.LogError(ex, "Error deleting notification");
            snackbar.Add("Error deleting notification", Severity.Error);
        }
        finally {
            IsProcessing = false;
        }
    }

    async Task MarkAllAsRead() {
        var unread = AllNotifications.Where(n => !n.IsRead).ToList();
        if (unread.Count == 0 || IsMarkingAll) return;

        IsMarkingAll = true;
        MarkAllProgress = 0;
        MarkAllTotal = unread.Count;

        try {
            foreach (var n in unread) {
                // Fire-and-forget per notification. Progress bar advances as each event is sent;
                // actual storage updates arrive asynchronously via CachedNotifications observer.
                try {
                    await appBwPortService.SendEventAsync(
                        AppBwMessageType.Values.RequestMarkNotification,
                        new { said = n.Id });
                }
                catch (Exception sendEx) {
                    logger.LogWarning(sendEx, "MarkAllAsRead: Failed to send event for {Id}", n.Id);
                }
                MarkAllProgress++;
                await InvokeAsync(StateHasChanged);
            }
            snackbar.Add($"Marked {MarkAllTotal} as read", Severity.Info);
        }
        catch (Exception ex) {
            logger.LogError(ex, "Error during mark all as read");
            snackbar.Add("Error marking notifications", Severity.Error);
        }
        finally {
            IsMarkingAll = false;
        }
    }

    public void Dispose() {
        this.UnsubscribeFromAppCache();
        GC.SuppressFinalize(this);
    }
}

<div id="@this.GetType().Name" class="bt-body-page">
    <MudStack Class="bt-main">
        <div class="bt-main-inside-scroll">
            <PageHeading Title="Notifications" InfoTooltip="" />
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <ViewSelector T="Notification"
                              ViewDefs="@NotificationViewDefs"
                              SelectedViewDefId="@selectedViewDefId"
                              SelectedViewDefIdChanged="@OnViewDefChanged"
                              FilteredCount="@(IsFilteredCountLoading ? null : ViewDefFilteredNotifications.Count)"
                              SubtotalCount="@(IsSubtotalCountLoading ? null : SubtotalCount)"
                              TotalCount="@(IsNotificationsLoading ? null : AllNotifications.Count)" />
                <MudSpacer />
                @if (UnreadCount > 0 && !IsMarkingAll)
                {
                    <MudButton Variant="Variant.Text"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.DoneAll"
                               OnClick="MarkAllAsRead"
                               Disabled="@IsProcessing">
                        Mark all read
                    </MudButton>
                }
            </MudStack>

            @if (IsMarkingAll)
            {
                <MudProgressLinear Value="@MarkAllProgress" Max="@MarkAllTotal" Color="Color.Primary" Class="my-1" />
            }

            @if (ViewDefFilteredNotifications.Count > 0)
            {
                <MudStack Row="true" Spacing="2" Class="mt-1">
                    <MudSelect T="string" Label="Route" Value="@FilterRoute" ValueChanged="@(v => FilterRoute = v)"
                               Dense="true" Margin="Margin.Dense" Variant="Variant.Outlined"
                               Style="min-width: 160px;">
                        <MudSelectItem T="string" Value="@((string?)null)">All</MudSelectItem>
                        @foreach (var route in AvailableRoutes)
                        {
                            <MudSelectItem T="string" Value="@route">@RouteLabel(route)</MudSelectItem>
                        }
                    </MudSelect>
                    <MudSelect T="bool?" Label="Status" Value="@FilterReadStatus" ValueChanged="@(v => FilterReadStatus = v)"
                               Dense="true" Margin="Margin.Dense" Variant="Variant.Outlined"
                               Style="min-width: 120px;">
                        <MudSelectItem T="bool?" Value="@((bool?)null)">All</MudSelectItem>
                        <MudSelectItem T="bool?" Value="@((bool?)false)">Unread</MudSelectItem>
                        <MudSelectItem T="bool?" Value="@((bool?)true)">Read</MudSelectItem>
                    </MudSelect>
                </MudStack>
            }

            @if (!_renderContent)
            {
                <div style="display:flex; align-items:center; justify-content:center; padding: 48px;">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                </div>
            }
            else if (!FilteredNotifications.Any())
            {
                <MudAlert Severity="Severity.Info" Class="mt-4">
                    @(IsFiltering ? "No notifications match the current filters." : "No notifications.")
                </MudAlert>
            }

            @if (_renderContent)
            {
            @foreach (var n in FilteredNotifications)
            {
                var prefixes = appCache.GetExchangePrefixes(n.ExchangeSaid);
                <MudCard Elevation="0" Class="py-0 my-1">
                    <div class="d-flex align-center bt-notif-row bt-clickable"
                         @onclick="@(() => navManager.NavigateTo($"{Routes.Paths.Notification}?id={n.Id}"))">
                        <div class="d-flex align-center bt-notif-aids">
                            <AidPrefixDisplay Prefix="@(prefixes.Sender ?? "")"
                                              TextPosition="AidPrefixDisplay.TextSide.Left"
                                              ShowCopyButton="false" />
                            <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Class="bt-notif-arrow" />
                            <AidPrefixDisplay Prefix="@(prefixes.Target ?? "")"
                                              ShowCopyButton="false" />
                        </div>
                        <div class="bt-notif-details">
                            <MudText Typo="@(n.IsRead ? Typo.body1 : Typo.h6)">@RouteLabel(n.Route, n)</MudText>
                            <MudText Typo="Typo.caption">@n.DateTime</MudText>
                            <MudTooltip Text="@n.Id" Delay="300">
                                <MudText Typo="Typo.caption">@Elide(n.Id, 6, 4)</MudText>
                            </MudTooltip>
                        </div>
                        @if (!n.IsRead)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text">Unread</MudChip>
                        }
                        <span @onclick:stopPropagation="true">
                            <MudMenu Icon="@Icons.Material.Filled.MoreVert" Dense="true" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                                @if (!n.IsRead)
                                {
                                    <MudMenuItem OnClick="@(() => MarkAsRead(n))" Icon="@Icons.Material.Filled.MarkEmailRead" Disabled="@IsProcessing">Mark as Read</MudMenuItem>
                                }
                                <MudMenuItem OnClick="@(() => DeleteNotification(n))" Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" Disabled="@IsProcessing">Delete</MudMenuItem>
                            </MudMenu>
                        </span>
                    </div>
                </MudCard>
            }
            }

            @if (IsProcessing)
            {
                <div style="display:flex; align-items: center; justify-content:center; padding: 24px;">
                    <MudProgressCircular Color="Color.Default" Indeterminate="true" />
                </div>
            }
        </div>
    </MudStack>
    <MudStack Row="true" class="bt-button-tray">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBackIosNew" Variant="Variant.Text" OnClick='@(async () => await Helper.PreviousPage.GoBack(js))' Class="justify-start" />
        <MudSpacer />
    </MudStack>
</div>
