@page "/Notifications.html"
@using Extension.Models
@using Extension.Models.Messages.AppBw
@using Extension.Services.SignifyService.Models
@using Extension.Services.Storage
@using Extension.Services.Port
@using Extension.UI.Components
@inherits AuthenticatedPageBase
@implements IDisposable

@inject ILogger<NotificationsPage> logger
@inject IStorageGateway storageGateway
@inject IJSRuntime js
@inject ISnackbar snackbar
@inject AppCache appCache
@inject IAppBwPortService appBwPortService
@inject IDialogService dialogService

@code {
    bool IsProcessing { get; set; }
    bool IsNotificationsLoading => appCache.MyPollingState.NotificationsLastFetchedUtc is null;
    string selectedViewDefId =>
        appCache.MyPreferences.SelectedViewDefIds.TryGetValue(nameof(NotificationsPage), out var savedId) && NotificationViewDefs.Any(v => v.Id == savedId)
            ? savedId
            : ViewDefIds.NotifAll;

    List<Notification> AllNotifications => appCache?.MyNotifications?.Items ?? [];

    int UnreadCount => AllNotifications.Count(n => !n.IsRead);

    // ViewDef
    List<FilterSet<Notification>> ProfileSubtotalFilterSets =>
    [
        new("Target", [(Notification n) => n.TargetPrefix == appCache.SelectedPrefix]),
        new("Sender", [(Notification n) => n.SenderPrefix == appCache.SelectedPrefix])
    ];

    List<ViewDef<Notification>> NotificationViewDefs =>
    [
        new(ViewDefIds.NotifTarget, "Target (active profile)",
            FilterSets: [new("Target", [(Notification n) => n.TargetPrefix == appCache.SelectedPrefix])],
            SubtotalFilterSets: ProfileSubtotalFilterSets,
            CountStyle: CountStyle.OfSubTotal,
            SortSets: [new("DateTime", [new SortExpression<Notification>(n => n.DateTime, Descending: true)])]),

        new(ViewDefIds.NotifSender, "Sender (active profile)",
            FilterSets: [new("Sender", [(Notification n) => n.SenderPrefix == appCache.SelectedPrefix])],
            SubtotalFilterSets: ProfileSubtotalFilterSets,
            CountStyle: CountStyle.OfSubTotal,
            SortSets: [new("DateTime", [new SortExpression<Notification>(n => n.DateTime, Descending: true)])]),

        new(ViewDefIds.NotifUnreadProfile, "Unread (active profile)",
            FilterSets: [new("Target", [(Notification n) => n.TargetPrefix == appCache.SelectedPrefix && !n.IsRead]),
                         new("Sender", [(Notification n) => n.SenderPrefix == appCache.SelectedPrefix && !n.IsRead])],
            SubtotalFilterSets: ProfileSubtotalFilterSets,
            CountStyle: CountStyle.OfSubTotal,
            SortSets: [new("DateTime", [new SortExpression<Notification>(n => n.DateTime, Descending: true)])]),

        new(ViewDefIds.NotifProfile, "All (active profile)",
            FilterSets: [new("Target", [(Notification n) => n.TargetPrefix == appCache.SelectedPrefix]),
                         new("Sender", [(Notification n) => n.SenderPrefix == appCache.SelectedPrefix])],
            SubtotalFilterSets: ProfileSubtotalFilterSets,
            CountStyle: CountStyle.OfSubTotal,
            SortSets: [new("DateTime", [new SortExpression<Notification>(n => n.DateTime, Descending: true)])]),
        
        new(ViewDefIds.NotifUnreadAll, "All unread",
            FilterSets: [new("Unread", [(Notification n) => !n.IsRead])],
            CountStyle: CountStyle.Total,
            SortSets: [new("DateTime", [new SortExpression<Notification>(n => n.DateTime, Descending: true)])]),
        
        new(ViewDefIds.NotifAll, "All",
            CountStyle: CountStyle.Total,
            SortSets: [new("DateTime", [new SortExpression<Notification>(n => n.DateTime, Descending: true)])])
    ];

    ViewDef<Notification>? SelectedViewDef => NotificationViewDefs.FirstOrDefault(v => v.Id == selectedViewDefId);

    // ViewDef-filtered list (profile-based filtering + sorting)
    List<Notification> ViewDefFilteredNotifications => ViewDefHelper.Apply(AllNotifications, SelectedViewDef);

    int? SubtotalCount => SelectedViewDef?.SubtotalFilterSets is { Count: > 0 }
        ? ViewDefHelper.ApplySubtotalCount(AllNotifications, SelectedViewDef)
        : (int?)null;

    // Route/ReadStatus filtering state (composes on top of ViewDef)
    string? FilterRoute { get; set; }
    bool? FilterReadStatus { get; set; }

    List<string> AvailableRoutes => ViewDefFilteredNotifications
        .Select(n => n.Route)
        .Where(r => !string.IsNullOrEmpty(r))
        .Distinct()
        .OrderBy(r => r)
        .ToList();

    List<Notification> FilteredNotifications {
        get {
            IEnumerable<Notification> filtered = ViewDefFilteredNotifications;
            if (FilterRoute is not null) {
                filtered = filtered.Where(n => n.Route == FilterRoute);
            }
            if (FilterReadStatus is not null) {
                filtered = filtered.Where(n => n.IsRead == FilterReadStatus.Value);
            }
            return filtered.ToList();
        }
    }

    bool IsFiltering => FilterRoute is not null || FilterReadStatus is not null;


    List<Connection> AllConnections => appCache?.MyConnections ?? [];

    string ResolveName(string? prefix) {
        if (prefix is null) return "(unknown)";
        var profile = appCache?.Aids?.FirstOrDefault(a => a.Prefix == prefix);
        if (profile is not null) return profile.Name;
        var conn = AllConnections.FirstOrDefault(c => c.ReceiverPrefix == prefix);
        if (conn is not null) return $"{conn.Name} (connection)";
        return "(unknown)";
    }

    // Lazy flow type cache: maps notification ID -> resolved IpexFlowType
    // TODO P3 refactor such caching into appCache or even stored, so display is instant
    Dictionary<string, IpexFlowType> _flowTypeCache = [];
    HashSet<string> _flowTypeFetching = [];

    string RouteLabel(string route, Notification? notification = null) {
        if (route == "/exn/ipex/apply") return "Credential Request \u2013 Apply";

        var ipexStep = route switch {
            "/exn/ipex/offer" => "Offer",
            "/exn/ipex/agree" => "Agree",
            "/exn/ipex/grant" => "Grant",
            "/exn/ipex/admit" => "Admit",
            _ => null
        };
        if (ipexStep is not null) {
            if (notification is not null && _flowTypeCache.TryGetValue(notification.Id, out var cachedFlow)) {
                var flowLabel = cachedFlow switch {
                    IpexFlowType.Issuance => "Credential Issuance",
                    IpexFlowType.Presentation => "Credential Presentation",
                    _ => "Credential"
                };
                return $"{flowLabel} \u2013 {ipexStep}";
            }
            if (notification is not null) {
                _ = ResolveFlowTypeLazy(notification);
            }
            return $"Credential \u2013 {ipexStep}";
        }
        return route switch {
            "/multisig/iss" => "Multisig Issuance",
            "/multisig/icp" => "Multisig Inception",
            "/multisig/rot" => "Multisig Rotation",
            "/multisig/exn" => "Multisig Exchange",
            _ => route
        };
    }

    async Task ResolveFlowTypeLazy(Notification notification) {
        if (_flowTypeCache.ContainsKey(notification.Id)) return;
        if (!_flowTypeFetching.Add(notification.Id)) return; // already in flight

        try {
            if (notification.ExchangeSaid is null) return;

            var response = await appBwPortService.SendRpcRequestAsync(
                AppBwMessageType.Values.RequestGetExchange,
                new { payload = new { said = notification.ExchangeSaid } });

            if (!response.Ok || response.Result is not JsonElement jsonEl) return;

            var exchangeResult = JsonSerializer.Deserialize<GetExchangeResponsePayload>(
                jsonEl.GetRawText(), Helper.JsonOptions.PortMessaging);
            if (exchangeResult?.Success != true || exchangeResult.Exchange is null) return;

            var view = ExchangeView.FromRecursiveDictionary(exchangeResult.Exchange);

            // Approach B: infer from embedded ACDC (works for Offer/Grant)
            var flowType = ExchangeView.InferFlowFromAcdc(view.I, view.E);

            // If unknown, try prior chain (for Agree/Admit)
            if (flowType == IpexFlowType.Unknown && view.P is not null) {
                flowType = await ResolveFlowTypeFromPrior(view.P);
            }

            _flowTypeCache[notification.Id] = flowType;
            StateHasChanged();
        }
        catch (Exception ex) {
            logger.LogWarning(ex, "Error resolving flow type for notification {Id}", notification.Id);
        }
        finally {
            _flowTypeFetching.Remove(notification.Id);
        }
    }

    async Task<IpexFlowType> ResolveFlowTypeFromPrior(string priorSaid) {
        try {
            var response = await appBwPortService.SendRpcRequestAsync(
                AppBwMessageType.Values.RequestGetExchange,
                new { payload = new { said = priorSaid } });

            if (!response.Ok || response.Result is not JsonElement priorJson) return IpexFlowType.Unknown;

            var priorPayload = JsonSerializer.Deserialize<GetExchangeResponsePayload>(
                priorJson.GetRawText(), Helper.JsonOptions.PortMessaging);
            if (priorPayload?.Success != true || priorPayload.Exchange is null) return IpexFlowType.Unknown;

            var priorView = ExchangeView.FromRecursiveDictionary(priorPayload.Exchange);
            return ExchangeView.InferFlowFromAcdc(priorView.I, priorView.E);
        }
        catch {
            return IpexFlowType.Unknown;
        }
    }

    static string RouteIcon(string route) => route switch {
        "/exn/ipex/grant" => Icons.Material.Filled.CardGiftcard,
        "/exn/ipex/admit" => Icons.Material.Filled.CheckCircle,
        "/exn/ipex/apply" => Icons.Material.Filled.Assignment,
        "/exn/ipex/offer" => Icons.Material.Filled.LocalOffer,
        "/exn/ipex/agree" => Icons.Material.Filled.Handshake,
        "/multisig/iss" => Icons.Material.Filled.GroupWork,
        "/multisig/icp" => Icons.Material.Filled.Groups,
        "/multisig/rot" => Icons.Material.Filled.RotateRight,
        "/multisig/exn" => Icons.Material.Filled.SwapHoriz,
        _ => Icons.Material.Filled.Notifications
    };

    // Mark-all-as-read state
    bool IsMarkingAll { get; set; }
    int MarkAllProgress { get; set; }
    int MarkAllTotal { get; set; }

    // Expansion state
    string? ExpandedNotificationId { get; set; }
    ExchangeView? ExpandedExchangeData { get; set; }
    bool IsLoadingExchange { get; set; }
    string? ExchangeLoadError { get; set; }
    bool IsAdmitting { get; set; }
    bool IsAlreadyAdmitted { get; set; }
    bool IsAgreeing { get; set; }
    bool IsAlreadyAgreed { get; set; }
    HashSet<string> _agreedOfferSaids = [];
    bool IsOffering { get; set; }
    bool IsAlreadyOffered { get; set; }
    HashSet<string> _offeredApplySaids = [];
    bool IsGranting { get; set; }
    bool IsAlreadyGranted { get; set; }
    HashSet<string> _grantedAgreeSaids = [];
    HashSet<string> _grantedApplySaids = [];
    bool IsGrantingPresentation { get; set; }
    bool IsOfferingPresentation { get; set; }
    bool IsLoadingPrior { get; set; }

    protected override async Task OnInitializedAsync() {
        logger.LogInformation("OnInitializedAsync");
        InitializeAppCache(appCache);
        await this.SubscribeToAppCache(appCache);

        // Request BW to start notification burst polling (if not already active).
        // Fire-and-forget: App observes updated notifications via CachedNotifications storage observer.
        try {
            await appBwPortService.SendEventAsync(AppBwMessageType.Values.RequestPollNotifications);
        }
        catch (Exception ex) {
            logger.LogWarning(ex, "Failed to send RequestPollNotifications event");
        }
    }

    async Task OnViewDefChanged(string newId) {
        var updatedIds = new Dictionary<string, string>(appCache.MyPreferences.SelectedViewDefIds)
        {
            [nameof(NotificationsPage)] = newId
        };
        await storageGateway.SetItem(appCache.MyPreferences with { SelectedViewDefIds = updatedIds });
    }

    async Task ToggleNotificationDetail(Notification notification) {
        if (ExpandedNotificationId == notification.Id) {
            ExpandedNotificationId = null;
            ExpandedExchangeData = null;
            ExchangeLoadError = null;
            return;
        }

        ExpandedNotificationId = notification.Id;
        ExpandedExchangeData = null;
        ExchangeLoadError = null;
        IsAlreadyAdmitted = false;
        IsAlreadyAgreed = notification.Route == "/exn/ipex/offer"
            && notification.ExchangeSaid is not null
            && _agreedOfferSaids.Contains(notification.ExchangeSaid);
        IsAlreadyOffered = notification.Route == "/exn/ipex/apply"
            && notification.ExchangeSaid is not null
            && _offeredApplySaids.Contains(notification.ExchangeSaid);
        IsAlreadyGranted = notification.ExchangeSaid is not null
            && ((notification.Route == "/exn/ipex/agree" && _grantedAgreeSaids.Contains(notification.ExchangeSaid))
                || (notification.Route == "/exn/ipex/apply" && _grantedApplySaids.Contains(notification.ExchangeSaid)));
        IsLoadingPrior = false;

        if (notification.ExchangeSaid is null) {
            ExchangeLoadError = "No exchange SAID available";
            return;
        }

        IsLoadingExchange = true;

        try {
            // Cache-first: check AppCache for previously fetched exchange
            RecursiveDictionary? exchange = null;
            if (appCache.MyCachedExns.TryGetValue(notification.ExchangeSaid, out var cachedRawJson)) {
                exchange = JsonSerializer.Deserialize<RecursiveDictionary>(cachedRawJson, JsonOptions.RecursiveDictionary);
            }

            if (exchange is null) {
                // Cache miss: fetch via RPC (BackgroundWorker will cache it)
                var response = await appBwPortService.SendRpcRequestAsync(
                    AppBwMessageType.Values.RequestGetExchange,
                    new { payload = new { said = notification.ExchangeSaid } });

                if (!response.Ok) {
                    ExchangeLoadError = response.Error ?? "Failed to load exchange details";
                    return;
                }

                var exchangeResult = response.Result is JsonElement jsonEl
                    ? JsonSerializer.Deserialize<GetExchangeResponsePayload>(jsonEl.GetRawText(), Helper.JsonOptions.PortMessaging)
                    : null;

                if (exchangeResult is not null && exchangeResult.Success && exchangeResult.Exchange is not null) {
                    exchange = exchangeResult.Exchange;
                }
                else {
                    ExchangeLoadError = exchangeResult?.Error ?? "Unknown error loading exchange";
                    return;
                }
            }

            if (exchange is not null) {
                ExpandedExchangeData = ExchangeView.FromRecursiveDictionary(exchange);

                // For grant notifications, check if credential has already been admitted
                if (notification.Route == "/exn/ipex/grant") {
                    var credSaid = ExpandedExchangeData.Value.E?.GetValueByPath("acdc.d")?.Value?.ToString();
                    if (credSaid is not null) {
                        IsAlreadyAdmitted = appCache.MyCachedCredentials.Any(c =>
                            c.GetValueByPath("sad.d")?.Value?.ToString() == credSaid);
                    }

                    if (IsAlreadyAdmitted && !notification.IsRead) {
                        _ = MarkAsRead(notification);
                    }
                }

            }
        }
        catch (Exception ex) {
            logger.LogError(ex, "Error fetching exchange details");
            ExchangeLoadError = "Error loading exchange details";
        }
        finally {
            IsLoadingExchange = false;
        }
    }

    async Task AdmitCredential(Notification notification) {
        if (IsAdmitting || ExpandedExchangeData is null) return;

        var view = ExpandedExchangeData.Value;
        var issuerPrefix = view.I;
        var recipientPrefix = view.Rp;

        // Validate the recipient is one of our AIDs
        if (recipientPrefix is null || !appCache.Aids.Any(a => a.Prefix == recipientPrefix)) {
            snackbar.Add("Could not find matching AID for this grant", Severity.Error);
            return;
        }

        if (notification.ExchangeSaid is null || issuerPrefix is null) {
            snackbar.Add("Missing exchange data for admit", Severity.Error);
            return;
        }

        IsAdmitting = true;

        try {
            var response = await appBwPortService.SendRpcRequestAsync(
                AppBwMessageType.Values.RequestIpexAdmit,
                new { payload = new IpexAdmitRequestPayload(
                    SenderNameOrPrefix: recipientPrefix,
                    RecipientPrefix: issuerPrefix,
                    GrantSaid: notification.ExchangeSaid) },
                timeout: TimeSpan.FromMinutes(2));

            if (!response.Ok) {
                snackbar.Add($"Admit failed: {response.Error}", Severity.Error);
                return;
            }

            var admitResult = response.Result is JsonElement admitJsonEl
                ? JsonSerializer.Deserialize<IpexAdmitResponsePayload>(admitJsonEl.GetRawText(), Helper.JsonOptions.PortMessaging)
                : null;

            if (admitResult is not null && admitResult.Success) {
                IsAlreadyAdmitted = true;
                snackbar.Add("Credential admitted", Severity.Success);
                if (!notification.IsRead) {
                    await MarkAsRead(notification);
                }
            }
            else {
                snackbar.Add($"Admit failed: {admitResult?.Error ?? "Unknown error"}", Severity.Error);
            }
        }
        catch (Exception ex) {
            logger.LogError(ex, "Error during IPEX admit");
            snackbar.Add("Error admitting credential", Severity.Error);
        }
        finally {
            IsAdmitting = false;
        }
    }

    async Task AgreeToOffer(Notification notification) {
        if (IsAgreeing || ExpandedExchangeData is null) return;

        var view = ExpandedExchangeData.Value;
        var offerSenderPrefix = view.I;
        var userPrefix = view.Rp;

        if (userPrefix is null || !appCache.Aids.Any(a => a.Prefix == userPrefix)) {
            snackbar.Add("Could not find matching AID for this offer", Severity.Error);
            return;
        }

        if (notification.ExchangeSaid is null || offerSenderPrefix is null) {
            snackbar.Add("Missing exchange data for agree", Severity.Error);
            return;
        }

        IsAgreeing = true;

        try {
            var response = await appBwPortService.SendRpcRequestAsync(
                AppBwMessageType.Values.RequestIpexAgree,
                new { payload = new IpexAgreeRequestPayload(
                    SenderNameOrPrefix: userPrefix,
                    RecipientPrefix: offerSenderPrefix,
                    OfferSaid: notification.ExchangeSaid) },
                timeout: TimeSpan.FromMinutes(2));

            if (!response.Ok) {
                snackbar.Add($"Agree failed: {response.Error}", Severity.Error);
                return;
            }

            var agreeResult = response.Result is JsonElement agreeJsonEl
                ? JsonSerializer.Deserialize<IpexAgreeResponsePayload>(agreeJsonEl.GetRawText(), Helper.JsonOptions.PortMessaging)
                : null;

            if (agreeResult is not null && agreeResult.Success) {
                if (notification.ExchangeSaid is not null) _agreedOfferSaids.Add(notification.ExchangeSaid);
                IsAlreadyAgreed = true;
                snackbar.Add("Agreed to offer", Severity.Success);
                if (!notification.IsRead) {
                    await MarkAsRead(notification);
                }
            }
            else {
                snackbar.Add($"Agree failed: {agreeResult?.Error ?? "Unknown error"}", Severity.Error);
            }
        }
        catch (Exception ex) {
            logger.LogError(ex, "Error during IPEX agree");
            snackbar.Add("Error agreeing to offer", Severity.Error);
        }
        finally {
            IsAgreeing = false;
        }
    }

    async Task OfferCredential(Notification notification) {
        if (IsOffering || ExpandedExchangeData is null) return;

        var view = ExpandedExchangeData.Value;

        // Show confirmation dialog
        var parameters = new DialogParameters<OfferCredentialDialog>
        {
            { x => x.ApplyExchange, view }
        };
        var options = new DialogOptions {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            BackdropClick = false,
            CloseButton = true,
            Position = DialogPosition.Center,
        };
        var dialog = await dialogService.ShowAsync<OfferCredentialDialog>("Offer credential", parameters, options);
        var dialogResult = await dialog.Result;

        if (dialogResult is null || dialogResult.Canceled) return;

        // Extract Apply data: I = applicant (holder), Rp = our AID (issuer)
        var applicantPrefix = view.I;
        var ourPrefix = view.Rp;
        var applySaid = notification.ExchangeSaid;

        // Extract role from Apply attributes
        var ecrRole = view.A?.GetValueByPath("a.engagementContextRole")?.Value?.ToString();

        if (ourPrefix is null || applicantPrefix is null || applySaid is null || ecrRole is null) {
            snackbar.Add("Missing data from Apply exchange", Severity.Error);
            return;
        }

        IsOffering = true;

        try {
            var response = await appBwPortService.SendRpcRequestAsync(
                AppBwMessageType.Values.RequestIpexOffer,
                new { payload = new IpexOfferRequestPayload(
                    SenderNameOrPrefix: ourPrefix,
                    RecipientPrefix: applicantPrefix,
                    ApplySaid: applySaid,
                    EcrRole: ecrRole) },
                timeout: TimeSpan.FromMinutes(3));

            if (!response.Ok) {
                snackbar.Add($"Offer failed: {response.Error}", Severity.Error);
                return;
            }

            var offerResult = response.Result is JsonElement offerJsonEl
                ? JsonSerializer.Deserialize<IpexOfferResponsePayload>(offerJsonEl.GetRawText(), Helper.JsonOptions.PortMessaging)
                : null;

            if (offerResult is not null && offerResult.Success) {
                if (notification.ExchangeSaid is not null) _offeredApplySaids.Add(notification.ExchangeSaid);
                IsAlreadyOffered = true;
                snackbar.Add("Credential offered", Severity.Success);
                if (!notification.IsRead) {
                    await MarkAsRead(notification);
                }
            }
            else {
                snackbar.Add($"Offer failed: {offerResult?.Error ?? "Unknown error"}", Severity.Error);
            }
        }
        catch (Exception ex) {
            logger.LogError(ex, "Error during IPEX offer");
            snackbar.Add("Error offering credential", Severity.Error);
        }
        finally {
            IsOffering = false;
        }
    }

    async Task GrantFromNotification(Notification notification) {
        if (notification.Route == "/exn/ipex/apply") {
            await GrantCredentialFromApply(notification);
        } else {
            await GrantCredential(notification);
        }
    }

    async Task GrantCredentialFromApply(Notification notification) {
        if (IsGranting || ExpandedExchangeData is null) return;

        var view = ExpandedExchangeData.Value;
        var applicantPrefix = view.I;
        var ourPrefix = view.Rp;
        var applySaid = notification.ExchangeSaid;
        var ecrRole = view.A?.GetValueByPath("a.engagementContextRole")?.Value?.ToString();

        if (ourPrefix is null || applicantPrefix is null || applySaid is null || ecrRole is null) {
            snackbar.Add("Missing data from Apply exchange", Severity.Error);
            return;
        }

        if (!appCache.Aids.Any(a => a.Prefix == ourPrefix)) {
            snackbar.Add("Could not find matching AID for this apply", Severity.Error);
            return;
        }

        IsGranting = true;

        try {
            var response = await appBwPortService.SendRpcRequestAsync(
                AppBwMessageType.Values.RequestIpexGrant,
                new { payload = new IpexGrantRequestPayload(
                    SenderNameOrPrefix: ourPrefix,
                    RecipientPrefix: applicantPrefix,
                    ApplySaid: applySaid,
                    EcrRole: ecrRole) },
                timeout: TimeSpan.FromMinutes(3));

            if (!response.Ok) {
                snackbar.Add($"Grant failed: {response.Error}", Severity.Error);
                return;
            }

            var grantResult = response.Result is JsonElement grantJsonEl
                ? JsonSerializer.Deserialize<IpexGrantResponsePayload>(grantJsonEl.GetRawText(), Helper.JsonOptions.PortMessaging)
                : null;

            if (grantResult is not null && grantResult.Success) {
                if (notification.ExchangeSaid is not null) _grantedApplySaids.Add(notification.ExchangeSaid);
                IsAlreadyGranted = true;
                snackbar.Add("Credential granted", Severity.Success);
                if (!notification.IsRead) {
                    await MarkAsRead(notification);
                }
            }
            else {
                snackbar.Add($"Grant failed: {grantResult?.Error ?? "Unknown error"}", Severity.Error);
            }
        }
        catch (Exception ex) {
            logger.LogError(ex, "Error during IPEX grant from apply");
            snackbar.Add("Error granting credential", Severity.Error);
        }
        finally {
            IsGranting = false;
        }
    }

    async Task GrantCredential(Notification notification) {
        if (IsGranting || ExpandedExchangeData is null) return;

        var view = ExpandedExchangeData.Value;
        var agreeSenderPrefix = view.I;
        var ourPrefix = view.Rp;

        if (ourPrefix is null || !appCache.Aids.Any(a => a.Prefix == ourPrefix)) {
            snackbar.Add("Could not find matching AID for this agree", Severity.Error);
            return;
        }

        if (notification.ExchangeSaid is null || agreeSenderPrefix is null) {
            snackbar.Add("Missing exchange data for grant", Severity.Error);
            return;
        }

        IsGranting = true;

        try {
            var response = await appBwPortService.SendRpcRequestAsync(
                AppBwMessageType.Values.RequestIpexGrant,
                new { payload = new IpexGrantRequestPayload(
                    SenderNameOrPrefix: ourPrefix,
                    RecipientPrefix: agreeSenderPrefix,
                    AgreeSaid: notification.ExchangeSaid) },
                timeout: TimeSpan.FromMinutes(3));

            if (!response.Ok) {
                snackbar.Add($"Grant failed: {response.Error}", Severity.Error);
                return;
            }

            var grantResult = response.Result is JsonElement grantJsonEl
                ? JsonSerializer.Deserialize<IpexGrantResponsePayload>(grantJsonEl.GetRawText(), Helper.JsonOptions.PortMessaging)
                : null;

            if (grantResult is not null && grantResult.Success) {
                if (notification.ExchangeSaid is not null) _grantedAgreeSaids.Add(notification.ExchangeSaid);
                IsAlreadyGranted = true;
                snackbar.Add("Credential granted", Severity.Success);
                if (!notification.IsRead) {
                    await MarkAsRead(notification);
                }
            }
            else {
                snackbar.Add($"Grant failed: {grantResult?.Error ?? "Unknown error"}", Severity.Error);
            }
        }
        catch (Exception ex) {
            logger.LogError(ex, "Error during IPEX grant");
            snackbar.Add("Error granting credential", Severity.Error);
        }
        finally {
            IsGranting = false;
        }
    }

    Task GrantPresentationFromNotification(Notification notification) =>
        PresentationFromNotification(notification, isOffer: false);

    Task OfferPresentationFromNotification(Notification notification) =>
        PresentationFromNotification(notification, isOffer: true);

    async Task PresentationFromNotification(Notification notification, bool isOffer) {
        if (IsGrantingPresentation || IsOfferingPresentation || ExpandedExchangeData is null) return;

        var view = ExpandedExchangeData.Value;
        var actionLabel = isOffer ? "Offer" : "Grant";

        var parameters = new DialogParameters<OfferOrGrantPresentationDialog>
        {
            { x => x.ApplyExchange, view },
            { x => x.IsOffer, isOffer }
        };
        var options = new DialogOptions {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            BackdropClick = false,
            CloseButton = true,
            Position = DialogPosition.Center,
        };
        var dialog = await dialogService.ShowAsync<OfferOrGrantPresentationDialog>($"{actionLabel} Presentation", parameters, options);
        var dialogResult = await dialog.Result;

        if (dialogResult is null || dialogResult.Canceled) return;

        var presentationResult = dialogResult.Data as OfferOrGrantPresentationDialog.GrantPresentationResult;
        if (presentationResult is null) return;

        var ourPrefix = view.Rp;
        var verifierPrefix = view.I;
        var applySaid = notification.ExchangeSaid;

        if (ourPrefix is null || verifierPrefix is null || applySaid is null) {
            snackbar.Add("Missing data from Apply exchange", Severity.Error);
            return;
        }

        if (isOffer) IsOfferingPresentation = true;
        else IsGrantingPresentation = true;

        try {
            var response = await appBwPortService.SendRpcRequestAsync(
                AppBwMessageType.Values.RequestIpexGrantPresentation,
                new { payload = new IpexGrantPresentationRequestPayload(
                    SenderNameOrPrefix: ourPrefix,
                    RecipientPrefix: verifierPrefix,
                    ApplySaid: applySaid,
                    CredentialSaid: presentationResult.CredentialSaid,
                    ElisionMap: presentationResult.ElisionMap,
                    IsOffer: isOffer) },
                timeout: TimeSpan.FromMinutes(3));

            if (!response.Ok) {
                snackbar.Add($"{actionLabel} presentation failed: {response.Error}", Severity.Error);
                return;
            }

            var grantResult = response.Result is JsonElement grantJsonEl
                ? JsonSerializer.Deserialize<IpexGrantResponsePayload>(grantJsonEl.GetRawText(), Helper.JsonOptions.PortMessaging)
                : null;

            if (grantResult is not null && grantResult.Success) {
                if (notification.ExchangeSaid is not null) _grantedApplySaids.Add(notification.ExchangeSaid);
                IsAlreadyGranted = true;
                snackbar.Add($"Credential presentation {(isOffer ? "offered" : "granted")}", Severity.Success);
                if (!notification.IsRead) {
                    await MarkAsRead(notification);
                }
            }
            else {
                snackbar.Add($"{actionLabel} presentation failed: {grantResult?.Error ?? "Unknown error"}", Severity.Error);
            }
        }
        catch (Exception ex) {
            logger.LogError(ex, "Error during IPEX {Action} presentation", actionLabel);
            snackbar.Add($"Error {(isOffer ? "offering" : "granting")} credential presentation", Severity.Error);
        }
        finally {
            IsGrantingPresentation = false;
            IsOfferingPresentation = false;
        }
    }

    async Task MarkAsRead(Notification notification) {
        if (IsProcessing) return;
        IsProcessing = true;

        var notifId = notification.Id;
        try {
            // Fire-and-forget: BW marks the notification in KERIA and refreshes CachedNotifications.
            // App observes the update via storage observer.
            await appBwPortService.SendEventAsync(
                AppBwMessageType.Values.RequestMarkNotification,
                new { said = notifId });

            await appCache.WaitForAppCache([
                () => appCache.MyNotifications.Items.Any(n => n.Id == notifId && n.IsRead)
            ]);
            snackbar.Add("Marked as read", Severity.Info);
        }
        catch (Exception ex) {
            logger.LogError(ex, "Error marking notification as read");
            snackbar.Add("Error marking notification", Severity.Error);
        }
        finally {
            IsProcessing = false;
        }
    }

    async Task DeleteNotification(Notification notification) {
        if (IsProcessing) return;
        IsProcessing = true;

        var notifId = notification.Id;
        try {
            // Fire-and-forget: BW deletes the notification in KERIA and refreshes CachedNotifications.
            // App observes the update via storage observer.
            await appBwPortService.SendEventAsync(
                AppBwMessageType.Values.RequestDeleteNotification,
                new { said = notifId });

            await appCache.WaitForAppCache([
                () => !appCache.MyNotifications.Items.Any(n => n.Id == notifId)
            ]);
            snackbar.Add("Notification deleted", Severity.Info);
        }
        catch (Exception ex) {
            logger.LogError(ex, "Error deleting notification");
            snackbar.Add("Error deleting notification", Severity.Error);
        }
        finally {
            IsProcessing = false;
        }
    }

    async Task MarkAllAsRead() {
        var unread = AllNotifications.Where(n => !n.IsRead).ToList();
        if (unread.Count == 0 || IsMarkingAll) return;

        IsMarkingAll = true;
        MarkAllProgress = 0;
        MarkAllTotal = unread.Count;

        try {
            foreach (var n in unread) {
                // Fire-and-forget per notification. Progress bar advances as each event is sent;
                // actual storage updates arrive asynchronously via CachedNotifications observer.
                try {
                    await appBwPortService.SendEventAsync(
                        AppBwMessageType.Values.RequestMarkNotification,
                        new { said = n.Id });
                }
                catch (Exception sendEx) {
                    logger.LogWarning(sendEx, "MarkAllAsRead: Failed to send event for {Id}", n.Id);
                }
                MarkAllProgress++;
                await InvokeAsync(StateHasChanged);
            }
            snackbar.Add($"Marked {MarkAllTotal} as read", Severity.Info);
        }
        catch (Exception ex) {
            logger.LogError(ex, "Error during mark all as read");
            snackbar.Add("Error marking notifications", Severity.Error);
        }
        finally {
            IsMarkingAll = false;
        }
    }

    public void Dispose() {
        this.UnsubscribeFromAppCache();
        GC.SuppressFinalize(this);
    }
}

<div id="@this.GetType().Name" class="bt-body-page">
    <MudStack Class="bt-main">
        <div class="bt-main-inside-scroll">
            <PageHeading Title="Notifications" InfoTooltip="" />
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <ViewSelector T="Notification"
                              ViewDefs="@NotificationViewDefs"
                              SelectedViewDefId="@selectedViewDefId"
                              SelectedViewDefIdChanged="@OnViewDefChanged"
                              FilteredCount="@(IsNotificationsLoading ? null : ViewDefFilteredNotifications.Count)"
                              SubtotalCount="@(IsNotificationsLoading ? null : SubtotalCount)"
                              TotalCount="@(IsNotificationsLoading ? null : AllNotifications.Count)" />
                <MudSpacer />
                @if (UnreadCount > 0 && !IsMarkingAll)
                {
                    <MudButton Variant="Variant.Text"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.DoneAll"
                               OnClick="MarkAllAsRead"
                               Disabled="@IsProcessing">
                        Mark all read
                    </MudButton>
                }
            </MudStack>

            @if (IsMarkingAll)
            {
                <MudProgressLinear Value="@MarkAllProgress" Max="@MarkAllTotal" Color="Color.Primary" Class="my-1" />
            }

            @if (ViewDefFilteredNotifications.Count > 0)
            {
                <MudStack Row="true" Spacing="2" Class="mt-1">
                    <MudSelect T="string" Label="Route" Value="@FilterRoute" ValueChanged="@(v => FilterRoute = v)"
                               Dense="true" Margin="Margin.Dense" Variant="Variant.Outlined"
                               Style="min-width: 160px;">
                        <MudSelectItem T="string" Value="@((string?)null)">All</MudSelectItem>
                        @foreach (var route in AvailableRoutes)
                        {
                            <MudSelectItem T="string" Value="@route">@RouteLabel(route)</MudSelectItem>
                        }
                    </MudSelect>
                    <MudSelect T="bool?" Label="Status" Value="@FilterReadStatus" ValueChanged="@(v => FilterReadStatus = v)"
                               Dense="true" Margin="Margin.Dense" Variant="Variant.Outlined"
                               Style="min-width: 120px;">
                        <MudSelectItem T="bool?" Value="@((bool?)null)">All</MudSelectItem>
                        <MudSelectItem T="bool?" Value="@((bool?)false)">Unread</MudSelectItem>
                        <MudSelectItem T="bool?" Value="@((bool?)true)">Read</MudSelectItem>
                    </MudSelect>
                </MudStack>
            }

            @if (!FilteredNotifications.Any())
            {
                <MudAlert Severity="Severity.Info" Class="mt-4">
                    @(IsFiltering ? "No notifications match the current filters." : "No notifications.")
                </MudAlert>
            }

            @foreach (var n in FilteredNotifications)
            {
                <MudCard Elevation="0" Class="py-0 my-1">
                    <div class="d-flex align-center bt-notif-row"
                         @onclick="@(() => ToggleNotificationDetail(n))">
                        <div class="d-flex align-center bt-notif-aids">
                            <AidPrefixDisplay Prefix="@(n.SenderPrefix ?? "")"
                                              Name="@ResolveName(n.SenderPrefix)"
                                              TextPosition="AidPrefixDisplay.TextSide.Left"
                                              ShowCopyButton="false" />
                            <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Class="bt-notif-arrow" />
                            <AidPrefixDisplay Prefix="@(n.TargetPrefix ?? "")"
                                              Name="@ResolveName(n.TargetPrefix)"
                                              ShowCopyButton="false" />
                        </div>
                        <div class="bt-notif-details">
                            <MudText Typo="@(n.IsRead ? Typo.body1 : Typo.h6)">@RouteLabel(n.Route, n)</MudText>
                            <MudText Typo="Typo.caption">@n.DateTime</MudText>
                            <MudTooltip Text="@n.Id" Delay="300">
                                <MudText Typo="Typo.caption">@Elide(n.Id, 6, 4)</MudText>
                            </MudTooltip>
                        </div>
                        @if (!n.IsRead)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text">Unread</MudChip>
                        }
                        <MudMenu Icon="@Icons.Material.Filled.MoreVert" Dense="true" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                            @if (!n.IsRead)
                            {
                                <MudMenuItem OnClick="@(() => MarkAsRead(n))" Icon="@Icons.Material.Filled.MarkEmailRead" Disabled="@IsProcessing">Mark as Read</MudMenuItem>
                            }
                            <MudMenuItem OnClick="@(() => DeleteNotification(n))" Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" Disabled="@IsProcessing">Delete</MudMenuItem>
                        </MudMenu>
                    </div>

                    @if (ExpandedNotificationId == n.Id)
                    {
                        <MudDivider />
                        <div class="bt-notif-detail-content">
                            <LoadingDiv IsLoading="@IsLoadingExchange">
                                @if (ExchangeLoadError is not null)
                                {
                                    <MudAlert Severity="Severity.Warning" Dense="true">@ExchangeLoadError</MudAlert>
                                }
                                else if (ExpandedExchangeData is not null)
                                {
                                    <NotificationExchangeDetail Exchange="@ExpandedExchangeData.Value"
                                                                Route="@n.Route"
                                                                OnAdmit="@(() => AdmitCredential(n))"
                                                                IsAdmitting="@IsAdmitting"
                                                                IsAlreadyAdmitted="@IsAlreadyAdmitted"
                                                                OnAgree="@(() => AgreeToOffer(n))"
                                                                IsAgreeing="@IsAgreeing"
                                                                IsAlreadyAgreed="@IsAlreadyAgreed"
                                                                OnOfferIssuance="@(() => OfferCredential(n))"
                                                                IsOffering="@IsOffering"
                                                                IsAlreadyOffered="@IsAlreadyOffered"
                                                                OnGrant="@(() => GrantFromNotification(n))"
                                                                IsGranting="@IsGranting"
                                                                IsAlreadyGranted="@IsAlreadyGranted"
                                                                OnGrantPresentation="@(() => GrantPresentationFromNotification(n))"
                                                                IsGrantingPresentation="@IsGrantingPresentation"
                                                                OnOfferPresentation="@(() => OfferPresentationFromNotification(n))"
                                                                IsOfferingPresentation="@IsOfferingPresentation"
                                                                IsLoadingPrior="@IsLoadingPrior" />
                                }
                            </LoadingDiv>
                        </div>
                    }
                </MudCard>
            }

            @if (IsProcessing)
            {
                <div style="display:flex; align-items: center; justify-content:center; padding: 24px;">
                    <MudProgressCircular Color="Color.Default" Indeterminate="true" />
                </div>
            }
        </div>
    </MudStack>
    <MudStack Row="true" class="bt-button-tray">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBackIosNew" Variant="Variant.Text" OnClick='@(async () => await Helper.PreviousPage.GoBack(js))' Class="justify-start" />
        <MudSpacer />
    </MudStack>
</div>
